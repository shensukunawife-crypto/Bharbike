PORT=3000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Prefer SUPABASE_KEY or any of the fallbacks below (service_role on server)
SUPABASE_KEY=your_service_role_secret
# service_role secret — Dashboard → Settings → API → service_role (NOT anon / NOT publishable)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
# optional legacy fallback:
SUPABASE_SERVICE_KEY=your_service_role_secret
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Optional local fallback for legacy /api/auth/login demo flow only:
DEMO_OTP=123456
ENABLE_DEMO_OTP=true
# Optional comma-separated frontend origins for CORS
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Razorpay (optional — overrides DB payment_configs when both set)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_MODE=test
