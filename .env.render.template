# ============================================
# BharBike Backend - Render Environment Variables
# Copy these to Render Dashboard → Environment
# ============================================

# ============================================
# SERVER CONFIGURATION (Required)
# ============================================
PORT=10000
NODE_ENV=production

# ============================================
# SUPABASE (Required)
# Get from: Supabase Dashboard → Settings → API
# ============================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ IMPORTANT: Use service_role key (NOT anon key)
# Find it in: Supabase → Settings → API → service_role (secret)

# ============================================
# SECURITY (Required)
# ============================================
JWT_SECRET=GENERATE_32_CHAR_RANDOM_STRING_HERE

# Generate JWT_SECRET using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ============================================
# ADMIN CREDENTIALS (Required)
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# ⚠️ IMPORTANT: Change the default password!

# ============================================
# CORS ORIGINS (Required)
# ============================================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Add your frontend URLs (comma-separated, no spaces)
# Examples:
# - Production: https://bharbike.com,https://www.bharbike.com
# - Staging: https://staging.bharbike.com
# - Local: http://localhost:8081,http://localhost:19006

# ============================================
# RAZORPAY PAYMENT GATEWAY (Required)
# Get from: Razorpay Dashboard → Settings → API Keys
# ============================================
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET
RAZORPAY_MODE=test

# Start with test mode, switch to live after testing:
# RAZORPAY_MODE=live

# ============================================
# DEMO MODE (Optional - Disable in Production)
# ============================================
ENABLE_DEMO_OTP=false
DEMO_OTP=123456

# ⚠️ Set ENABLE_DEMO_OTP=false for production!

# ============================================
# GPS TRACKING (Optional)
# Only if using Loconav integration
# ============================================
# LOCONAV_USER_AUTH_TOKEN=your_loconav_token_here

# ============================================
# NOTES
# ============================================
# 
# 1. Never commit this file with real values to Git
# 2. Keep service_role key secret (server-side only)
# 3. Use strong passwords (12+ characters)
# 4. Update CORS_ORIGINS with actual frontend URLs
# 5. Start with test mode for Razorpay
# 6. Disable demo OTP in production
# 
# ============================================
