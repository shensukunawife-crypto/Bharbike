<style>
  /* Premium Ad management view styling */
  main.main-content > section.panel:has(.ads-page) {
    outline: none !important;
    border: none !important;
    box-shadow: none !important;
    background: transparent !important;
    padding: 0 !important;
  }

  .ads-page {
    --ads-ring: rgba(234, 179, 8, 0.45);
    animation: adsFade 0.35s ease-out;
    accent-color: #ca8a04;
  }
  .ads-page .ads-card--form,
  .ads-page #ads-form,
  .ads-page section.ads-card {
    outline: none !important;
  }
  .ads-page #ads-form:focus-within {
    outline: none !important;
  }
  @keyframes adsFade {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .ads-hero {
    margin-bottom: 1.5rem;
  }
  .ads-hero h1 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .ads-hero p {
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .ads-split {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .ads-split {
      grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
    }
  }
  .ads-card {
    background: #ffffff;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    box-shadow:
      0 4px 6px -1px rgb(15 23 42 / 0.07),
      0 2px 4px -2px rgb(15 23 42 / 0.05);
    padding: 1.5rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.2s ease;
  }
  .ads-card:hover {
    border-color: #d1d5db;
    box-shadow:
      0 10px 15px -3px rgb(15 23 42 / 0.08),
      0 4px 6px -4px rgb(15 23 42 / 0.05);
  }
  .ads-card-title {
    margin: 0 0 1rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }
  .ads-form-stack {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ads-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin-bottom: 0.35rem;
  }
  .ads-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    font-size: 0.95rem;
    color: var(--text);
    background: #ffffff;
    outline: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }
  .ads-input:focus {
    border-color: #eab308;
    box-shadow: 0 0 0 3px var(--ads-ring);
    outline: none;
  }
  .ads-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    margin-top: 0.25rem;
    padding: 0.85rem 1.25rem;
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    color: #ffffff;
    background: linear-gradient(90deg, #facc15 0%, #eab308 100%);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.12);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      filter 0.2s ease;
  }
  .ads-btn:hover {
    filter: brightness(1.05);
    box-shadow: 0 10px 15px -3px rgb(234 179 8 / 0.35);
    transform: translateY(-1px);
  }
  .ads-btn:active {
    transform: translateY(0);
  }
  .ads-stats-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ads-stat-mini {
    background: #ffffff;
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid #f3f4f6;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  .ads-stat-mini:hover {
    transform: translateY(-2px);
    border-color: rgba(234, 179, 8, 0.35);
    box-shadow: 0 8px 15px -4px rgb(0 0 0 / 0.1);
  }
  .ads-stat-mini .label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b7280;
    margin-bottom: 0.35rem;
  }
  .ads-stat-mini .value {
    font-size: 1.65rem;
    font-weight: 700;
    color: #111827;
    line-height: 1.2;
  }
  .ads-table-wrap {
    margin-top: 1.5rem;
    background: #ffffff;
    border-radius: 1rem;
    border: 1px solid #f3f4f6;
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.08),
      0 4px 6px -4px rgb(0 0 0 / 0.06);
    padding: 1rem;
  }
  .ads-table-inner {
    overflow-x: auto;
  }
  .ads-table-wrap .table {
    margin: 0;
  }
  .ads-table-wrap .table th {
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: #374151 !important;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }
  .ads-table-wrap .table tbody tr:hover {
    background: #fffbeb !important;
  }
  .ads-status {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .ads-status--inactive {
    background: #fee2e2;
    color: #dc2626;
  }
  .ads-status--active {
    background: #dcfce7;
    color: #15803d;
  }
  .ads-empty {
    text-align: center;
    padding: 3rem 1.5rem;
    color: #6b7280;
  }
  .ads-empty-icon {
    font-size: 2.75rem;
    line-height: 1;
    margin-bottom: 0.75rem;
    opacity: 0.85;
  }
  .ads-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    border: 1px solid #e5e7eb;
    background: #ffffff;
    color: #4b5563;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }
  .ads-action-btn:hover {
    background: #f3f4f6;
    border-color: #d1d5db;
    transform: scale(1.05);
  }
  .ads-action-btn--delete:hover {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #dc2626;
  }
  .ads-thumbnail {
    width: 80px;
    height: 45px;
    object-fit: cover;
    border-radius: 0.375rem;
    border: 1px solid #e5e7eb;
    background: #f3f4f6;
  }
</style>

<% var _ads = ads || []; %>
<% var _activeCount = _ads.filter(a => a.status === 'active').length; %>
<% var _inactiveCount = _ads.filter(a => a.status === 'inactive').length; %>

<div class="ads-page">
  <div class="ads-hero">
    <h1>Advertisement & Banner Campaigns</h1>
    <p>Manage in-app promotional banners displayed on the rider home and discover pages.</p>
  </div>

  <div class="ads-split">
    <!-- Form Panel -->
    <section class="ads-card ads-card--form" aria-labelledby="ads-form-heading">
      <h2 id="ads-form-heading" class="ads-card-title">Add Campaign Banner</h2>
      <form id="ads-form" class="ads-form-stack" autocomplete="off">
        <div>
          <label class="ads-label" for="ad-title">Campaign Title</label>
          <input id="ad-title" name="title" class="ads-input" type="text" placeholder="e.g. Monsoon Rider Discount 20%" required />
        </div>
        <div>
          <label class="ads-label" for="ad-image">Banner Image URL</label>
          <input id="ad-image" name="image_url" class="ads-input" type="url" placeholder="https://example.com/banner.jpg" required />
        </div>
        <div>
          <label class="ads-label" for="ad-link">Target Link URL (Optional)</label>
          <input id="ad-link" name="link_url" class="ads-input" type="url" placeholder="https://example.com/promo-details" />
        </div>
        <div>
          <label class="ads-label" for="ad-status">Initial Status</label>
          <select id="ad-status" name="status" class="ads-input">
            <option value="active" selected>Active (Live immediately)</option>
            <option value="inactive">Inactive (Draft)</option>
          </select>
        </div>
        <button type="submit" class="ads-btn" id="ad-submit">
          <span>📢</span>
          Launch Banner Campaign
        </button>
      </form>
    </section>

    <!-- Stats Panel -->
    <aside class="ads-stats-stack" aria-label="Summary statistics">
      <div class="ads-stat-mini">
        <div class="label">Total Campaigns</div>
        <div class="value" id="stat-total"><%= _ads.length %></div>
      </div>
      <div class="ads-stat-mini">
        <div class="label">Active Live Banners</div>
        <div class="value" id="stat-active"><%= _activeCount %></div>
      </div>
      <div class="ads-stat-mini">
        <div class="label">Inactive Drafts</div>
        <div class="value" id="stat-inactive"><%= _inactiveCount %></div>
      </div>
    </aside>
  </div>

  <!-- Table List Panel -->
  <div class="ads-table-wrap">
    <h2 class="ads-card-title" style="margin: 0 0 0.75rem">Campaign Registry</h2>
    <div id="ads-table-container">
      <% if (!_ads.length) { %>
      <div id="ads-empty" class="ads-empty">
        <div class="ads-empty-icon">📢</div>
        <h3>No advertising campaigns found</h3>
        <p>Use the form above to add and schedule your first promotional banner.</p>
      </div>
      <div id="ads-table-inner" class="ads-table-inner" style="display: none;"></div>
      <% } else { %>
      <div id="ads-empty" class="ads-empty" style="display: none"></div>
      <div id="ads-table-inner" class="ads-table-inner">
        <div class="table-wrap">
          <table class="table" id="ads-table">
            <thead>
              <tr>
                <th>Banner Preview</th>
                <th>Campaign Title</th>
                <th>Target Action URL</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="ads-tbody">
              <% _ads.forEach(function(ad) { %>
              <tr>
                <td>
                  <img src="<%= ad.image_url %>" class="ads-thumbnail" alt="Banner Preview" onerror="this.src='/admin/static/images/logo.png'" />
                </td>
                <td style="font-weight: 600; color: #111;"><%= ad.title %></td>
                <td><a href="<%= ad.link_url || '#' %>" target="_blank" style="color: #ca8a04; text-decoration: underline;"><%= ad.link_url || '—' %></a></td>
                <td>
                  <span class="ads-status <%= ad.status === 'active' ? 'ads-status--active' : 'ads-status--inactive' %>">
                    <%= ad.status === 'active' ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td>
                  <div style="display: flex; gap: 0.35rem;">
                    <button type="button" class="ads-action-btn" onclick="toggleAdStatus('<%= ad.id %>')" title="Toggle Live State">🔄</button>
                    <button type="button" class="ads-action-btn ads-action-btn--delete" onclick="deleteAdRecord('<%= ad.id %>')" title="Delete Campaign">🗑️</button>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  (function () {
    var form = document.getElementById("ads-form");
    var emptyEl = document.getElementById("ads-empty");
    var tableInner = document.getElementById("ads-table-inner");

    function escapeHtml(s) {
      var d = document.createElement("div");
      d.textContent = s;
      return d.innerHTML;
    }

    function renderRows(rows) {
      if (!tableInner || !emptyEl) return;
      
      document.getElementById("stat-total").textContent = String(rows.length);
      document.getElementById("stat-active").textContent = String(rows.filter(a => a.status === 'active').length);
      document.getElementById("stat-inactive").textContent = String(rows.filter(a => a.status === 'inactive').length);

      if (!rows || !rows.length) {
        emptyEl.style.display = "block";
        tableInner.style.display = "none";
        tableInner.innerHTML = "";
        return;
      }

      emptyEl.style.display = "none";
      tableInner.style.display = "block";

      var html = '<div class="table-wrap"><table class="table" id="ads-table"><thead><tr>' +
        '<th>Banner Preview</th><th>Campaign Title</th><th>Target Action URL</th><th>Status</th><th>Actions</th></tr></thead><tbody>';

      rows.forEach(function (ad) {
        var statusClass = ad.status === 'active' ? 'ads-status--active' : 'ads-status--inactive';
        var statusLabel = ad.status === 'active' ? 'Active' : 'Inactive';
        var targetLink = ad.link_url ? '<a href="' + escapeHtml(ad.link_url) + '" target="_blank" style="color: #ca8a04; text-decoration: underline;">' + escapeHtml(ad.link_url) + '</a>' : '—';

        html += '<tr>' +
          '<td><img src="' + escapeHtml(ad.image_url) + '" class="ads-thumbnail" alt="Banner Preview" onerror="this.src=\'/admin/static/images/logo.png\'" /></td>' +
          '<td style="font-weight: 600; color: #111;">' + escapeHtml(ad.title) + '</td>' +
          '<td>' + targetLink + '</td>' +
          '<td><span class="ads-status ' + statusClass + '">' + statusLabel + '</span></td>' +
          '<td><div style="display: flex; gap: 0.35rem;">' +
          '<button type="button" class="ads-action-btn" onclick="toggleAdStatus(\'' + escapeHtml(ad.id) + '\')" title="Toggle Live State">🔄</button>' +
          '<button type="button" class="ads-action-btn ads-action-btn--delete" onclick="deleteAdRecord(\'' + escapeHtml(ad.id) + '\')" title="Delete Campaign">🗑️</button>' +
          '</div></td></tr>';
      });

      html += '</tbody></table></div>';
      tableInner.innerHTML = html;
    }

    async function refreshAdsTable() {
      try {
        var res = await fetch("/admin/ads", { headers: { Accept: "application/json" } });
        // Handled by client-side router or direct EJS API fetch fallback:
        var text = await res.text();
        if (text.trim().startsWith("[")) {
          var rows = JSON.parse(text);
          renderRows(rows);
        } else {
          // If HTML returned, reload page to refresh EJS state smoothly
          window.location.reload();
        }
      } catch (e) {
        console.error("REFRESH ERROR:", e);
      }
    }

    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      var title = document.getElementById("ad-title").value.trim();
      var image_url = document.getElementById("ad-image").value.trim();
      var link_url = document.getElementById("ad-link").value.trim();
      var status = document.getElementById("ad-status").value;

      try {
        var res = await fetch("/admin/ads/add", {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify({ title, image_url, link_url, status }),
        });
        var data = await res.json();
        if (!res.ok) {
          alert(data.message || "Failed to launch campaign banner");
          return;
        }

        if (typeof showToast === "function") {
          showToast("Campaign banner launched successfully! 🚀");
        } else {
          alert("Campaign banner launched successfully! 🚀");
        }
        form.reset();
        refreshAdsTable();
      } catch (err) {
        console.error("LAUNCH ERROR:", err);
        alert("Launch Failed ❌");
      }
    });

    window.toggleAdStatus = async function (id) {
      if (!id) return;
      try {
        var res = await fetch("/admin/ads/" + id + "/toggle", {
          method: "POST",
          headers: { Accept: "application/json" }
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.message || "Toggle failed");

        if (typeof showToast === "function") {
          showToast("Campaign status updated to " + data.nextStatus);
        } else {
          alert("Campaign status updated to " + data.nextStatus + " ✅");
        }
        refreshAdsTable();
      } catch (err) {
        console.error("TOGGLE ERROR:", err);
        alert("Failed to toggle status: " + err.message);
      }
    };

    window.deleteAdRecord = async function (id) {
      if (!id) return;
      if (!confirm("Are you sure you want to delete this advertising campaign? This action is permanent!")) return;
      try {
        var res = await fetch("/admin/ads/" + id + "/delete", {
          method: "POST",
          headers: { Accept: "application/json" }
        });
        var data = await res.json();
        if (!res.ok) throw new Error(data.message || "Delete failed");

        if (typeof showToast === "function") {
          showToast("Campaign deleted successfully");
        } else {
          alert("Campaign deleted successfully ✅");
        }
        refreshAdsTable();
      } catch (err) {
        console.error("DELETE ERROR:", err);
        alert("Failed to delete campaign: " + err.message);
      }
    };
  })();
</script>
