<div class="stats-grid">
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">🚲</span><span class="stat-label">Bike ID</span></div><strong class="stat-value"><%= bike.bike_code %></strong></div>
  <% if (bike.model) { %>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">🏍️</span><span class="stat-label">Model</span></div><strong class="stat-value"><%= bike.model %></strong></div>
  <% } %>
  <% if (bike.color) { %>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">🎨</span><span class="stat-label">Color</span></div><strong class="stat-value"><%= bike.color %></strong></div>
  <% } %>
  <% if (bike.year) { %>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">📅</span><span class="stat-label">Year</span></div><strong class="stat-value"><%= bike.year %></strong></div>
  <% } %>
  <% if (bike.registration_number) { %>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">🪪</span><span class="stat-label">Reg. Number</span></div><strong class="stat-value"><%= bike.registration_number %></strong></div>
  <% } %>
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">🔋</span><span class="stat-label">Battery</span></div>
    <strong class="stat-value"><%= bike.battery %>%</strong>
    <span class="badge success" style="font-size: 10px; margin-top: 4px;">Live from LocoNav</span>
  </div>
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">📍</span><span class="stat-label">Location</span></div>
    <% if (bike.isLive) { %>
      <strong class="stat-value" style="font-size: 14px; margin-bottom: 6px;"><%= Number(bike.liveLat).toFixed(4) %>, <%= Number(bike.liveLng).toFixed(4) %></strong>
      <button onclick="openMapModal(<%= bike.liveLat %>, <%= bike.liveLng %>)" class="btn btn-sm btn-gold glow" style="font-size: 11px; padding: 4px 8px; border-radius: 4px; margin-bottom: 4px; cursor: pointer; display: flex; align-items: center; gap: 4px; justify-content: center; width: 100%;">🗺️ View Live Map</button>
      <span class="badge success" style="font-size: 10px; margin-top: 4px;">GPS Live</span>
    <% } else { %>
      <strong class="stat-value"><%= bike.location %></strong>
      <span class="badge" style="font-size: 10px; margin-top: 4px;">Static (Last Known)</span>
    <% } %>
  </div>

  <div class="stat-card" style="display: flex; flex-direction: column; justify-content: space-between;">
    <div>
      <div class="stat-head">
        <span class="stat-icon">🔒</span>
        <span class="stat-label">Smart Lock</span>
      </div>
      <strong class="stat-value" style="color: <%= bike.is_locked !== false ? '#f87171' : '#4ade80' %>; font-size: 24px;">
        <%= bike.is_locked !== false ? "Locked 🔒" : "Unlocked 🔓" %>
      </strong>
    </div>
    <div style="display: flex; gap: 8px; margin-top: 12px;">
      <button class="btn btn-sm btn-danger admin-action" data-url="/admin/bikes/<%= bike.id %>/lock" data-method="POST" style="flex: 1; padding: 8px 12px; font-size: 12px; font-weight: 700; border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 4px;">
        Lock
      </button>
      <button class="btn btn-sm btn-success admin-action" data-url="/admin/bikes/<%= bike.id %>/unlock" data-method="POST" style="flex: 1; padding: 8px 12px; font-size: 12px; font-weight: 700; border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 4px; background-color: #22c55e; border-color: #22c55e; color: white;">
        Unlock
      </button>
    </div>
  </div>
  <div class="stat-card" style="display: flex; flex-direction: column; justify-content: space-between;">
    <div>
      <div class="stat-head">
        <span class="stat-icon">📡</span>
        <span class="stat-label">GPS Tracker ID</span>
      </div>
      <strong class="stat-value" style="font-size: 14.5px; word-break: break-all; margin-top: 4px; display: block; color: <%= bike.tracker_uuid ? 'var(--accent)' : '#9ca3af' %>;">
        <%= bike.tracker_uuid || "⚠️ None Linked" %>
      </strong>
    </div>
    <form class="ajax-form" data-url="/admin/bikes/<%= bike.id %>/link-gps" style="margin-top: 12px; display: flex; flex-direction: column; gap: 8px;">
      <input type="text" name="device_uuid" placeholder="GPS Tracker UUID" value="<%= bike.tracker_uuid || '' %>" style="width: 100%; padding: 8px 10px; font-size: 12px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg); color: var(--text); font-family: inherit;" />
      <button type="submit" class="btn btn-sm btn-gold glow" style="width: 100%; padding: 8px; font-size: 12px; border-radius: 6px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 4px; background: var(--accent); border: none; color: #fff;">
        🔗 Link / Update GPS
      </button>
    </form>
    </form>
  </div>
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">📊</span><span class="stat-label">Total Trips</span></div>
    <strong class="stat-value"><%= totalTrips %></strong>
  </div>
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">💰</span><span class="stat-label">Revenue</span></div>
    <strong class="stat-value">₹<%= Number(totalRevenue).toLocaleString('en-IN') %></strong>
  </div>
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">👤</span><span class="stat-label">Current Renter</span></div>
    <strong class="stat-value" style="font-size: 14px; word-break: break-all;">
      <%= currentRenter || "Available" %>
    </strong>
  </div>
</div>
<div class="analytics-grid">
  <div class="chart-card">
    <h3>Usage History</h3>
    <div class="table-wrap">
      <table class="table">
        <thead><tr><th>Rental ID</th><th>User</th><th>Start</th><th>End</th><th>Status</th></tr></thead>
        <tbody>
          <% if (!usageHistory.length) { %><tr><td colspan="5" class="empty">No usage history</td></tr><% } %>
          <% usageHistory.forEach((row) => { %>
          <tr>
            <td><code style="font-size:11px" title="<%= row.id %>"><%= row.shortId %></code></td>
            <td><%= row.userName %></td>
            <td><%= String(row.startTime || row.start_time || "-").replace("T", " ").slice(0, 16) %></td>
            <td><%= String(row.endTime || row.end_time || "-").replace("T", " ").slice(0, 16) %></td>
            <td><span class="badge"><%= row.status || "-" %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="chart-card">
    <h3>Related Payments</h3>
    <div class="table-wrap">
      <table class="table">
        <thead><tr><th>Order ID</th><th>User</th><th>Amount</th><th>Status</th></tr></thead>
        <tbody>
          <% if (!ordersHistory.length) { %><tr><td colspan="4" class="empty">No related payments</td></tr><% } %>
          <% ordersHistory.forEach((row) => { %>
          <tr>
            <td><%= row.shortId %></td>
            <td><%= row.userName %></td>
            <td>₹<%= Number(row.amount || 0).toFixed(2) %></td>
            <td><span class="badge"><%= row.status %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="chart-card">
  <h3>Maintenance Logs</h3>
  <div class="table-wrap">
    <table class="table">
      <thead><tr><th>Issue</th><th>Status</th><th>Cost</th><th>Date</th></tr></thead>
      <tbody>
        <% if (!maintenanceLogs.length) { %><tr><td colspan="4" class="empty">No maintenance logs</td></tr><% } %>
        <% maintenanceLogs.forEach((log) => { %>
        <tr>
          <td><%= log.issue %></td>
          <td><span class="badge"><%= log.status %></span></td>
          <td>₹<%= Number(log.cost || 0).toFixed(2) %></td>
          <td><%= log.date %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<!-- Map Modal -->
<div class="modal" id="map-modal">
  <div class="modal-card" style="width: 90%; max-width: 600px; padding: 20px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 16px;">
      <h3 style="margin:0;">Bike Live Location</h3>
      <button type="button" style="background:none; border:none; font-size:24px; cursor:pointer; color:#6b7280;" onclick="closeMapModal()">&times;</button>
    </div>
    <div id="bike-map" style="height: 400px; width: 100%; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;"></div>
  </div>
</div>

<script>
let bikeMap = null;
let bikeMarker = null;

function openMapModal(lat, lng) {
  const modal = document.getElementById("map-modal");
  modal.classList.add("show");
  
  // Need to use a slight timeout to ensure the modal is visible before rendering the map, 
  // otherwise Leaflet tiles might not load correctly due to incorrect container dimensions.
  setTimeout(() => {
    if (!bikeMap) {
      bikeMap = L.map("bike-map").setView([lat, lng], 15);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution: "� OpenStreetMap contributors"
      }).addTo(bikeMap);
      
      bikeMarker = L.marker([lat, lng]).addTo(bikeMap)
        .bindPopup("<b>Bike Location</b><br>Lat: " + lat + "<br>Lng: " + lng).openPopup();
    } else {
      bikeMap.setView([lat, lng], 15);
      bikeMarker.setLatLng([lat, lng]);
      bikeMap.invalidateSize();
    }
  }, 100);
}

function closeMapModal() {
  document.getElementById("map-modal").classList.remove("show");
}
</script>
</script>

<script>
  // Real-time GPS Polling
  function pollLiveGPS() {
    fetch('/api/admin/bikes/<%= bike.id %>/live-gps')
      .then(res => res.json())
      .then(data => {
        if(data && data.success) {
           // If map is open and new coords received, update marker
           if(bikeMap && bikeMarker && data.isLive) {
              bikeMap.setView([data.lat, data.lng], 15);
              bikeMarker.setLatLng([data.lat, data.lng]);
           }
        }
      })
      .catch(console.error);
  }
  // Poll every 10 seconds
  setInterval(pollLiveGPS, 10000);
</script>
