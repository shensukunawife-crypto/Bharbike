<div class="toolbar">
  <button class="btn btn-gold" data-modal-target="add-bike-modal">+ Add Bike</button>
  <form class="toolbar" method="get" action="/admin/bikes">
    <input class="filter-input" type="text" name="search" placeholder="Search Bike ID" value="<%= filters.search %>" />
    <select class="filter-input" name="status">
      <option value="all" <%= filters.status === "all" ? "selected" : "" %>>All Status</option>
      <option value="available" <%= filters.status === "available" ? "selected" : "" %>>Available</option>
      <option value="in_use" <%= filters.status === "in_use" ? "selected" : "" %>>In Use</option>
      <option value="maintenance" <%= filters.status === "maintenance" ? "selected" : "" %>>Maintenance</option>
      <option value="offline" <%= filters.status === "offline" ? "selected" : "" %>>Offline</option>
    </select>
    <label class="switch-row">
      Low Battery
      <input type="checkbox" name="lowBattery" value="true" <%= filters.lowBattery ? "checked" : "" %> />
      <span class="switch"></span>
    </label>
    <button type="submit" class="btn btn-gold">Apply</button>
  </form>
</div>
<div class="table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>Bike ID</th>
        <th>Status</th>
        <th>Lock Status</th>
        <th>Usage</th>
        <th>Battery %</th>
        <th>Location</th>
        <th>Last Service</th>
        <th>Health</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!bikes.length) { %>
      <tr><td colspan="8" class="empty">No bikes found</td></tr>
      <% } %>
      <% bikes.forEach((bike) => { %>
      <tr>
        <td><%= bike.bike_code %></td>
        <td>
          <span class="badge <%= bike.status === 'available' ? 'success' : bike.status === 'in_use' ? 'warning' : bike.status === 'maintenance' ? 'danger' : '' %>">
            <%= bike.statusLabel %>
          </span>
        </td>
        <td>
          <span class="badge <%= bike.is_locked !== false ? 'danger' : 'success' %>" style="font-size: 11px; font-weight: 600; padding: 4px 8px;">
            <%= bike.is_locked !== false ? "Locked 🔒" : "Unlocked 🔓" %>
          </span>
        </td>
        <td><%= bike.usage %></td>
        <td>
          <div class="battery-wrap">
            <div class="battery-bar">
              <span class="battery-fill <%= bike.battery > 60 ? 'good' : bike.battery > 30 ? 'mid' : 'low' %>" style="width: <%= bike.battery %>%"></span>
            </div>
            <small><%= bike.battery %>%</small>
          </div>
        </td>
        <td><%= bike.location %></td>
        <td><%= bike.lastServiceDate %></td>
        <td>
          <span class="badge <%= bike.healthStatus === 'Good' ? 'success' : bike.healthStatus === 'Average' ? 'warning' : 'danger' %>">
            <%= bike.healthStatus %>
          </span>
        </td>
        <td class="actions">
          <a class="btn btn-ghost" href="/admin/bikes/<%= bike.id %>">View Details</a>
          <button class="btn btn-gold" onclick="openAssignModal('<%= bike.id %>', '<%= bike.bike_code %>')">Assign Bike</button>
          <button class="btn btn-ghost admin-action" data-url="/admin/bikes/<%= bike.id %>/maintenance" data-method="POST">Send to Maintenance</button>
          <button class="btn btn-danger admin-action" data-url="/admin/bikes/<%= bike.id %>/disable" data-method="POST">Disable Bike</button>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="modal" id="add-bike-modal">
  <div class="modal-card">
    <h3>Add Bike</h3>
    <form class="admin-form ajax-form" data-url="/admin/bikes/add">
      <input name="bike_code" placeholder="Bike ID" required />
      <select name="status">
        <option value="available">Available</option>
        <option value="in_use">In Use</option>
        <option value="maintenance">Maintenance</option>
        <option value="offline">Offline</option>
      </select>
      <input type="number" name="battery" min="0" max="100" placeholder="Battery %" />
      <input name="location" placeholder="Location" />
      <input type="date" name="lastServiceDate" />
      <button type="submit" class="btn btn-gold glow">Create</button>
    </form>
  </div>
</div>

<div class="modal" id="assign-bike-modal">
  <div class="modal-card">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h3>Assign Bike <span id="assign-bike-code" style="color:#f59e0b; font-size: 16px;"></span></h3>
      <button type="button" style="background:none; border:none; font-size:24px; cursor:pointer; color:#6b7280;" onclick="closeAssignModal()">&times;</button>
    </div>
    <form class="admin-form ajax-form" id="assign-bike-form" data-url="">
      <select name="user_id" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #d1d5db; margin-bottom: 12px; background: #f8fafc; font-size: 14px;">
        <option value="">Select User (Search by typing)...</option>
        <% users.forEach(user => { %>
          <option value="<%= user.id %>"><%= user.full_name || user.name || "Unknown User" %> - <%= user.phone || user.email || "No Contact" %></option>
        <% }) %>
      </select>
      <label style="display: block; margin-bottom: 6px; font-size: 13px; color: #4b5563; font-weight: 500;">Rental Duration (Hours)</label>
      <input type="number" name="duration_hours" value="24" min="1" required />
      <button type="submit" class="btn btn-gold glow">Assign to User</button>
    </form>
  </div>
</div>

<script>
function openAssignModal(bikeId, bikeCode) {
  const modal = document.getElementById('assign-bike-modal');
  const form = document.getElementById('assign-bike-form');
  document.getElementById('assign-bike-code').innerText = '(' + bikeCode + ')';
  form.setAttribute('data-url', '/admin/bikes/' + bikeId + '/assign');
  modal.classList.add('show');
}
function closeAssignModal() {
  document.getElementById('assign-bike-modal').classList.remove('show');
}
</script>
