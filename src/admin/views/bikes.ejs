<div class="toolbar" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 12px;">
  <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
    <button class="btn btn-gold" data-modal-target="add-bike-modal" style="padding: 8px 16px; border-radius: 8px; font-weight: 600;">+ Add Bike</button>
    <form style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin: 0;" method="get" action="/admin/bikes">
      <input class="filter-input" type="text" name="search" placeholder="Search Bike ID" value="<%= filters.search %>" style="margin: 0; padding: 8px 12px; border-radius: 8px;" />
      <select class="filter-input" name="status" style="margin: 0; padding: 8px 12px; border-radius: 8px;">
        <option value="all" <%= filters.status === "all" ? "selected" : "" %>>All Status</option>
        <option value="available" <%= filters.status === "available" ? "selected" : "" %>>Available</option>
        <option value="in_use" <%= filters.status === "in_use" ? "selected" : "" %>>In Use</option>
        <option value="maintenance" <%= filters.status === "maintenance" ? "selected" : "" %>>Maintenance</option>
        <option value="offline" <%= filters.status === "offline" ? "selected" : "" %>>Offline</option>
      </select>
      <label class="switch-row" style="margin: 0; display: flex; align-items: center; gap: 6px; font-size: 13px;">
        Low Battery
        <input type="checkbox" name="lowBattery" value="true" <%= filters.lowBattery ? "checked" : "" %> />
        <span class="switch"></span>
      </label>
      <button type="submit" class="btn btn-gold" style="padding: 8px 16px; border-radius: 8px;">Apply</button>
    </form>
  </div>
  
  <div class="export-center" style="display: flex; gap: 12px; align-items: center;">
    <a href="/admin/bikes/export/excel?search=<%= filters.search %>&status=<%= filters.status %>&lowBattery=<%= filters.lowBattery %>" class="btn btn-ghost" style="border: 1px solid #10b981; color: #10b981; display: flex; align-items: center; gap: 8px; font-weight: 600; padding: 8px 16px; border-radius: 8px; text-decoration: none; transition: background-color 0.2s;">
      <span>📥</span> Export Excel (.xlsx)
    </a>
    <a href="/admin/bikes/export/pdf?search=<%= filters.search %>&status=<%= filters.status %>&lowBattery=<%= filters.lowBattery %>" target="_blank" class="btn btn-gold" style="display: flex; align-items: center; gap: 8px; font-weight: 600; padding: 8px 16px; border-radius: 8px; text-decoration: none;">
      <span>📄</span> Download PDF Report
    </a>
  </div>
</div>

<div class="table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>Bike ID</th>
        <th>Status</th>
        <th>Lock Status</th>
        <th>Present Rider</th>
        <th>Usage</th>
        <th>Battery %</th>
        <th>Location</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!bikes.length) { %>
      <tr><td colspan="8" class="empty">No bikes found</td></tr>
      <% } %>
      <% bikes.forEach((bike) => { %>
      <tr>
        <td><%= bike.bike_code %></td>
        <td>
          <span class="badge <%= bike.status === 'available' ? 'success' : bike.status === 'in_use' ? 'warning' : bike.status === 'maintenance' ? 'danger' : '' %>">
            <%= bike.statusLabel %>
          </span>
        </td>
        <td>
          <span class="badge <%= bike.is_locked !== false ? 'danger' : 'success' %>" style="font-size: 11px; font-weight: 600; padding: 4px 8px;">
            <%= bike.is_locked !== false ? "Locked 🔒" : "Unlocked 🔓" %>
          </span>
        </td>
        <td>
          <% if (bike.riderName && bike.riderName !== '-') { %>
            <strong style="color: var(--accent);"><%= bike.riderName %></strong>
            <% if (bike.riderPhone) { %>
              <div style="font-size: 11px; color: var(--text-muted);"><%= bike.riderPhone %></div>
            <% } %>
          <% } else { %>
            <span class="text-muted-foreground">-</span>
          <% } %>
        </td>
        <td><%= bike.usage %></td>
        <td class="battery-cell">
          <div class="battery-wrap">
            <div class="battery-bar">
              <span class="battery-fill <%= bike.battery > 60 ? 'good' : bike.battery > 30 ? 'mid' : 'low' %>" style="width: <%= bike.battery %>%"></span>
            </div>
            <small><%= bike.battery %>%</small>
          </div>
        </td>
        <td class="location-cell"><%= bike.location %></td>
        <td class="actions">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; align-items: center; min-width: 260px;">
            <a class="btn btn-ghost" href="/admin/bikes/<%= bike.id %>" style="display: flex; justify-content: center; padding: 6px 10px; font-size: 12px;">View Details</a>
            <button class="btn btn-gold" onclick="openAssignModal('<%= bike.id %>', '<%= bike.bike_code %>')" style="padding: 6px 10px; font-size: 12px;">Assign Bike</button>
            <button class="btn btn-ghost check-status-btn" data-id="<%= bike.id %>" style="grid-column: span 2; padding: 6px 10px; font-size: 12px; border: 1px solid var(--accent); color: var(--accent); font-weight: 700; background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px;">🔍 Status Check</button>
            <button class="btn btn-ghost admin-action" data-url="/admin/bikes/<%= bike.id %>/maintenance" data-method="POST" style="grid-column: span 2; padding: 6px 10px; font-size: 12px;">Send to Maintenance</button>
            <button class="btn btn-<%= bike.status === 'offline' ? 'success' : 'danger' %> admin-action" data-url="/admin/bikes/<%= bike.id %>/disable" data-method="POST" style="padding: 6px 10px; font-size: 12px;"><%= bike.status === 'offline' ? '✅ Enable Bike' : '🚫 Disable Bike' %></button>
            <button class="btn btn-danger admin-action" data-url="/admin/bikes/<%= bike.id %>/delete" data-method="POST" data-confirm="Are you sure you want to completely delete this bike?" style="padding: 6px 10px; font-size: 12px;">Delete</button>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="modal" id="add-bike-modal">
  <div class="modal-card">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 16px;">
      <h3>Add Bike</h3>
      <button type="button" style="background:none; border:none; font-size:24px; cursor:pointer; color:#6b7280;" onclick="document.getElementById('add-bike-modal').classList.remove('show')">&times;</button>
    </div>
    <form class="admin-form ajax-form" data-url="/admin/bikes/add">
      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">Bike ID / Code <span style="color:red">*</span></label>
      <input name="bike_code" placeholder="e.g. BB001" required />

      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">Model Name</label>
      <input name="model" placeholder="e.g. Hero Splendor, Honda Activa" />

      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">Color</label>
      <input name="color" placeholder="e.g. Red, Black, Blue" />

      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">Year of Manufacture</label>
      <input type="number" name="year" placeholder="e.g. 2022" min="2000" max="2030" />

      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">Registration Number</label>
      <input name="registration_number" placeholder="e.g. MH04AB1234" />

      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">GPS Tracker ID / Device UUID</label>
      <input name="device_uuid" placeholder="Optional - link GPS tracker" style="margin-bottom: 12px;" />

      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">Status</label>
      <select name="status">
        <option value="available">Available</option>
        <option value="in_use">In Use</option>
        <option value="maintenance">Maintenance</option>
        <option value="offline">Offline</option>
      </select>

      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">Battery %</label>
      <input type="number" name="battery" min="0" max="100" placeholder="Battery % (0-100)" />

      <label style="font-size:13px;color:#6b7280;margin-bottom:4px;display:block;">Location / Battery Swapping Station</label>
      <input name="location" placeholder="e.g. Bandra Station Battery Swapping Station" />

      <button type="submit" class="btn btn-gold glow" style="margin-top:8px;">Create Bike</button>
    </form>
  </div>
</div>

<div class="modal" id="assign-bike-modal">
  <div class="modal-card">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <h3>Assign Bike <span id="assign-bike-code" style="color:#f59e0b; font-size: 16px;"></span></h3>
      <button type="button" style="background:none; border:none; font-size:24px; cursor:pointer; color:#6b7280;" onclick="closeAssignModal()">&times;</button>
    </div>
    <form class="admin-form ajax-form" id="assign-bike-form" data-url="">
      <select name="user_id" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #d1d5db; margin-bottom: 12px; background: #f8fafc; font-size: 14px;">
        <option value="">Select User (Search by typing)...</option>
        <% users.forEach(user => { %>
          <option value="<%= user.id %>"><%= user.full_name || user.name || "Unknown User" %> - <%= user.phone || user.email || "No Contact" %></option>
        <% }) %>
      </select>
      <div style="display: flex; gap: 10px; margin-bottom: 15px;">
        <div style="flex: 2;">
          <label style="display: block; margin-bottom: 6px; font-size: 13px; color: #4b5563; font-weight: 500;">Rental Duration</label>
          <input type="number" name="duration_value" value="24" min="1" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #d1d5db; box-sizing: border-box; background: #f8fafc; font-size: 14px;" />
        </div>
        <div style="flex: 1;">
          <label style="display: block; margin-bottom: 6px; font-size: 13px; color: #4b5563; font-weight: 500;">Unit</label>
          <select name="duration_unit" id="duration-unit-select" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #d1d5db; background: #f8fafc; font-size: 14px; box-sizing: border-box; height: 45px;">
            <option value="hours" selected>Hours</option>
            <option value="days">Days</option>
          </select>
        </div>
      </div>
      <button type="submit" class="btn btn-gold glow">Assign to User</button>
    </form>
  </div>
</div>

<script>
function openAssignModal(bikeId, bikeCode) {
  const modal = document.getElementById('assign-bike-modal');
  const form = document.getElementById('assign-bike-form');
  document.getElementById('assign-bike-code').innerText = '(' + bikeCode + ')';
  form.setAttribute('data-url', '/admin/bikes/' + bikeId + '/assign');
  modal.classList.add('show');
}
function closeAssignModal() {
  document.getElementById('assign-bike-modal').classList.remove('show');
}

document.getElementById('duration-unit-select').addEventListener('change', function() {
  const durationInput = document.querySelector('input[name="duration_value"]');
  if (this.value === 'days') {
    durationInput.value = '1';
  } else {
    durationInput.value = '24';
  }
});

// AJAX live status checking
document.querySelectorAll('.check-status-btn').forEach(btn => {
  btn.addEventListener('click', async function(e) {
    e.preventDefault();
    const bikeId = this.getAttribute('data-id');
    const row = this.closest('tr');
    
    // UI Feedback: disable button and show checking status
    const originalText = this.innerHTML;
    this.innerHTML = '⚡ Checking...';
    this.disabled = true;
    
    try {
      const response = await fetch('/admin/bikes/' + bikeId + '/live-gps');
      const data = await response.json();
      
      if (data.success) {
        // 1. Update Battery Cell
        const batteryCell = row.querySelector('.battery-cell');
        if (batteryCell && typeof data.battery === 'number') {
          const fill = batteryCell.querySelector('.battery-fill');
          const smallText = batteryCell.querySelector('small');
          if (fill) {
            fill.style.width = data.battery + '%';
            // Update color class
            fill.classList.remove('good', 'mid', 'low');
            if (data.battery > 60) fill.classList.add('good');
            else if (data.battery > 30) fill.classList.add('mid');
            else fill.classList.add('low');
          }
          if (smallText) {
            smallText.textContent = data.battery + '%';
          }
        }
        
        // 2. Update Location Cell
        const locationCell = row.querySelector('.location-cell');
        if (locationCell) {
          if (data.lat && data.lng) {
            locationCell.textContent = Number(data.lat).toFixed(5) + ', ' + Number(data.lng).toFixed(5);
          } else {
            // Keep the last known location already in the cell, or fallback to 'Thane' if empty/placeholder
            const existingLoc = locationCell.textContent ? locationCell.textContent.trim() : '';
            if (!existingLoc || existingLoc === 'Offline / No GPS' || existingLoc === '-') {
              locationCell.textContent = 'Thane';
            }
          }
        }
        
        // Success Feedback
        this.innerHTML = '✅ Updated';
        this.style.borderColor = '#10b981';
        this.style.color = '#10b981';
      } else {
        this.innerHTML = '❌ Failed';
        this.style.borderColor = '#ef4444';
        this.style.color = '#ef4444';
      }
    } catch (err) {
      console.error('Status check failed:', err);
      this.innerHTML = '❌ Error';
      this.style.borderColor = '#ef4444';
      this.style.color = '#ef4444';
    }
    
    // Restore button after 2 seconds
    setTimeout(() => {
      this.innerHTML = originalText;
      this.style.borderColor = 'var(--accent)';
      this.style.color = 'var(--accent)';
      this.disabled = false;
    }, 2000);
  });
});
</script>
