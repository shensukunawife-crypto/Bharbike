<div class="toolbar">
  <h2 style="margin:0;font-size:1.1rem">📋 All Bookings / Active Rentals</h2>
</div>

<div class="table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>Booking ID</th>
        <th>User</th>
        <th>Bike</th>
        <th>Plan / Duration</th>
        <th>Status</th>
        <th>Start Time</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!bookings.length) { %>
      <tr><td colspan="7" class="empty">No bookings found</td></tr>
      <% } %>
      <% bookings.forEach((booking) => {
        const status = String(booking.status || '').toLowerCase();
        const badgeClass = status === 'active' ? 'success' : status === 'completed' ? 'info' : status === 'cancelled' ? 'danger' : 'warning';
      %>
      <tr>
        <td><code style="font-size:11px" title="<%= booking.id %>"><%= booking.shortId %></code></td>
        <td>
          <% if (booking.user_id) { %>
            <a href="/admin/users/<%= booking.user_id %>" class="link-gold" style="font-size:12px" title="<%= booking.user_id %>"><%= booking.shortUserId %></a>
          <% } else { %> - <% } %>
        </td>
        <td>
          <% if (booking.bike_id) { %>
            <a href="/admin/bikes/<%= booking.bike_id %>" class="link-gold" style="font-size:12px" title="<%= booking.bike_id %>"><%= booking.bike_name || booking.shortBikeId %></a>
          <% } else { %> - <% } %>
        </td>
        <td>
          <span><%= booking.plan_name || booking.duration || '-' %></span>
          <% if (booking.amount || booking.price) { %>
            <div class="table-subtext">₹<%= Number(booking.amount || booking.price || 0).toFixed(0) %></div>
          <% } %>
        </td>
        <td><span class="badge <%= badgeClass %>"><%= booking.status || '-' %></span></td>
        <td style="font-size:12px"><%= booking.start_time ? String(booking.start_time).replace('T', ' ').slice(0, 16) : '-' %></td>
        <td class="actions">
          <% if (status === 'active' || status === 'pending') { %>
            <button class="btn btn-success admin-action"
              data-url="/admin/bookings/<%= booking.id %>/complete"
              data-method="POST"
              title="Mark as completed">✔ Complete</button>
            <button class="btn btn-danger admin-action"
              data-url="/admin/bookings/<%= booking.id %>/cancel"
              data-method="POST"
              title="Cancel booking">✖ Cancel</button>
          <% } else { %>
            <span class="table-subtext">No actions</span>
          <% } %>
          <a href="/admin/users/<%= booking.user_id %>" class="btn btn-ghost" style="font-size:11px">👤 User</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
