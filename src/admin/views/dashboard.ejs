<style>
/* Dashboard specific refinements */
.db-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 24px; }
.db-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow-sm); }
.db-card-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; }

/* Growth indicator */
.growth { font-size: 11px; font-weight: 600; padding: 2px 6px; border-radius: 4px; margin-left: 8px; }
.growth.up { background: rgba(22, 163, 74, 0.1); color: #16a34a; }
.growth.down { background: rgba(220, 38, 38, 0.1); color: #dc2626; }

/* Fleet Health */
.health-item { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border-light); }
.health-item:last-child { border-bottom: none; }
.health-label { font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 8px; }
.health-val { font-size: 14px; font-weight: 700; color: var(--text); }
.dot { width: 8px; height: 8px; border-radius: 50%; }

/* Alerts Feed */
.alert-box { display: flex; gap: 12px; padding: 12px; border-radius: var(--radius-sm); margin-bottom: 10px; border: 1px solid transparent; }
.alert-info { background: rgba(59, 130, 246, 0.05); border-color: rgba(59, 130, 246, 0.1); color: #1d4ed8; }
.alert-warning { background: rgba(245, 158, 11, 0.05); border-color: rgba(245, 158, 11, 0.1); color: #b45309; }
.alert-success { background: rgba(16, 185, 129, 0.05); border-color: rgba(16, 185, 129, 0.1); color: #059669; }
.alert-content { flex: 1; }
.alert-title { font-size: 13px; font-weight: 700; margin-bottom: 2px; }
.alert-desc { font-size: 12px; opacity: 0.8; }

/* Hubs List */
.hub-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; }
.hub-name { font-size: 13px; color: var(--text); }
.hub-count { font-size: 11px; font-weight: 600; background: var(--border-light); padding: 2px 8px; border-radius: 10px; color: var(--text-muted); }
</style>

<!-- Stats Grid with Growth Arrows -->
<div class="db-stats">
  <div class="db-stat">
    <p class="db-stat-label">Total Users</p>
    <div style="display:flex; align-items:baseline;">
      <p class="db-stat-value"><%= stats.usersCount %></p>
      <span class="growth <%= stats.userGrowth >= 0 ? 'up' : 'down' %>">
        <%= stats.userGrowth >= 0 ? '↑' : '↓' %> <%= Math.abs(stats.userGrowth) %>%
      </span>
    </div>
    <p class="db-stat-sub">Registered accounts</p>
  </div>
  
  <div class="db-stat">
    <p class="db-stat-label">Total Earnings</p>
    <div style="display:flex; align-items:baseline;">
      <p class="db-stat-value" style="font-size:22px;">₹<%= Number(stats.totalEarnings).toLocaleString('en-IN') %></p>
      <span class="growth <%= stats.earningsGrowth >= 0 ? 'up' : 'down' %>">
        <%= stats.earningsGrowth >= 0 ? '↑' : '↓' %> <%= Math.abs(stats.earningsGrowth) %>%
      </span>
    </div>
    <p class="db-stat-sub">Lifetime revenue</p>
  </div>

  <div class="db-stat">
    <p class="db-stat-label">KYC Queue</p>
    <p class="db-stat-value"><%= stats.kycPendingCount %></p>
    <p class="db-stat-sub">Pending verification</p>
  </div>

  <div class="db-stat db-stat-accent">
    <p class="db-stat-label">Active Rentals</p>
    <p class="db-stat-value"><%= stats.activeRentalsCount %></p>
    <p class="db-stat-sub">Currently on road</p>
  </div>
</div>

<!-- Middle Section: Fleet & Alerts -->
<div class="db-grid">
  <!-- Fleet Health Breakdown -->
  <div class="db-card">
    <p class="db-card-title">Fleet Status <span><%= stats.bikesCount %> Bikes</span></p>
    <div class="health-item">
      <span class="health-label"><span class="dot" style="background:#16a34a;"></span> Available</span>
      <span class="health-val"><%= fleetStatus.available %></span>
    </div>
    <div class="health-item">
      <span class="health-label"><span class="dot" style="background:#3b82f6;"></span> Rented / Active</span>
      <span class="health-val"><%= fleetStatus.rented %></span>
    </div>
    <div class="health-item">
      <span class="health-label"><span class="dot" style="background:#f59e0b;"></span> Low Battery</span>
      <span class="health-val"><%= fleetStatus.lowBattery %></span>
    </div>
    <div class="health-item">
      <span class="health-label"><span class="dot" style="background:#dc2626;"></span> Maintenance</span>
      <span class="health-val"><%= fleetStatus.maintenance %></span>
    </div>
  </div>

  <!-- Operational Alerts -->
  <div class="db-card">
    <p class="db-card-title">Operational Alerts</p>
    <% alerts.forEach(alert => { %>
      <div class="alert-box alert-<%= alert.level %>">
        <div class="alert-content">
          <p class="alert-title"><%= alert.title %></p>
          <p class="alert-desc"><%= alert.detail %></p>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Top Hubs -->
  <div class="db-card">
    <p class="db-card-title">Top Hubs</p>
    <% topHubs.forEach(hub => { %>
      <div class="hub-row">
        <span class="hub-name"><%= hub.name %></span>
        <span class="hub-count"><%= hub.count %> Bikes</span>
      </div>
    <% }) %>
  </div>
</div>

<!-- Recent Orders Table -->
<div class="db-main">
  <div class="db-main-head">
    <div>
      <p class="db-main-title">Recent Activity</p>
      <p class="db-main-sub">Latest 6 system events</p>
    </div>
    <div class="db-main-metrics">
      <div>
        <p class="db-metric-val"><%= stats.bikesCount %></p>
        <p class="db-metric-label">Bikes</p>
      </div>
      <div>
        <p class="db-metric-val"><%= stats.activeRentalsCount %></p>
        <p class="db-metric-label">Active</p>
      </div>
    </div>
  </div>

  <table class="db-table">
    <thead>
      <tr>
        <th>Activity</th>
        <th>Details</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% if (!recentActivity.length) { %>
        <tr><td colspan="3" style="text-align:center; padding:32px; color:var(--text-muted);">No recent activity</td></tr>
      <% } %>
      <% recentActivity.forEach(item => { %>
      <tr>
        <td style="font-weight:600; color:var(--text);"><%= item.title %></td>
        <td style="color:var(--text-muted); font-size:12px;"><%= item.subtitle %></td>
        <td>
          <span class="status-dot <%= item.title.includes('COMPLETED') ? 'status-completed' : 'status-active' %>">
            <%= item.title.split(' ').pop() %>
          </span>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Bottom: Charts -->
<div class="db-bottom">
  <div class="db-chart-card">
    <div class="db-chart-head">
      <p class="db-chart-title">Revenue Trend (7 Days)</p>
    </div>
    <div style="height: 220px; position:relative;">
      <canvas id="revenueChart"></canvas>
    </div>
  </div>

  <div class="db-chart-card">
    <div class="db-chart-head">
      <p class="db-chart-title">Orders by Status</p>
    </div>
    <div style="height: 220px; position:relative;">
      <canvas id="ordersChart"></canvas>
    </div>
  </div>
</div>

<script>
(() => {
  const isDark = document.body.classList.contains("dark-mode");
  const gridColor = isDark ? "rgba(255,255,255,0.05)" : "#f3f4f6";
  const tickColor = isDark ? "#525252" : "#9ca3af";

  // Revenue Chart
  const revCtx = document.getElementById("revenueChart");
  if (revCtx) {
    new Chart(revCtx, {
      type: "line",
      data: {
        labels: <%- JSON.stringify(revenueChart.labels) %>,
        datasets: [{
          label: "Revenue",
          data: <%- JSON.stringify(revenueChart.data) %>,
          borderColor: "#f26d21",
          backgroundColor: "rgba(242,109,33,0.08)",
          fill: true,
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false }, ticks: { color: tickColor, font: { size: 10 } } },
          y: { grid: { color: gridColor }, ticks: { color: tickColor, font: { size: 10 } } }
        }
      }
    });
  }

  // Orders Chart
  const ordCtx = document.getElementById("ordersChart");
  if (ordCtx) {
    new Chart(ordCtx, {
      type: "bar",
      data: {
        labels: <%- JSON.stringify(ordersChart.labels) %>,
        datasets: [{
          data: <%- JSON.stringify(ordersChart.data) %>,
          backgroundColor: ["#f26d21", "#3b82f6", "#10b981", "#6b7280", "#ef4444"],
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false }, ticks: { color: tickColor, font: { size: 10 } } },
          y: { grid: { color: gridColor }, ticks: { color: tickColor, font: { size: 10 } } }
        }
      }
    });
  }
})();
</script>
