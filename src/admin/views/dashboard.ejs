<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
  .dashboard-grid {
    display: grid;
    gap: 1rem;
  }
  .dashboard-row {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .dash-card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1rem;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.08), 0 2px 4px -2px rgb(0 0 0 / 0.06);
  }
  .dash-title {
    margin: 0 0 0.75rem;
    font-size: 0.95rem;
    letter-spacing: 0.3px;
    color: #1f2937;
  }
  .quick-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .quick-btn {
    padding: 0.6rem 0.9rem;
    border-radius: 10px;
    color: #ffffff;
    text-decoration: none;
    background: #eab308;
    font-weight: 600;
  }
  .quick-btn:hover {
    background: #ca8a04;
  }
  .quick-btn.secondary {
    background: #0d9488;
    color: #ffffff;
  }
  .quick-btn.secondary:hover {
    background: #0f766e;
  }
  .activity-list,
  .alerts-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }
  .activity-item,
  .alert-item {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 0.7rem;
  }
  .item-title {
    margin: 0;
    font-weight: 600;
    font-size: 0.92rem;
    color: #1f2937;
  }
  .item-subtitle,
  .item-time {
    margin: 0.2rem 0 0;
    font-size: 0.82rem;
    color: #4b5563;
  }
  .alert-badge {
    display: inline-block;
    margin-bottom: 0.35rem;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
  }
  .alert-warning {
    background: #fffbeb;
    color: #a16207;
    border: 1px solid #fde68a;
  }
  .alert-info {
    background: #eff6ff;
    color: #1d4ed8;
    border: 1px solid #bfdbfe;
  }
  .alert-success {
    background: #f0fdf4;
    color: #15803d;
    border: 1px solid #bbf7d0;
  }
  .breakdown-value {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: #1f2937;
  }
</style>

<div class="dashboard-grid">
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-head"><span class="stat-icon">👥</span><span class="stat-label">Total Users</span></div>
      <strong class="stat-value"><%= stats.usersCount %></strong>
    </div>
    <div class="stat-card">
      <div class="stat-head"><span class="stat-icon">🚲</span><span class="stat-label">Total Bikes</span></div>
      <strong class="stat-value"><%= stats.bikesCount %></strong>
    </div>
    <div class="stat-card">
      <div class="stat-head"><span class="stat-icon">⏱️</span><span class="stat-label">Active Rentals</span></div>
      <strong class="stat-value"><%= stats.activeRentalsCount %></strong>
    </div>
    <div class="stat-card">
      <div class="stat-head"><span class="stat-icon">💰</span><span class="stat-label">Total Earnings</span></div>
      <strong class="stat-value">₹<%= Number(stats.totalEarnings || 0).toFixed(2) %></strong>
    </div>
  </div>

  <div class="dashboard-row">
    <div class="dash-card">
      <h3 class="dash-title">Quick Actions</h3>
      <div class="quick-actions">
        <a class="quick-btn" href="/admin/bikes">Add Bike</a>
        <a class="quick-btn secondary" href="/admin/users">Add User</a>
      </div>
    </div>

    <div class="dash-card">
      <h3 class="dash-title">Earnings Breakdown</h3>
      <p class="breakdown-value">Today: ₹<%= Number(earningsBreakdown?.today || 0).toFixed(2) %></p>
      <p class="breakdown-value">Weekly: ₹<%= Number(earningsBreakdown?.weekly || 0).toFixed(2) %></p>
      <p class="breakdown-value">Monthly: ₹<%= Number(earningsBreakdown?.monthly || 0).toFixed(2) %></p>
    </div>
  </div>

  <div class="dashboard-row">
    <div class="dash-card">
      <h3 class="dash-title">Revenue Trend (7 Days)</h3>
      <div class="chart-box">
        <canvas id="revenueChart"></canvas>
      </div>
    </div>
    <div class="dash-card">
      <h3 class="dash-title">Orders by Status</h3>
      <div class="chart-box">
        <canvas id="ordersChart"></canvas>
      </div>
    </div>
  </div>

  <div class="dashboard-row">
    <div class="dash-card">
      <h3 class="dash-title">Recent Activity</h3>
      <ul class="activity-list">
        <% if ((recentActivity || []).length === 0) { %>
          <li class="activity-item">
            <p class="item-title">No recent activity</p>
          </li>
        <% } %>
        <% (recentActivity || []).forEach((activity) => { %>
          <li class="activity-item">
            <p class="item-title"><%= activity.title %></p>
            <p class="item-subtitle"><%= activity.subtitle %></p>
            <p class="item-time"><%= activity.time %></p>
          </li>
        <% }) %>
      </ul>
    </div>

    <div class="dash-card">
      <h3 class="dash-title">Alerts</h3>
      <ul class="alerts-list">
        <% (alerts || []).forEach((alert) => { %>
          <li class="alert-item">
            <span class="alert-badge alert-<%= alert.level %>"><%= String(alert.level || "info").toUpperCase() %></span>
            <p class="item-title"><%= alert.title %></p>
            <p class="item-subtitle"><%= alert.detail %></p>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>
</div>

<script>
  (() => {
    const revenueCtx = document.getElementById("revenueChart");
    const ordersCtx = document.getElementById("ordersChart");
    if (!window.Chart || !revenueCtx || !ordersCtx) return;

    new Chart(revenueCtx, {
      type: "line",
      data: {
        labels: <%- JSON.stringify(revenueChart?.labels || []) %>,
        datasets: [{
          label: "Revenue",
          data: <%- JSON.stringify(revenueChart?.data || []) %>,
          borderColor: "#22c55e",
          backgroundColor: "rgba(34, 197, 94, 0.2)",
          fill: true,
          tension: 0.35
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: "#374151" } },
        },
        scales: {
          x: {
            ticks: { color: "#6b7280" },
            grid: { color: "#e5e7eb" },
          },
          y: {
            beginAtZero: true,
            ticks: { color: "#6b7280" },
            grid: { color: "#e5e7eb" },
          },
        },
      },
    });

    new Chart(ordersCtx, {
      type: "bar",
      data: {
        labels: <%- JSON.stringify(ordersChart?.labels || []) %>,
        datasets: [{
          label: "Orders",
          data: <%- JSON.stringify(ordersChart?.data || []) %>,
          backgroundColor: ["#f59e0b", "#3b82f6", "#8b5cf6", "#10b981", "#ef4444"]
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: "#374151" } },
        },
        scales: {
          x: {
            ticks: { color: "#6b7280" },
            grid: { color: "#e5e7eb" },
          },
          y: {
            beginAtZero: true,
            ticks: { precision: 0, color: "#6b7280" },
            grid: { color: "#e5e7eb" },
          },
        },
      },
    });
  })();
</script>
