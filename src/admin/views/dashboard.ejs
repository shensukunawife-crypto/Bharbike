<%
  const today = new Date();
  const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const todayStr = `${dayNames[today.getDay()]}, ${today.getDate()} ${monthNames[today.getMonth()]}`;
%>

<style>
/* Dashboard Specific */
.db-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  gap: 16px;
}

.db-search {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 9px 16px;
  flex: 1;
  max-width: 360px;
}

.db-search input {
  border: none;
  background: none;
  outline: none;
  font-size: 13.5px;
  color: var(--text);
  width: 100%;
  font-family: inherit;
}

.db-search svg { color: var(--text-light); flex-shrink: 0; }

.db-header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.db-date {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 8px 16px;
}

/* Stats row */
.db-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 20px;
}

.db-stat {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 22px;
  box-shadow: var(--shadow-sm);
}

.db-stat-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.db-stat-value {
  font-size: 32px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -1px;
  line-height: 1;
}

.db-stat-sub {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 5px;
}

.db-stat-accent .db-stat-value { color: var(--accent); }

/* Main content area */
.db-main {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  margin-bottom: 20px;
  overflow: hidden;
}

.db-main-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24px 24px 16px;
  border-bottom: 1px solid var(--border);
}

.db-main-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -0.4px;
}

.db-main-sub {
  font-size: 13px;
  color: var(--text-muted);
  margin-top: 4px;
}

.db-main-sub span {
  font-weight: 600;
  color: var(--text);
}

.db-main-metrics {
  display: flex;
  gap: 32px;
  text-align: right;
}

.db-metric-val {
  font-size: 26px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -0.5px;
  line-height: 1;
}

.db-metric-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 3px;
}

/* Recent orders table */
.db-table { width: 100%; border-collapse: collapse; }

.db-table th {
  text-align: left;
  padding: 10px 24px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-light);
  background: var(--border-light);
  border-bottom: 1px solid var(--border);
}

.db-table td {
  padding: 14px 24px;
  font-size: 13.5px;
  border-bottom: 1px solid var(--border-light);
  color: var(--text);
}

.db-table tr:last-child td { border-bottom: none; }
.db-table tbody tr:hover { background: var(--border-light); }

.status-dot {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 500;
}

.status-dot::before {
  content: '';
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

.status-active { color: #16a34a; }
.status-pending { color: #d97706; }
.status-completed { color: #6b7280; }
.status-cancelled { color: #dc2626; }

/* Bottom Grid */
.db-bottom {
  display: grid;
  grid-template-columns: 1fr 1fr 340px;
  gap: 20px;
}

.db-chart-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 22px 24px;
  box-shadow: var(--shadow-sm);
}

.db-chart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
}

.db-chart-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
}

.db-chart-legend {
  display: flex;
  align-items: center;
  gap: 16px;
  font-size: 12px;
  color: var(--text-muted);
}

.db-chart-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  margin-right: 4px;
}

/* Dark info card */
.db-dark-card {
  background: #111827;
  border-radius: var(--radius);
  padding: 24px;
  color: #f9fafb;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

body.dark-mode .db-dark-card { background: #000000; border: 1px solid #1f1f1f; }

.db-dark-title {
  font-size: 15px;
  font-weight: 700;
  color: #f9fafb;
}

.db-quick-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.db-quick-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px;
  color: #f9fafb;
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  transition: background 0.15s;
  cursor: pointer;
}

.db-quick-btn:hover { background: rgba(255,255,255,0.1); }

.db-quick-btn svg { opacity: 0.5; }

.db-earnings-bar {
  margin-top: 8px;
}

.db-earnings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.db-earnings-period {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.db-earnings-amount {
  font-size: 14px;
  font-weight: 700;
  color: #f9fafb;
}

.db-earnings-track {
  height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 4px;
}

.db-earnings-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 4px;
}

@media (max-width: 1100px) {
  .db-stats { grid-template-columns: repeat(2, 1fr); }
  .db-bottom { grid-template-columns: 1fr 1fr; }
  .db-dark-card { grid-column: 1 / -1; }
}

@media (max-width: 640px) {
  .db-stats { grid-template-columns: 1fr 1fr; }
  .db-header { flex-wrap: wrap; }
  .db-search { max-width: 100%; }
}
</style>

<!-- Header -->
<div class="db-header">
  <div class="db-search">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" placeholder="Search orders, users, bikes..." id="dash-search" />
  </div>
  <div class="db-header-right">
    <div class="db-date"><%= todayStr %></div>
    <a href="/admin/orders" class="btn btn-primary" style="gap:6px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Order
    </a>
  </div>
</div>

<!-- Stats -->
<div class="db-stats">
  <div class="db-stat">
    <p class="db-stat-label">Total Users</p>
    <p class="db-stat-value"><%= stats.usersCount || 0 %></p>
    <p class="db-stat-sub">Registered accounts</p>
  </div>
  <div class="db-stat">
    <p class="db-stat-label">Fleet Size</p>
    <p class="db-stat-value"><%= stats.bikesCount || 0 %></p>
    <p class="db-stat-sub">Bikes available</p>
  </div>
  <div class="db-stat db-stat-accent">
    <p class="db-stat-label">Active Rentals</p>
    <p class="db-stat-value"><%= stats.activeRentalsCount || 0 %></p>
    <p class="db-stat-sub">Currently ongoing</p>
  </div>
  <div class="db-stat">
    <p class="db-stat-label">Total Earnings</p>
    <p class="db-stat-value" style="font-size:22px;">₹<%= Number(stats.totalEarnings || 0).toLocaleString('en-IN', {maximumFractionDigits:0}) %></p>
    <p class="db-stat-sub">Lifetime revenue</p>
  </div>
</div>


<!-- Recent Orders Table -->
<div class="db-main">
  <div class="db-main-head">
    <div>
      <p class="db-main-title">Recent Orders</p>
      <p class="db-main-sub">
        <span><%= (recentActivity || []).length %> orders</span> — latest activity on the platform
      </p>
    </div>
    <div class="db-main-metrics">
      <div>
        <p class="db-metric-val"><%= stats.bikesCount || 0 %></p>
        <p class="db-metric-label">Bikes</p>
      </div>
      <div>
        <p class="db-metric-val"><%= stats.activeRentalsCount || 0 %></p>
        <p class="db-metric-label">Active</p>
      </div>
    </div>
  </div>

  <table class="db-table">
    <thead>
      <tr>
        <th>Activity</th>
        <th>Details</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% const recentList = (recentActivity || []).slice(0, 8); %>
      <% if (recentList.length === 0) { %>
      <tr>
        <td colspan="3" style="text-align:center; color:var(--text-muted); padding: 32px;">
          No recent activity found
        </td>
      </tr>
      <% } %>
      <% recentList.forEach(item => { %>
      <tr>
        <td style="font-weight:600; color:var(--text);"><%= item.title || '—' %></td>
        <td style="color:var(--text-muted); font-size:12px; max-width:280px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
          <%= item.subtitle || '—' %>
        </td>
        <td>
          <% const stText = (item.title || '').toLowerCase(); %>
          <span class="status-dot <%= stText.includes('completed') ? 'status-completed' : stText.includes('accepted') || stText.includes('active') || stText.includes('ongoing') ? 'status-active' : stText.includes('cancelled') || stText.includes('rejected') ? 'status-cancelled' : 'status-pending' %>">
            <%= stText.includes('completed') ? 'Completed' : stText.includes('accepted') || stText.includes('ongoing') ? 'Active' : stText.includes('cancelled') || stText.includes('rejected') ? 'Cancelled' : 'Pending' %>
          </span>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Bottom: Two Charts + Dark Card -->
<div class="db-bottom">

  <!-- Revenue Line Chart -->
  <div class="db-chart-card">
    <div class="db-chart-head">
      <p class="db-chart-title">Revenue Trend (7 Days)</p>
      <div class="db-chart-legend">
        <span><span class="db-chart-dot" style="background:#f26d21;"></span>Revenue (₹)</span>
      </div>
    </div>
    <div style="height: 220px; position:relative;">
      <canvas id="revenueChart"></canvas>
    </div>
  </div>

  <!-- Orders Bar Chart -->
  <div class="db-chart-card">
    <div class="db-chart-head">
      <p class="db-chart-title">Orders by Status</p>
    </div>
    <div style="height: 220px; position:relative;">
      <canvas id="ordersChart"></canvas>
    </div>
  </div>

  <!-- Dark earnings + quick actions card -->
  <div class="db-dark-card">
    <p class="db-dark-title">Earnings Breakdown</p>

    <div class="db-earnings-bar">
      <div class="db-earnings-row">
        <span class="db-earnings-period">Today</span>
        <span class="db-earnings-amount">₹<%= Number(earningsBreakdown?.today || 0).toLocaleString('en-IN', {maximumFractionDigits:0}) %></span>
      </div>
      <div class="db-earnings-track">
        <div class="db-earnings-fill" style="width:<%= Math.min(100, ((earningsBreakdown?.today || 0) / Math.max(earningsBreakdown?.monthly || 1, 1)) * 100).toFixed(0) %>%"></div>
      </div>

      <div class="db-earnings-row" style="margin-top:12px;">
        <span class="db-earnings-period">This Week</span>
        <span class="db-earnings-amount">₹<%= Number(earningsBreakdown?.weekly || 0).toLocaleString('en-IN', {maximumFractionDigits:0}) %></span>
      </div>
      <div class="db-earnings-track">
        <div class="db-earnings-fill" style="width:<%= Math.min(100, ((earningsBreakdown?.weekly || 0) / Math.max(earningsBreakdown?.monthly || 1, 1)) * 100).toFixed(0) %>%"></div>
      </div>

      <div class="db-earnings-row" style="margin-top:12px;">
        <span class="db-earnings-period">This Month</span>
        <span class="db-earnings-amount">₹<%= Number(earningsBreakdown?.monthly || 0).toLocaleString('en-IN', {maximumFractionDigits:0}) %></span>
      </div>
      <div class="db-earnings-track">
        <div class="db-earnings-fill" style="width:100%"></div>
      </div>
    </div>

    <div>
      <p class="db-dark-title" style="margin-bottom:12px;">Quick Actions</p>
      <div class="db-quick-actions">
        <a href="/admin/bikes" class="db-quick-btn">
          <span>Add New Bike</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/admin/users" class="db-quick-btn">
          <span>Manage Users</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/admin/kyc-documents" class="db-quick-btn">
          <span>Review KYC</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>

</div>

<script>
(() => {
  const ctx = document.getElementById("revenueChart");
  if (!window.Chart || !ctx) return;

  const labels = <%- JSON.stringify(revenueChart?.labels || ['Mon','Tue','Wed','Thu','Fri','Sat','Sun']) %>;
  const data   = <%- JSON.stringify(revenueChart?.data   || [0,0,0,0,0,0,0]) %>;

  const isDark = document.body.classList.contains("dark-mode");
  const gridColor = isDark ? "rgba(255,255,255,0.05)" : "#f3f4f6";
  const tickColor = isDark ? "#525252" : "#9ca3af";

  new Chart(ctx, {
    type: "line",
    data: {
      labels,
      datasets: [{
        label: "Revenue (₹)",
        data,
        borderColor: "#f26d21",
        backgroundColor: "rgba(242,109,33,0.08)",
        borderWidth: 2,
        fill: true,
        tension: 0.4,
        pointRadius: 3,
        pointBackgroundColor: "#f26d21",
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: isDark ? "#1a1a1a" : "#fff",
          titleColor: isDark ? "#f5f5f5" : "#111827",
          bodyColor: isDark ? "#a3a3a3" : "#6b7280",
          borderColor: isDark ? "#262626" : "#e5e7eb",
          borderWidth: 1,
          padding: 10,
          callbacks: {
            label: ctx => `₹${Number(ctx.raw).toLocaleString('en-IN')}`
          }
        }
      },
      scales: {
        x: {
          ticks: { color: tickColor, font: { size: 11 } },
          grid: { color: gridColor }
        },
        y: {
          beginAtZero: true,
          ticks: { color: tickColor, font: { size: 11 }, callback: v => `₹${v}` },
          grid: { color: gridColor }
        }
      }
    }
  });
  // Orders Bar Chart
  const ordersCtx = document.getElementById("ordersChart");
  if (window.Chart && ordersCtx) {
    new Chart(ordersCtx, {
      type: "bar",
      data: {
        labels: <%- JSON.stringify(ordersChart?.labels || ['Pending','Accepted','Ongoing','Completed','Cancelled']) %>,
        datasets: [{
          label: "Orders",
          data: <%- JSON.stringify(ordersChart?.data || [0,0,0,0,0]) %>,
          backgroundColor: ["#fbbf24","#34d399","#60a5fa","#a78bfa","#f87171"],
          borderRadius: 6,
          borderSkipped: false,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: isDark ? "#1a1a1a" : "#fff",
            titleColor: isDark ? "#f5f5f5" : "#111827",
            bodyColor: isDark ? "#a3a3a3" : "#6b7280",
            borderColor: isDark ? "#262626" : "#e5e7eb",
            borderWidth: 1,
            padding: 10,
          }
        },
        scales: {
          x: { ticks: { color: tickColor, font: { size: 11 } }, grid: { display: false } },
          y: { beginAtZero: true, ticks: { precision: 0, color: tickColor, font: { size: 11 } }, grid: { color: gridColor } }
        }
      }
    });
  }
})();
</script>
