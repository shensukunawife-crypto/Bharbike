<%
  const today = new Date();
  const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const todayStr = `${dayNames[today.getDay()]}, ${today.getDate()} ${monthNames[today.getMonth()]}`;
%>

<style>
/* Dashboard Specific */
.db-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  gap: 16px;
}

.db-search {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 9px 16px;
  flex: 1;
  max-width: 360px;
}

.db-search input {
  border: none;
  background: none;
  outline: none;
  font-size: 13.5px;
  color: var(--text);
  width: 100%;
  font-family: inherit;
}

.db-search svg { color: var(--text-light); flex-shrink: 0; }

.db-header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.db-date {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 8px 16px;
}

/* Stats row */
.db-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 20px;
}

.db-stat {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 22px;
  box-shadow: var(--shadow-sm);
}

.db-stat-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.db-stat-value {
  font-size: 32px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -1px;
  line-height: 1;
}

.db-stat-sub {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 5px;
}

.db-stat-accent .db-stat-value { color: var(--accent); }

/* Main content area */
.db-main {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  margin-bottom: 20px;
  overflow: hidden;
}

.db-main-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24px 24px 16px;
  border-bottom: 1px solid var(--border);
}

.db-main-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -0.4px;
}

.db-main-sub {
  font-size: 13px;
  color: var(--text-muted);
  margin-top: 4px;
}

.db-main-sub span {
  font-weight: 600;
  color: var(--text);
}

.db-main-metrics {
  display: flex;
  gap: 32px;
  text-align: right;
}

.db-metric-val {
  font-size: 26px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -0.5px;
  line-height: 1;
}

.db-metric-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 3px;
}

/* Recent orders table */
.db-table { width: 100%; border-collapse: collapse; }

.db-table th {
  text-align: left;
  padding: 10px 24px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-light);
  background: var(--border-light);
  border-bottom: 1px solid var(--border);
}

.db-table td {
  padding: 14px 24px;
  font-size: 13.5px;
  border-bottom: 1px solid var(--border-light);
  color: var(--text);
}

.db-table tr:last-child td { border-bottom: none; }
.db-table tbody tr:hover { background: var(--border-light); }

.status-dot {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 500;
}

.status-dot::before {
  content: '';
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

.status-active { color: #16a34a; }
.status-pending { color: #d97706; }
.status-completed { color: #6b7280; }
.status-cancelled { color: #dc2626; }

/* Bottom Grid */
.db-bottom {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.db-chart-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 22px 24px;
  box-shadow: var(--shadow-sm);
}

.db-chart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
}

.db-chart-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
}

.db-chart-legend {
  display: flex;
  align-items: center;
  gap: 16px;
  font-size: 12px;
  color: var(--text-muted);
}

.db-chart-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  margin-right: 4px;
}

/* Dark info card */
.db-dark-card {
  background: #111827;
  border-radius: var(--radius);
  padding: 24px;
  color: #f9fafb;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

body.dark-mode .db-dark-card { background: #000000; border: 1px solid #1f1f1f; }

.db-dark-title {
  font-size: 15px;
  font-weight: 700;
  color: #f9fafb;
}

.db-quick-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.db-quick-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px;
  color: #f9fafb;
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  transition: background 0.15s;
  cursor: pointer;
}

.db-quick-btn:hover { background: rgba(255,255,255,0.1); }

.db-quick-btn svg { opacity: 0.5; }

.db-earnings-bar {
  margin-top: 8px;
}

.db-earnings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.db-earnings-period {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.db-earnings-amount {
  font-size: 14px;
  font-weight: 700;
  color: #f9fafb;
}

.db-earnings-track {
  height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 4px;
}

.db-earnings-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 4px;
}

@media (max-width: 1100px) {
  .db-stats { grid-template-columns: repeat(2, 1fr); }
  .db-bottom { grid-template-columns: 1fr 1fr; }
  .db-dark-card { grid-column: 1 / -1; }
}

@media (max-width: 640px) {
  .db-stats { grid-template-columns: 1fr 1fr; }
  .db-header { flex-wrap: wrap; }
  .db-search { max-width: 100%; }
}
</style>

<!-- Header -->
<div class="db-header">
  <div class="db-search">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" placeholder="Search orders, users, bikes..." id="dash-search" />
  </div>
  <div class="db-header-right">
    <div class="db-date"><%= todayStr %></div>
    <a href="/admin/orders" class="btn btn-primary" style="gap:6px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Order
    </a>
  </div>
</div>

<!-- Stats -->
<div class="db-stats">
  <div class="db-stat">
    <p class="db-stat-label">Total Users</p>
    <p class="db-stat-value"><%= stats.usersCount || 0 %></p>
    <p class="db-stat-sub">Registered accounts</p>
  </div>
  <div class="db-stat">
    <p class="db-stat-label">Fleet Size</p>
    <p class="db-stat-value"><%= stats.bikesCount || 0 %></p>
    <p class="db-stat-sub">Bikes available</p>
  </div>
  <div class="db-stat db-stat-accent">
    <p class="db-stat-label">Active Rentals</p>
    <p class="db-stat-value"><%= stats.activeRentalsCount || 0 %></p>
    <p class="db-stat-sub">Currently ongoing</p>
  </div>
  <% if (locals.admin && locals.admin.role === 'sub_admin') { %>
  <div class="db-stat db-stat-accent">
    <p class="db-stat-label">Pending KYC Docs</p>
    <p class="db-stat-value" style="font-size:22px;"><%= stats.pendingKycCount || 0 %></p>
    <p class="db-stat-sub">Awaiting verification</p>
  </div>
  <% } else { %>
  <div class="db-stat">
    <p class="db-stat-label">Total Earnings</p>
    <p class="db-stat-value" style="font-size:22px;">₹<%= Number(stats.totalEarnings || 0).toLocaleString('en-IN', {maximumFractionDigits:0}) %></p>
    <p class="db-stat-sub">Lifetime revenue</p>
  </div>
  <% } %>
</div>


<% if (locals.admin && locals.admin.role === 'sub_admin') { %>
  <!-- Sub-Admin Operations Control Center Dashboard -->
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; align-items: start;">
    
    <!-- Left Column: KYC Approvals, Expiring Subscriptions & Maintenance Bikes -->
    <div style="display: flex; flex-direction: column; gap: 20px;">
      
      <!-- KYC Document Approvals -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">📋 KYC Document Approvals</p>
            <p class="db-main-sub">Review uploaded rider documents</p>
          </div>
          <span class="pay-badge pay-badge-pending" style="font-size: 12px; font-weight: bold; background: #e0f2fe; color: #0284c7; padding: 4px 10px; border-radius: 9999px;"><%= (pendingKycList || []).length %> Pending</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Rider</th>
              <th>Document</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!pendingKycList || !pendingKycList.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No pending KYC approvals</td></tr>
            <% } else { %>
              <% pendingKycList.forEach(function(doc) { %>
              <tr>
                <td><strong><%= doc.userName %></strong><br/><span style="font-size:11px; color:var(--text-muted);"><%= doc.userPhone %></span></td>
                <td>
                  <span class="code-badge" style="background:#e0f2fe; color:#0369a1; font-weight:bold; font-size:11px;"><%= doc.type.toUpperCase().replace('_', ' ') %></span>
                  <a href="<%= doc.fileUrl %>" target="_blank" style="margin-left:6px; font-size:12px; text-decoration:underline; color:var(--accent); font-weight:600;">View</a>
                </td>
                <td style="display:flex; gap:6px;">
                  <button class="btn btn-sm btn-primary kyc-approve-btn" data-id="<%= doc.id %>" style="padding:2px 8px; font-size:11px; background:#10b981; border:none; color:white; border-radius:6px; font-weight:bold;">Approve</button>
                  <button class="btn btn-sm btn-danger kyc-reject-btn" data-id="<%= doc.id %>" style="padding:2px 8px; font-size:11px; background:#ef4444; border:none; color:white; border-radius:6px; font-weight:bold;">Reject</button>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Expiring Subscriptions (<= 2 Days Left) -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">⏳ Expiring Subscriptions (Next 48h)</p>
            <p class="db-main-sub">Whose 2 days are left</p>
          </div>
          <span class="pay-badge pay-badge-pending" style="font-size: 12px; font-weight: bold; background: #fef3c7; color: #d97706; padding: 4px 10px; border-radius: 9999px;"><%= (expiringSubs || []).length %> Expiring</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Rider</th>
              <th>Plan</th>
              <th>Time Left</th>
            </tr>
          </thead>
          <tbody>
            <% if (!expiringSubs || !expiringSubs.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No subscriptions expiring in next 48h</td></tr>
            <% } else { %>
              <% expiringSubs.forEach(function(sub) { %>
              <tr>
                <td><strong><%= sub.userName %></strong><br/><span style="font-size:11px; color:var(--text-muted);"><%= sub.userPhone %></span></td>
                <td><span class="code-badge" style="background:#f1f5f9; color:#475569; font-weight:bold; font-size:11px;"><%= sub.planName %></span></td>
                <td><span class="status-dot status-pending" style="font-weight: 700; font-size:12.5px;"><%= sub.timeLeftStr %></span></td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Bikes Under Maintenance -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">🔧 Bikes Under Maintenance</p>
            <p class="db-main-sub">Bikes currently in repair/maintenance state</p>
          </div>
          <span class="pay-badge pay-badge-failed" style="font-size: 12px; font-weight: bold; background: #fee2e2; color: #ef4444; padding: 4px 10px; border-radius: 9999px;"><%= (activeMaintenance || []).length %> in Repair</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Bike</th>
              <th>Issue / Work Details</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!activeMaintenance || !activeMaintenance.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No bikes in maintenance</td></tr>
            <% } else { %>
              <% activeMaintenance.forEach(function(m) { %>
              <tr>
                <td><span class="code-badge" style="background:#f1f5f9; color:#0f172a; font-weight:bold; font-size:11px;"><%= m.bikeCode %></span></td>
                <td>
                  <strong><%= m.issueType %></strong><br/>
                  <span style="font-size:11px; color:var(--text-muted); display:inline-block; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= m.workDetails %>"><%= m.workDetails %></span>
                </td>
                <td>
                  <button class="btn btn-sm btn-primary bike-fixed-btn" data-bike-id="<%= m.bikeId %>" style="padding:4px 8px; font-size:11px; background:#10b981; border:none; color:white; border-radius:6px; font-weight:bold;">✅ Fixed</button>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>

    <!-- Right Column: Assigned Bikes (Rider-Bike Mappings) & Low Battery Warnings -->
    <div style="display: flex; flex-direction: column; gap: 20px;">
      
      <!-- Assigned Bikes (Active Rentals) -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">🚲 Assigned Bikes (Active Rentals)</p>
            <p class="db-main-sub">Current active riders and assignments</p>
          </div>
          <span class="pay-badge pay-badge-success" style="font-size: 12px; font-weight: bold; background: #dcfce7; color: #15803d; padding: 4px 10px; border-radius: 9999px;"><%= (assignedBikes || []).length %> Active</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Rider Details</th>
              <th>Assigned Bike</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!assignedBikes || !assignedBikes.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No active bike assignments</td></tr>
            <% } else { %>
              <% assignedBikes.forEach(function(item) { %>
              <tr>
                <td>
                  <strong><%= item.userName %></strong><br/>
                  <span style="font-size:11px; color:var(--text-muted);"><%= item.userPhone %></span><br/>
                  <span style="font-size:10px; color:var(--text-muted);">Started: <%= item.startTime %></span>
                </td>
                <td><span class="code-badge" style="background:#e8f5e9; color:#2e7d32; font-weight:bold; font-size:11px; border:1px solid #c8e6c9;"><%= item.bikeCode %></span></td>
                <td>
                  <div style="display:flex; flex-direction:column; gap:4px;">
                    <div style="display:flex; gap:4px;">
                      <button class="btn btn-sm btn-outline bike-lock-btn" data-bike-id="<%= item.bikeId %>" style="padding:4px 8px; font-size:10.5px; border-color:#cbd5e1; font-weight:bold; border-radius:6px; cursor:pointer;">⚡ Lock</button>
                      <button class="btn btn-sm btn-outline bike-unlock-btn" data-bike-id="<%= item.bikeId %>" style="padding:4px 8px; font-size:10.5px; border-color:#cbd5e1; font-weight:bold; border-radius:6px; cursor:pointer;">🔓 Unlock</button>
                    </div>
                    <button class="btn btn-sm btn-danger booking-complete-btn" data-booking-id="<%= item.id %>" style="padding:4px 6px; font-size:10.5px; background:#ef4444; color:white; border:none; width:100%; font-weight:bold; border-radius:6px; cursor:pointer;">🛑 End Ride</button>
                  </div>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Low Battery Alerts -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">🔋 Low Battery Warnings (&lt;25%)</p>
            <p class="db-main-sub">Bikes needing battery swapping/recharges</p>
          </div>
          <span class="pay-badge pay-badge-failed" style="font-size: 12px; font-weight: bold; background: #fffbeb; color: #d97706; padding: 4px 10px; border-radius: 9999px;"><%= (lowBatteryBikes || []).length %> Low</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Bike</th>
              <th>Battery %</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!lowBatteryBikes || !lowBatteryBikes.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No low battery alerts</td></tr>
            <% } else { %>
              <% lowBatteryBikes.forEach(function(b) { %>
              <tr id="bike-row-<%= b.id %>">
                <td>
                  <span class="code-badge" style="background:#fffbeb; color:#b45309; font-weight:bold; font-size:11px;"><%= b.bike_code || b.id %></span><br/>
                  <span class="muted-small bike-loc-text" style="font-size:11px; color:var(--text-muted);"><%= b.location || 'Unknown' %></span>
                </td>
                <td>
                  <div style="display:flex; align-items:center; gap:8px;">
                    <div style="flex:1; width:50px; height:6px; background:#e2e8f0; border-radius:3px; overflow:hidden;">
                      <div class="battery-fill-bar" style="width:<%= b.battery || 0 %>%; height:100%; background:#ef4444;"></div>
                    </div>
                    <span class="battery-pct-text" style="font-size:12px; font-weight:bold; color:#ef4444;"><%= b.battery || 0 %>%</span>
                  </div>
                </td>
                <td>
                  <button class="btn btn-sm btn-outline status-check-btn" data-bike-id="<%= b.id %>" style="padding:4px 8px; font-size:11px; border-color:#cbd5e1; border-radius:6px; font-weight:bold; cursor:pointer;">🔍 Status Check</button>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>

  </div>
<% } else { %>
  <!-- Recent Orders Table -->
  <div class="db-main">
    <div class="db-main-head">
      <div>
        <p class="db-main-title">Recent Orders</p>
        <p class="db-main-sub">
          <span><%= (recentActivity || []).length %> orders</span> — latest activity on the platform
        </p>
      </div>
      <div class="db-main-metrics">
        <div>
          <p class="db-metric-val"><%= stats.bikesCount || 0 %></p>
          <p class="db-metric-label">Bikes</p>
        </div>
        <div>
          <p class="db-metric-val"><%= stats.activeRentalsCount || 0 %></p>
          <p class="db-metric-label">Active</p>
        </div>
      </div>
    </div>

    <table class="db-table">
      <thead>
        <tr>
          <th>Activity</th>
          <th>Details</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% const recentList = (recentActivity || []).slice(0, 8); %>
        <% if (recentList.length === 0) { %>
        <tr>
          <td colspan="3" style="text-align:center; color:var(--text-muted); padding: 32px;">
            No recent activity found
          </td>
        </tr>
        <% } %>
        <% recentList.forEach(item => { %>
        <tr>
          <td style="font-weight:600; color:var(--text);"><%= item.title || '—' %></td>
          <td style="color:var(--text-muted); font-size:12px; max-width:280px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            <%= item.subtitle || '—' %>
          </td>
          <td>
            <% const stText = (item.title || '').toLowerCase(); %>
            <span class="status-dot <%= stText.includes('completed') || stText.includes('paid') ? 'status-completed' : stText.includes('accepted') || stText.includes('active') || stText.includes('ongoing') ? 'status-active' : stText.includes('cancelled') || stText.includes('rejected') ? 'status-cancelled' : 'status-pending' %>">
              <%= stText.includes('completed') || stText.includes('paid') ? 'Paid' : stText.includes('accepted') || stText.includes('ongoing') ? 'Active' : stText.includes('cancelled') || stText.includes('rejected') ? 'Cancelled' : 'Pending' %>
            </span>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Bottom: Two Charts -->
  <div class="db-bottom">
    <!-- Revenue Line Chart -->
    <div class="db-chart-card">
      <div class="db-chart-head">
        <p class="db-chart-title">Revenue Trend (7 Days)</p>
        <div class="db-chart-legend">
          <span><span class="db-chart-dot" style="background:#f26d21;"></span>Revenue (₹)</span>
        </div>
      </div>
      <div style="height: 220px; position:relative;">
        <canvas id="revenueChart"></canvas>
      </div>
    </div>

    <!-- Orders Bar Chart -->
    <div class="db-chart-card">
      <div class="db-chart-head">
        <p class="db-chart-title">Orders by Status</p>
      </div>
      <div style="height: 220px; position:relative;">
        <canvas id="ordersChart"></canvas>
      </div>
    </div>
  </div>
<% } %>

<script>
(() => {
  const ctx = document.getElementById("revenueChart");
  if (!window.Chart || !ctx) return;

  const labels = <%- JSON.stringify(revenueChart?.labels || ['Mon','Tue','Wed','Thu','Fri','Sat','Sun']) %>;
  const data   = <%- JSON.stringify(revenueChart?.data   || [0,0,0,0,0,0,0]) %>;

  const isDark = document.body.classList.contains("dark-mode");
  const gridColor = isDark ? "rgba(255,255,255,0.05)" : "#f3f4f6";
  const tickColor = isDark ? "#525252" : "#9ca3af";

  new Chart(ctx, {
    type: "line",
    data: {
      labels,
      datasets: [{
        label: "Revenue (₹)",
        data,
        borderColor: "#f26d21",
        backgroundColor: "rgba(242,109,33,0.08)",
        borderWidth: 2,
        fill: true,
        tension: 0.4,
        pointRadius: 3,
        pointBackgroundColor: "#f26d21",
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: isDark ? "#1a1a1a" : "#fff",
          titleColor: isDark ? "#f5f5f5" : "#111827",
          bodyColor: isDark ? "#a3a3a3" : "#6b7280",
          borderColor: isDark ? "#262626" : "#e5e7eb",
          borderWidth: 1,
          padding: 10,
          callbacks: {
            label: ctx => `₹${Number(ctx.raw).toLocaleString('en-IN')}`
          }
        }
      },
      scales: {
        x: {
          ticks: { color: tickColor, font: { size: 11 } },
          grid: { color: gridColor }
        },
        y: {
          beginAtZero: true,
          ticks: { color: tickColor, font: { size: 11 }, callback: v => `₹${v}` },
          grid: { color: gridColor }
        }
      }
    }
  });
  // Orders Bar Chart
  const ordersCtx = document.getElementById("ordersChart");
  if (window.Chart && ordersCtx) {
    new Chart(ordersCtx, {
      type: "bar",
      data: {
        labels: <%- JSON.stringify(ordersChart?.labels || ['Pending','Accepted','Ongoing','Completed','Cancelled']) %>,
        datasets: [{
          label: "Orders",
          data: <%- JSON.stringify(ordersChart?.data || [0,0,0,0,0]) %>,
          backgroundColor: ["#fbbf24","#34d399","#60a5fa","#a78bfa","#f87171"],
          borderRadius: 6,
          borderSkipped: false,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: isDark ? "#1a1a1a" : "#fff",
            titleColor: isDark ? "#f5f5f5" : "#111827",
            bodyColor: isDark ? "#a3a3a3" : "#6b7280",
            borderColor: isDark ? "#262626" : "#e5e7eb",
            borderWidth: 1,
            padding: 10,
          }
        },
        scales: {
          x: { ticks: { color: tickColor, font: { size: 11 } }, grid: { display: false } },
          y: { beginAtZero: true, ticks: { precision: 0, color: tickColor, font: { size: 11 } }, grid: { color: gridColor } }
        }
      }
    });
  }

  // Dashboard Search Logic
  const searchInput = document.getElementById("dash-search");
  if (searchInput) {
    searchInput.addEventListener("input", (e) => {
      const term = e.target.value.toLowerCase();
      const rows = document.querySelectorAll(".db-table tbody tr");
      rows.forEach((row) => {
        if (row.cells.length === 1) return; // skip "No activity" row
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(term) ? "" : "none";
      });
    });

    searchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && e.target.value.trim().length > 0) {
        window.location.href = "/admin/orders?search=" + encodeURIComponent(e.target.value.trim());
      }
    });
  }

  // Operations Control Center AJAX Event Listeners
  document.querySelectorAll(".kyc-approve-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const docId = btn.getAttribute("data-id");
      handleAction(`/admin/kyc-documents/${docId}/status`, "POST", { status: "verified" });
    });
  });

  document.querySelectorAll(".kyc-reject-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const docId = btn.getAttribute("data-id");
      const reason = prompt("Please enter the reason for rejecting this document:");
      if (reason === null) return; // cancel clicked
      if (!reason.trim()) {
        showToast("Rejection reason cannot be empty", "error");
        return;
      }
      handleAction(`/admin/kyc-documents/${docId}/status`, "POST", { status: "rejected", reason: reason.trim() });
    });
  });

  document.querySelectorAll(".bike-lock-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const bikeId = btn.getAttribute("data-bike-id");
      if (confirm("Are you sure you want to LOCK this bike?")) {
        handleAction(`/admin/bikes/${bikeId}/lock`, "POST");
      }
    });
  });

  document.querySelectorAll(".bike-unlock-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const bikeId = btn.getAttribute("data-bike-id");
      if (confirm("Are you sure you want to UNLOCK this bike?")) {
        handleAction(`/admin/bikes/${bikeId}/unlock`, "POST");
      }
    });
  });

  document.querySelectorAll(".booking-complete-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const bookingId = btn.getAttribute("data-booking-id");
      if (confirm("Are you sure you want to END this ride manually?")) {
        handleAction(`/admin/bookings/${bookingId}/complete`, "POST");
      }
    });
  });

  document.querySelectorAll(".bike-fixed-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const bikeId = btn.getAttribute("data-bike-id");
      if (confirm("Mark this bike as FIXED and return it to service?")) {
        handleAction(`/admin/maintenance/${bikeId}/fixed`, "POST");
      }
    });
  });

  document.querySelectorAll(".status-check-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      const bikeId = btn.getAttribute("data-bike-id");
      const row = document.getElementById(`bike-row-${bikeId}`);
      if (!row) return;

      const locTextEl = row.querySelector(".bike-loc-text");
      const fillBarEl = row.querySelector(".battery-fill-bar");
      const pctTextEl = row.querySelector(".battery-pct-text");
      
      btn.disabled = true;
      btn.innerHTML = "⏳ Checking...";

      try {
        const adminToken = localStorage.getItem("adminToken");
        const res = await fetch(`/admin/bikes/${bikeId}/live-gps`, {
          headers: {
            "Content-Type": "application/json",
            ...(adminToken ? { Authorization: `Bearer ${adminToken}` } : {}),
          }
        });
        if (res.status === 401) {
          localStorage.removeItem("adminToken");
          window.location.href = "/admin/login";
          return;
        }
        const data = await res.json();
        if (data.success) {
          // Update location text
          if (data.isLive && data.lat && data.lng) {
            locTextEl.innerHTML = `📍 Live: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)}`;
            locTextEl.style.color = "#10b981"; // success green
          } else {
            locTextEl.innerHTML = "📍 GPS signal unavailable";
            locTextEl.style.color = "#ef4444"; // error red
          }
          
          // Update battery indicators
          const battery = Number(data.battery || 0);
          pctTextEl.textContent = `${battery}%`;
          fillBarEl.style.width = `${battery}%`;
          if (battery < 25) {
            fillBarEl.style.background = "#ef4444"; // red
            pctTextEl.style.color = "#ef4444";
          } else if (battery < 60) {
            fillBarEl.style.background = "#f59e0b"; // yellow
            pctTextEl.style.color = "#f59e0b";
          } else {
            fillBarEl.style.background = "#10b981"; // green
            pctTextEl.style.color = "#10b981";
          }
          
          showToast(`Status checked for bike ${bikeId}`);
          btn.innerHTML = "✓ Updated";
          setTimeout(() => {
            btn.disabled = false;
            btn.innerHTML = "🔍 Status Check";
          }, 3000);
        } else {
          showToast("Failed to fetch GPS status", "error");
          btn.disabled = false;
          btn.innerHTML = "🔍 Status Check";
        }
      } catch (err) {
        showToast("Error checking status", "error");
        btn.disabled = false;
        btn.innerHTML = "🔍 Status Check";
      }
    });
  });
})();
</script>
