<%
  const today = new Date();
  const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const todayStr = `${dayNames[today.getDay()]}, ${today.getDate()} ${monthNames[today.getMonth()]}`;
%>

<style>
/* Dashboard Specific */
.db-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  gap: 16px;
}

.db-search {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 9px 16px;
  flex: 1;
  max-width: 360px;
}

.db-search input {
  border: none;
  background: none;
  outline: none;
  font-size: 13.5px;
  color: var(--text);
  width: 100%;
  font-family: inherit;
}

.db-search svg { color: var(--text-light); flex-shrink: 0; }

.db-header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.db-date {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 8px 16px;
}

/* Stats row */
.db-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 20px;
}

.db-stat {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 22px;
  box-shadow: var(--shadow-sm);
}

.db-stat-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.db-stat-value {
  font-size: 32px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -1px;
  line-height: 1;
}

.db-stat-sub {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 5px;
}

.db-stat-accent .db-stat-value { color: var(--accent); }

/* Main content area */
.db-main {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  margin-bottom: 20px;
  overflow: hidden;
}

.db-main-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24px 24px 16px;
  border-bottom: 1px solid var(--border);
}

.db-main-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -0.4px;
}

.db-main-sub {
  font-size: 13px;
  color: var(--text-muted);
  margin-top: 4px;
}

.db-main-sub span {
  font-weight: 600;
  color: var(--text);
}

.db-main-metrics {
  display: flex;
  gap: 32px;
  text-align: right;
}

.db-metric-val {
  font-size: 26px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -0.5px;
  line-height: 1;
}

.db-metric-label {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 3px;
}

/* Recent orders table */
.db-table { width: 100%; border-collapse: collapse; }

.db-table th {
  text-align: left;
  padding: 10px 24px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-light);
  background: var(--border-light);
  border-bottom: 1px solid var(--border);
}

.db-table td {
  padding: 14px 24px;
  font-size: 13.5px;
  border-bottom: 1px solid var(--border-light);
  color: var(--text);
}

.db-table tr:last-child td { border-bottom: none; }
.db-table tbody tr:hover { background: var(--border-light); }

.status-dot {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 500;
}

.status-dot::before {
  content: '';
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}

.status-active { color: #16a34a; }
.status-pending { color: #d97706; }
.status-completed { color: #6b7280; }
.status-cancelled { color: #dc2626; }

/* Bottom Grid */
.db-bottom {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.db-chart-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 22px 24px;
  box-shadow: var(--shadow-sm);
}

.db-chart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18px;
}

.db-chart-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
}

.db-chart-legend {
  display: flex;
  align-items: center;
  gap: 16px;
  font-size: 12px;
  color: var(--text-muted);
}

.db-chart-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  margin-right: 4px;
}

/* Dark info card */
.db-dark-card {
  background: #111827;
  border-radius: var(--radius);
  padding: 24px;
  color: #f9fafb;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

body.dark-mode .db-dark-card { background: #000000; border: 1px solid #1f1f1f; }

.db-dark-title {
  font-size: 15px;
  font-weight: 700;
  color: #f9fafb;
}

.db-quick-actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.db-quick-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px;
  color: #f9fafb;
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  transition: background 0.15s;
  cursor: pointer;
}

.db-quick-btn:hover { background: rgba(255,255,255,0.1); }

.db-quick-btn svg { opacity: 0.5; }

.db-earnings-bar {
  margin-top: 8px;
}

.db-earnings-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.db-earnings-period {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.db-earnings-amount {
  font-size: 14px;
  font-weight: 700;
  color: #f9fafb;
}

.db-earnings-track {
  height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 4px;
}

.db-earnings-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 4px;
}

@media (max-width: 1100px) {
  .db-stats { grid-template-columns: repeat(2, 1fr); }
  .db-bottom { grid-template-columns: 1fr 1fr; }
  .db-dark-card { grid-column: 1 / -1; }
}

@media (max-width: 640px) {
  .db-stats { grid-template-columns: 1fr 1fr; }
  .db-header { flex-wrap: wrap; }
  .db-search { max-width: 100%; }
}

/* KYC Pagination & Enhanced UI */
.kyc-row {
  transition: background-color 0.2s ease;
}
.kyc-row-animate {
  animation: kycFadeIn 0.3s ease-out forwards;
}
@keyframes kycFadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}
.kyc-prev-btn, .kyc-next-btn {
  transition: all 0.2s ease !important;
}
.kyc-prev-btn:hover:not(:disabled), .kyc-next-btn:hover:not(:disabled) {
  border-color: #3b82f6 !important;
  color: #2563eb !important;
  background: #eff6ff !important;
  transform: translateY(-0.5px);
}
.kyc-prev-btn:disabled, .kyc-next-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}
.kyc-approve-btn:hover {
  background: #059669 !important;
  transform: scale(1.05);
  box-shadow: 0 2px 4px rgba(16,185,129,0.2);
}
.kyc-reject-btn:hover {
  background: #dc2626 !important;
  transform: scale(1.05);
  box-shadow: 0 2px 4px rgba(239,68,68,0.2);
}
.view-link-badge:hover {
  background: #dbeafe !important;
  border-color: #3b82f6 !important;
  color: #1d4ed8 !important;
  transform: translateY(-0.5px);
}

/* ── Enhanced stat cards ── */
.db-stat { display:flex; align-items:center; gap:16px; }
.db-stat-icon {
  width:44px; height:44px; border-radius:12px;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.db-stat-hover { transition: transform 0.18s, box-shadow 0.18s; cursor:default; }
.db-stat-hover:hover { transform:translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.08); }

/* ── KPI earnings strip ── */
.db-kpi-strip {
  display:grid; grid-template-columns:repeat(5,1fr);
  gap:14px; margin-bottom:20px;
}
.db-kpi-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius); padding:16px 18px;
  display:flex; align-items:center; gap:12px;
  box-shadow:var(--shadow-sm); transition: transform 0.18s, box-shadow 0.18s;
}
.db-kpi-card:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(0,0,0,0.08); }
.db-kpi-icon { width:38px; height:38px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.db-kpi-label { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:var(--text-muted); margin-bottom:4px; }
.db-kpi-value { font-size:20px; font-weight:800; color:var(--text); letter-spacing:-0.5px; line-height:1; }

/* ── Alerts ── */
.db-alerts-panel { display:flex; flex-direction:column; gap:8px; margin-bottom:20px; }
.db-alert {
  display:flex; align-items:flex-start; gap:10px;
  padding:10px 16px; border-radius:var(--radius-sm);
  border:1px solid; font-size:13px; font-weight:500;
}
.db-alert-warning  { background:rgba(245,158,11,0.08); border-color:rgba(245,158,11,0.25); color:#92400e; }
.db-alert-success  { background:rgba(16,185,129,0.08); border-color:rgba(16,185,129,0.25); color:#065f46; }
.db-alert-info     { background:rgba(99,102,241,0.08); border-color:rgba(99,102,241,0.25); color:#3730a3; }
body.dark-mode .db-alert-warning { color:#fbbf24; }
body.dark-mode .db-alert-success { color:#34d399; }
body.dark-mode .db-alert-info    { color:#a5b4fc; }
.db-alert-icon { display:flex; align-items:center; padding-top:1px; flex-shrink:0; }
.db-alert-detail { display:block; font-size:12px; margin-top:2px; opacity:0.8; }

/* ── Master 2-col grid ── */
.db-master-grid { display:grid; grid-template-columns:1fr 380px; gap:20px; align-items:start; }
.db-col-left  { display:flex; flex-direction:column; gap:16px; }
.db-col-right { display:flex; flex-direction:column; gap:16px; }
.db-chart-card-full { }

/* ── Chart card tweaks ── */
.db-chart-sub { font-size:12px; color:var(--text-muted); margin-top:2px; }

/* ── Status badges ── */
.db-badge {
  display:inline-block; padding:3px 9px; border-radius:99px;
  font-size:11px; font-weight:700; letter-spacing:0.02em;
}
.db-badge-success { background:rgba(16,185,129,0.1); color:#065f46; }
.db-badge-active  { background:rgba(99,102,241,0.1); color:#3730a3; }
.db-badge-danger  { background:rgba(239,68,68,0.1); color:#991b1b; }
.db-badge-pending { background:rgba(245,158,11,0.1); color:#92400e; }
body.dark-mode .db-badge-success { color:#34d399; }
body.dark-mode .db-badge-active  { color:#a5b4fc; }
body.dark-mode .db-badge-danger  { color:#f87171; }
body.dark-mode .db-badge-pending { color:#fbbf24; }

/* ── Live clock ── */
.db-live-clock { font-size:12px; color:var(--text-muted); font-weight:500; display:flex; align-items:center; gap:6px; }
.db-live-dot { width:7px; height:7px; background:#10b981; border-radius:50%; animation: pulse-dot 2s infinite; }
@keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:0.5;transform:scale(0.85);} }

/* ── Responsive ── */
@media(max-width:1100px){
  .db-master-grid { grid-template-columns:1fr; }
  .db-kpi-strip { grid-template-columns:repeat(3,1fr); }
}
@media(max-width:700px){
  .db-kpi-strip { grid-template-columns:repeat(2,1fr); }
  .db-stats { grid-template-columns:repeat(2,1fr); }
}

/* ── Quick action links ── */
.db-quick-link {
  display:flex; align-items:center; gap:7px;
  padding:9px 12px; border-radius:8px;
  border:1px solid var(--border);
  text-decoration:none; color:var(--text);
  font-size:12.5px; font-weight:600;
  transition: background 0.15s, border-color 0.15s;
}
.db-quick-link:hover { background:var(--border-light); border-color:var(--border); }
</style>

<!-- Header -->
<div class="db-header">
  <div class="db-search">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" placeholder="Search orders, users, bikes..." id="dash-search" />
  </div>
  <div class="db-header-right">
    <div class="db-date"><%= todayStr %></div>
    <a href="/admin/orders" class="btn btn-primary" style="gap:6px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Order
    </a>
  </div>
</div>

<!-- Stats -->
<div class="db-stats">
  <div class="db-stat">
    <p class="db-stat-label">Total Users</p>
    <p class="db-stat-value"><%= stats.usersCount || 0 %></p>
    <p class="db-stat-sub">Registered accounts</p>
  </div>
  <div class="db-stat db-stat-hover">
    <div class="db-stat-icon" style="background:rgba(16,185,129,0.1);color:#10b981;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/></svg>
    </div>
    <div>
      <p class="db-stat-label">Fleet Size</p>
      <p class="db-stat-value"><%= stats.bikesCount || 0 %></p>
      <p class="db-stat-sub">Total bikes</p>
    </div>
  </div>
  <div class="db-stat db-stat-hover db-stat-accent">
    <div class="db-stat-icon" style="background:rgba(242,109,33,0.12);color:#f26d21;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    </div>
    <div>
      <p class="db-stat-label">Active Rentals</p>
      <p class="db-stat-value"><%= stats.activeRentalsCount || 0 %></p>
      <p class="db-stat-sub">Currently ongoing</p>
    </div>
  </div>
  <% if (locals.admin && (locals.admin.role === 'sub_admin' || locals.admin.role === 'manager' || locals.admin.role === 'support')) { %>
  <div class="db-stat db-stat-hover">
    <div class="db-stat-icon" style="background:rgba(239,68,68,0.1);color:#ef4444;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    </div>
    <div>
      <p class="db-stat-label">Pending KYC</p>
      <p class="db-stat-value"><%= stats.pendingKycCount || 0 %></p>
      <p class="db-stat-sub">Awaiting verification</p>
    </div>
  </div>
  <% } else { %>
  <div class="db-stat db-stat-hover">
    <div class="db-stat-icon" style="background:rgba(16,185,129,0.1);color:#10b981;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    </div>
    <div>
      <p class="db-stat-label">Total Earnings</p>
      <p class="db-stat-value" style="font-size:20px;">₹<%= Number(stats.totalEarnings || 0).toLocaleString('en-IN', {maximumFractionDigits:0}) %></p>
      <p class="db-stat-sub">Lifetime revenue</p>
    </div>
  </div>
  <% } %>
</div>



<% if (locals.admin && (locals.admin.role === 'sub_admin' || locals.admin.role === 'manager' || locals.admin.role === 'support')) { %>
  <!-- Sub-Admin Operations Control Center Dashboard -->
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; align-items: start;">
    
    <!-- Left Column: KYC Approvals, Expiring Subscriptions & Maintenance Bikes -->
    <div style="display: flex; flex-direction: column; gap: 20px;">
      
      <!-- KYC Document Approvals -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">📋 KYC Document Approvals</p>
            <p class="db-main-sub">Review uploaded rider documents</p>
          </div>
          <span class="pay-badge pay-badge-pending" style="font-size: 12px; font-weight: bold; background: #e0f2fe; color: #0284c7; padding: 4px 10px; border-radius: 9999px;"><%= (pendingKycList || []).length %> Pending</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Rider</th>
              <th>Document</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!pendingKycList || !pendingKycList.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No pending KYC approvals</td></tr>
            <% } else { %>
              <% pendingKycList.forEach(function(doc, index) { %>
              <tr class="kyc-row" data-index="<%= index %>">
                <td><strong><%= doc.userName %></strong><br/><span style="font-size:11px; color:var(--text-muted);"><%= doc.userPhone %></span></td>
                <td>
                  <span class="code-badge" style="background:#e0f2fe; color:#0369a1; font-weight:bold; font-size:11px;"><%= doc.type.toUpperCase().replace('_', ' ') %></span>
                  <a href="<%= doc.fileUrl %>" target="_blank" class="view-link-badge" style="margin-left:8px; font-size:11px; padding: 2px 8px; background:#eff6ff; color:#2563eb; border: 1px solid #bfdbfe; border-radius: 6px; text-decoration:none; font-weight:600; display:inline-block; transition: all 0.2s;">
                    👁 View
                  </a>
                </td>
                <td style="display:flex; gap:6px;">
                  <button class="btn btn-sm btn-primary kyc-approve-btn" data-id="<%= doc.id %>" style="padding:4px 10px; font-size:11.5px; background:#10b981; border:none; color:white; border-radius:6px; font-weight:bold; transition: all 0.2s; cursor:pointer;">Approve</button>
                  <button class="btn btn-sm btn-danger kyc-reject-btn" data-id="<%= doc.id %>" style="padding:4px 10px; font-size:11.5px; background:#ef4444; border:none; color:white; border-radius:6px; font-weight:bold; transition: all 0.2s; cursor:pointer;">Reject</button>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
        <% if (pendingKycList && pendingKycList.length > 5) { %>
        <div class="db-pagination" style="display:flex; justify-content:space-between; align-items:center; padding:12px 24px; border-top:1px solid var(--border-light); background:rgba(0,0,0,0.01);">
          <button type="button" class="kyc-prev-btn" style="padding: 6px 14px; font-size:12px; font-weight:600; border-radius:6px; border:1px solid var(--border); background:#fff; color:#334155; cursor:pointer; display:flex; align-items:center; gap:4px; transition: all 0.2s;" disabled>
            ← Prev
          </button>
          <span class="kyc-page-info" style="font-size:12.5px; color:#475569; font-weight:600;">Page 1 of <%= Math.ceil(pendingKycList.length / 5) %></span>
          <button type="button" class="kyc-next-btn" style="padding: 6px 14px; font-size:12px; font-weight:600; border-radius:6px; border:1px solid var(--border); background:#fff; color:#334155; cursor:pointer; display:flex; align-items:center; gap:4px; transition: all 0.2s;">
            Next →
          </button>
        </div>
        <% } %>
      </div>

      <!-- Expiring Subscriptions (<= 2 Days Left) -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">⏳ Expiring Subscriptions (Next 48h)</p>
            <p class="db-main-sub">Whose 2 days are left</p>
          </div>
          <span class="pay-badge pay-badge-pending" style="font-size: 12px; font-weight: bold; background: #fef3c7; color: #d97706; padding: 4px 10px; border-radius: 9999px;"><%= (expiringSubs || []).length %> Expiring</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Rider</th>
              <th>Plan</th>
              <th>Time Left</th>
            </tr>
          </thead>
          <tbody>
            <% if (!expiringSubs || !expiringSubs.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No subscriptions expiring in next 48h</td></tr>
            <% } else { %>
              <% expiringSubs.forEach(function(sub) { %>
              <tr>
                <td><strong><%= sub.userName %></strong><br/><span style="font-size:11px; color:var(--text-muted);"><%= sub.userPhone %></span></td>
                <td><span class="code-badge" style="background:#f1f5f9; color:#475569; font-weight:bold; font-size:11px;"><%= sub.planName %></span></td>
                <td><span class="status-dot status-pending" style="font-weight: 700; font-size:12.5px;"><%= sub.timeLeftStr %></span></td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>

    <!-- Right Column: Assigned Bikes (Rider-Bike Mappings) & Maintenance -->
    <div style="display: flex; flex-direction: column; gap: 20px;">
      
      <!-- Assigned Bikes (Active Rentals) -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">🚲 Assigned Bikes (Active Rentals)</p>
            <p class="db-main-sub">Current active riders and assignments</p>
          </div>
          <span class="pay-badge pay-badge-success" style="font-size: 12px; font-weight: bold; background: #dcfce7; color: #15803d; padding: 4px 10px; border-radius: 9999px;"><%= (assignedBikes || []).length %> Active</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Rider Details</th>
              <th>Assigned Bike</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!assignedBikes || !assignedBikes.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No active bike assignments</td></tr>
            <% } else { %>
              <% assignedBikes.forEach(function(item) { %>
              <tr id="bike-row-<%= item.bikeId %>">
                <td>
                  <strong><%= item.userName %></strong><br/>
                  <span style="font-size:11px; color:var(--text-muted);"><%= item.userPhone %></span><br/>
                  <span style="font-size:10px; color:var(--text-muted);">Started: <%= item.startTime %></span>
                </td>
                <td>
                  <span class="code-badge" style="background:#e8f5e9; color:#2e7d32; font-weight:bold; font-size:11px; border:1px solid #c8e6c9;"><%= item.bikeCode %></span>
                  <% 
                    let batteryColor = "#10b981"; // green
                    if (item.battery < 25) {
                      batteryColor = "#ef4444"; // red
                    } else if (item.battery < 60) {
                      batteryColor = "#f59e0b"; // yellow
                    }
                  %>
                  <div style="display: flex; align-items: center; gap: 6px; margin-top: 6px;">
                    <div style="width: 50px; height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden; display: inline-block;">
                      <span class="battery-fill-bar" style="display: block; height: 100%; background: <%= batteryColor %>; width: <%= item.battery %>%"></span>
                    </div>
                    <small class="battery-pct-text" style="font-size: 11px; font-weight: 600; color: <%= batteryColor %>;"><%= item.battery %>%</small>
                  </div>
                  <span class="bike-loc-text" style="font-size: 11px; color: var(--text-muted); display: block; margin-top: 4px; font-weight: 500;">
                    📍 <%= item.location || 'Offline / No GPS' %>
                  </span>
                </td>
                <td>
                  <div style="display:flex; flex-direction:column; gap:4px;">
                    <div style="display:flex; gap:4px;">
                      <button class="btn btn-sm btn-outline bike-lock-btn" data-bike-id="<%= item.bikeId %>" style="padding:4px 8px; font-size:10.5px; border-color:#cbd5e1; font-weight:bold; border-radius:6px; cursor:pointer;">⚡ Lock</button>
                      <button class="btn btn-sm btn-outline bike-unlock-btn" data-bike-id="<%= item.bikeId %>" style="padding:4px 8px; font-size:10.5px; border-color:#cbd5e1; font-weight:bold; border-radius:6px; cursor:pointer;">🔓 Unlock</button>
                    </div>
                    <button class="btn btn-sm btn-outline status-check-btn" data-bike-id="<%= item.bikeId %>" style="padding:4px 6px; font-size:10.5px; border-color:#cbd5e1; width:100%; font-weight:bold; border-radius:6px; cursor:pointer;">🔍 Status Check</button>
                    <button class="btn btn-sm btn-danger booking-complete-btn" data-booking-id="<%= item.id %>" style="padding:4px 6px; font-size:10.5px; background:#ef4444; color:white; border:none; width:100%; font-weight:bold; border-radius:6px; cursor:pointer;">🛑 End Ride</button>
                  </div>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Bikes Under Maintenance -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">🔧 Bikes Under Maintenance</p>
            <p class="db-main-sub">Bikes currently in repair/maintenance state</p>
          </div>
          <span class="pay-badge pay-badge-failed" style="font-size: 12px; font-weight: bold; background: #fee2e2; color: #ef4444; padding: 4px 10px; border-radius: 9999px;"><%= (activeMaintenance || []).length %> in Repair</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>Bike</th>
              <th>Issue / Work Details</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!activeMaintenance || !activeMaintenance.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No bikes in maintenance</td></tr>
            <% } else { %>
              <% activeMaintenance.forEach(function(m) { %>
              <tr>
                <td><span class="code-badge" style="background:#f1f5f9; color:#0f172a; font-weight:bold; font-size:11px;"><%= m.bikeCode %></span></td>
                <td>
                  <strong><%= m.issueType %></strong><br/>
                  <span style="font-size:11px; color:var(--text-muted); display:inline-block; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= m.workDetails %>"><%= m.workDetails %></span>
                </td>
                <td>
                  <button class="btn btn-sm btn-primary bike-fixed-btn" data-bike-id="<%= m.bikeId %>" style="padding:4px 8px; font-size:11px; background:#10b981; border:none; color:white; border-radius:6px; font-weight:bold;">✅ Fixed</button>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pending Payment Verifications -->
      <div class="db-main" style="margin-bottom: 0;">
        <div class="db-main-head" style="padding: 20px 24px;">
          <div>
            <p class="db-main-title" style="font-size: 16px;">💳 Pending Payment Verifications</p>
            <p class="db-main-sub">Verify manual/UPI payments with UTR/receipts</p>
          </div>
          <span class="pay-badge pay-badge-pending" style="font-size: 12px; font-weight: bold; background: #e0f2fe; color: #0284c7; padding: 4px 10px; border-radius: 9999px;"><%= (pendingPayments || []).length %> Pending</span>
        </div>
        <table class="db-table">
          <thead>
            <tr>
              <th>User</th>
              <th>Details</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!pendingPayments || !pendingPayments.length) { %>
            <tr><td colspan="3" style="text-align:center; color:var(--text-muted); padding: 24px; font-size:13px;">No pending payment verifications</td></tr>
            <% } else { %>
              <% pendingPayments.forEach(function(pay) { %>
              <tr>
                <td><strong><%= pay.userName %></strong><br/><span style="font-size:11px; color:var(--text-muted);"><%= pay.userPhone %></span></td>
                <td>
                  <strong>₹<%= pay.amount %></strong><br/>
                  <span style="font-size:11px; color:var(--text-muted);">UTR: <%= pay.utr %></span>
                  <% if (pay.screenshotUrl) { %>
                  <a href="<%= pay.screenshotUrl %>" target="_blank" class="view-link-badge" style="margin-left:8px; font-size:11px; padding: 2px 8px; background:#eff6ff; color:#2563eb; border: 1px solid #bfdbfe; border-radius: 6px; text-decoration:none; font-weight:600; display:inline-block; transition: all 0.2s;">
                    📸 View Receipt
                  </a>
                  <% } %>
                </td>
                <td style="display:flex; gap:6px;">
                  <button class="btn btn-sm btn-primary payment-approve-btn" data-id="<%= pay.id %>" style="padding:4px 10px; font-size:11.5px; background:#10b981; border:none; color:white; border-radius:6px; font-weight:bold; transition: all 0.2s; cursor:pointer;">Approve</button>
                  <button class="btn btn-sm btn-danger payment-reject-btn" data-id="<%= pay.id %>" style="padding:4px 10px; font-size:11.5px; background:#ef4444; border:none; color:white; border-radius:6px; font-weight:bold; transition: all 0.2s; cursor:pointer;">Reject</button>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>

  </div>
<% } else { %>

  <!-- KPI Earnings Strip -->
  <div class="db-kpi-strip">
    <div class="db-kpi-card">
      <div class="db-kpi-icon" style="background:rgba(99,102,241,0.1);color:#6366f1;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      </div>
      <div><p class="db-kpi-label">Today</p><p class="db-kpi-value">₹<%= Number(earningsBreakdown&&earningsBreakdown.today||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></p></div>
    </div>
    <div class="db-kpi-card">
      <div class="db-kpi-icon" style="background:rgba(16,185,129,0.1);color:#10b981;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
      </div>
      <div><p class="db-kpi-label">This Week</p><p class="db-kpi-value">₹<%= Number(earningsBreakdown&&earningsBreakdown.weekly||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></p></div>
    </div>
    <div class="db-kpi-card">
      <div class="db-kpi-icon" style="background:rgba(242,109,33,0.1);color:#f26d21;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      </div>
      <div><p class="db-kpi-label">This Month</p><p class="db-kpi-value">₹<%= Number(earningsBreakdown&&earningsBreakdown.monthly||0).toLocaleString('en-IN',{maximumFractionDigits:0}) %></p></div>
    </div>
    <div class="db-kpi-card">
      <div class="db-kpi-icon" style="background:rgba(245,158,11,0.1);color:#f59e0b;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      </div>
      <div><p class="db-kpi-label">Pending KYC</p><p class="db-kpi-value"><%= stats.pendingKycCount||0 %></p></div>
    </div>
    <div class="db-kpi-card">
      <div class="db-kpi-icon" style="background:rgba(239,68,68,0.1);color:#ef4444;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="16" height="11" rx="2"/><path d="M22 11v3"/></svg>
      </div>
      <div><p class="db-kpi-label">Low Battery</p><p class="db-kpi-value"><%= (lowBatteryBikes||[]).length %></p></div>
    </div>
  </div>

  <!-- Alerts Panel -->
  <% if (alerts && alerts.length) { %>
  <div class="db-alerts-panel">
    <% alerts.forEach(function(a){ %>
    <div class="db-alert db-alert-<%= a.level %>">
      <span class="db-alert-icon">
        <% if(a.level==='warning'){ %><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <% }else if(a.level==='success'){ %><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <% }else{ %><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><% } %>
      </span>
      <div><strong><%= a.title %></strong><% if(a.detail){ %><span class="db-alert-detail"><%= a.detail %></span><% } %></div>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- Master 2-col Grid -->
  <div class="db-master-grid">

    <!-- LEFT: Charts -->
    <div class="db-col-left">

      <!-- Revenue Line Chart -->
      <div class="db-chart-card">
        <div class="db-chart-head">
          <div>
            <p class="db-chart-title">Revenue — Last 7 Days</p>
            <p class="db-chart-sub">Daily earnings from completed orders</p>
          </div>
          <div class="db-live-clock"><span class="db-live-dot"></span><span id="db-live-clock"></span></div>
        </div>
        <div style="height:230px;position:relative;"><canvas id="revenueChart"></canvas></div>
      </div>

      <!-- Two mini doughnut charts -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div class="db-chart-card">
          <div class="db-chart-head">
            <div><p class="db-chart-title">Orders by Status</p><p class="db-chart-sub">All-time breakdown</p></div>
          </div>
          <div style="height:180px;position:relative;"><canvas id="ordersChart"></canvas></div>
          <div id="ordersLegend" style="display:flex;flex-wrap:wrap;gap:6px;padding:10px 16px 14px;"></div>
        </div>
        <div class="db-chart-card">
          <div class="db-chart-head">
            <div><p class="db-chart-title">Fleet Status</p><p class="db-chart-sub">Bike availability now</p></div>
          </div>
          <div style="height:180px;position:relative;"><canvas id="fleetChart"></canvas></div>
          <div id="fleetLegend" style="display:flex;flex-wrap:wrap;gap:6px;padding:10px 16px 14px;"></div>
        </div>
      </div>

    </div>

    <!-- RIGHT: Recent Orders + Low Battery + Quick Links -->
    <div class="db-col-right">

      <!-- Recent Orders Table -->
      <div class="db-chart-card">
        <div class="db-chart-head" style="border-bottom:1px solid var(--border);padding-bottom:14px;margin-bottom:0;">
          <div>
            <p class="db-chart-title">Recent Orders</p>
            <p class="db-chart-sub"><%= (recentActivity||[]).length %> latest transactions</p>
          </div>
          <a href="/admin/orders" style="font-size:12px;font-weight:600;color:var(--accent);text-decoration:none;">View All &rarr;</a>
        </div>
        <table class="db-table" style="margin:0;">
          <thead><tr><th>Order</th><th>Amt</th><th>Status</th></tr></thead>
          <tbody>
            <% var rList = (recentActivity||[]).slice(0,10); %>
            <% if(!rList.length){ %><tr><td colspan="3" style="text-align:center;color:var(--text-muted);padding:24px;">No recent activity</td></tr><% } %>
            <% rList.forEach(function(item){ var st=(item.title||'').toLowerCase(); var amtM=(item.title||'').match(/\u20b9([\d,]+)/); %>
            <tr>
              <td>
                <div style="font-weight:600;font-size:12.5px;color:var(--text);line-height:1.3;"><%= item.title||'—' %></div>
                <div style="color:var(--text-muted);font-size:11px;margin-top:2px;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= item.subtitle||'' %></div>
              </td>
              <td style="font-weight:700;font-size:12.5px;"><%= amtM?'₹'+amtM[1]:'—' %></td>
              <td>
                <% var badge=st.includes('completed')||st.includes('paid')?'success':st.includes('active')||st.includes('ongoing')||st.includes('accepted')?'active':st.includes('cancelled')||st.includes('rejected')?'danger':'pending'; %>
                <span class="db-badge db-badge-<%= badge %>"><%= badge==='success'?'Paid':badge==='active'?'Active':badge==='danger'?'Cancelled':'Pending' %></span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Low Battery Bikes -->
      <% if(lowBatteryBikes && lowBatteryBikes.length){ %>
      <div class="db-chart-card">
        <div class="db-chart-head" style="border-bottom:1px solid var(--border);padding-bottom:14px;margin-bottom:0;">
          <div><p class="db-chart-title" style="color:#ef4444;">&#x1F50B; Low Battery Alert</p><p class="db-chart-sub">Bikes below 25% — needs charge</p></div>
          <span style="background:rgba(239,68,68,0.1);color:#ef4444;font-size:11px;font-weight:700;padding:3px 9px;border-radius:99px;"><%= lowBatteryBikes.length %> critical</span>
        </div>
        <% lowBatteryBikes.slice(0,5).forEach(function(bike){ var pct=bike.battery_level||bike.battery||0; %>
        <div style="display:flex;align-items:center;gap:10px;padding:10px 18px;border-bottom:1px solid var(--border-light);">
          <div style="width:30px;height:30px;border-radius:8px;background:rgba(239,68,68,0.1);display:flex;align-items:center;justify-content:center;color:#ef4444;flex-shrink:0;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="16" height="11" rx="2"/><path d="M22 11v3"/></svg>
          </div>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:12.5px;"><%= bike.code||bike.bike_code||('Bike #'+(bike.id||'')) %></div>
            <div style="width:100%;height:4px;background:var(--border);border-radius:2px;margin-top:4px;overflow:hidden;">
              <div style="height:100%;width:<%= pct %>%;background:#ef4444;border-radius:2px;"></div>
            </div>
          </div>
          <span style="font-weight:800;font-size:12px;color:#ef4444;"><%= pct %>%</span>
        </div>
        <% }) %>
      </div>
      <% } %>

      <!-- Quick Actions -->
      <div class="db-chart-card">
        <p class="db-chart-title" style="margin-bottom:12px;">Quick Actions</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          <a href="/admin/kyc-documents" class="db-quick-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> KYC Review</a>
          <a href="/admin/payments" class="db-quick-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Payments</a>
          <a href="/admin/bikes" class="db-quick-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/></svg> Fleet</a>
          <a href="/admin/earnings" class="db-quick-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f26d21" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg> Earnings</a>
          <a href="/admin/orders" class="db-quick-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg> All Orders</a>
          <a href="/admin/users" class="db-quick-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> Users</a>
        </div>
      </div>

    </div>
  </div>

<% } %>


<script>
(() => {
  const ctx = document.getElementById("revenueChart");
  const isDark = document.body.classList.contains("dark-mode");
  const gridColor = isDark ? "rgba(255,255,255,0.05)" : "#f3f4f6";
  const tickColor = isDark ? "#525252" : "#9ca3af";
  const tooltipBase = {
    backgroundColor: isDark?"#1a1a1a":"#fff",
    titleColor: isDark?"#f5f5f5":"#111827",
    bodyColor: isDark?"#a3a3a3":"#6b7280",
    borderColor: isDark?"#262626":"#e5e7eb",
    borderWidth:1, padding:10
  };

  function buildLegend(id, labels, colors) {
    var el = document.getElementById(id);
    if (!el) return;
    el.innerHTML = labels.map(function(l,i){
      return '<span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;color:var(--text-muted);"><span style="width:8px;height:8px;border-radius:50%;background:'+colors[i]+';flex-shrink:0;"></span>'+l+'</span>';
    }).join('');
  }

  // Revenue Line Chart
  var ctx = document.getElementById("revenueChart");
  if (window.Chart && ctx) {
    var revLabels = <%- JSON.stringify(revenueChart&&revenueChart.labels||['Mon','Tue','Wed','Thu','Fri','Sat','Sun']) %>;
    var revData   = <%- JSON.stringify(revenueChart&&revenueChart.data  ||[0,0,0,0,0,0,0]) %>;
    new Chart(ctx, {
      type: "line",
      data: { labels: revLabels, datasets: [{
        label: "Revenue (₹)", data: revData,
        borderColor: "#f26d21", backgroundColor: "rgba(242,109,33,0.10)",
        borderWidth: 2.5, fill: true, tension: 0.4,
        pointRadius: 4, pointBackgroundColor: "#f26d21", pointHoverRadius: 6
      }]},
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend:{display:false}, tooltip:{ ...tooltipBase, callbacks:{ label: function(c){ return '₹'+Number(c.raw).toLocaleString('en-IN'); }}}},
        scales: {
          x: { ticks:{color:tickColor,font:{size:11}}, grid:{display:false}},
          y: { beginAtZero:true, ticks:{color:tickColor,font:{size:11},callback:function(v){return '₹'+v;}}, grid:{color:gridColor}}
        }
      }
    });
  }

  // Orders Doughnut Chart
  var ordersCtx = document.getElementById("ordersChart");
  if (window.Chart && ordersCtx) {
    var oLabels = <%- JSON.stringify(ordersChart&&ordersChart.labels||['Pending','Accepted','Ongoing','Completed','Cancelled']) %>;
    var oData   = <%- JSON.stringify(ordersChart&&ordersChart.data  ||[0,0,0,0,0]) %>;
    var oColors = ["#fbbf24","#34d399","#60a5fa","#a78bfa","#f87171"];
    new Chart(ordersCtx, {
      type: "doughnut",
      data: { labels: oLabels, datasets:[{ data:oData, backgroundColor:oColors, borderWidth:2, borderColor: isDark?"#141414":"#fff", hoverOffset:6}]},
      options: { responsive:true, maintainAspectRatio:false, cutout:"65%",
        plugins:{ legend:{display:false}, tooltip:{...tooltipBase}}}
    });
    buildLegend("ordersLegend", oLabels, oColors);
  }

  // Fleet Doughnut Chart
  var fleetCtx = document.getElementById("fleetChart");
  if (window.Chart && fleetCtx) {
    var activeCount = <%- JSON.stringify(stats&&stats.activeRentalsCount||0) %>;
    var totalBikes  = <%- JSON.stringify(stats&&stats.bikesCount||0) %>;
    var maintCount  = <%- JSON.stringify((lowBatteryBikes||[]).length) %>;
    var available   = Math.max(0, totalBikes - activeCount - maintCount);
    var fLabels = ["Active Rentals","Available","Low Battery"];
    var fData   = [activeCount, available, maintCount];
    var fColors = ["#f26d21","#10b981","#ef4444"];
    new Chart(fleetCtx, {
      type: "doughnut",
      data: { labels: fLabels, datasets:[{ data:fData, backgroundColor:fColors, borderWidth:2, borderColor: isDark?"#141414":"#fff", hoverOffset:6}]},
      options: { responsive:true, maintainAspectRatio:false, cutout:"65%",
        plugins:{ legend:{display:false}, tooltip:{...tooltipBase}}}
    });
    buildLegend("fleetLegend", fLabels, fColors);
  }

  // Live Clock
  var clockEl = document.getElementById("db-live-clock");
  if (clockEl) {
    var tick = function(){ clockEl.textContent = new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); };
    tick(); setInterval(tick, 1000);
  }


  // Dashboard Search Logic
  const searchInput = document.getElementById("dash-search");
  if (searchInput) {
    searchInput.addEventListener("input", (e) => {
      const term = e.target.value.toLowerCase();
      const rows = document.querySelectorAll(".db-table tbody tr");
      rows.forEach((row) => {
        if (row.cells.length === 1) return; // skip "No activity" row
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(term) ? "" : "none";
      });
    });

    searchInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && e.target.value.trim().length > 0) {
        window.location.href = "/admin/orders?search=" + encodeURIComponent(e.target.value.trim());
      }
    });
  }

  // Operations Control Center AJAX Event Listeners
  document.querySelectorAll(".kyc-approve-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const docId = btn.getAttribute("data-id");
      handleAction(`/admin/kyc-documents/${docId}/status`, "POST", { status: "verified" });
    });
  });

  document.querySelectorAll(".kyc-reject-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const docId = btn.getAttribute("data-id");
      const reason = prompt("Please enter the reason for rejecting this document:");
      if (reason === null) return; // cancel clicked
      if (!reason.trim()) {
        showToast("Rejection reason cannot be empty", "error");
        return;
      }
      handleAction(`/admin/kyc-documents/${docId}/status`, "POST", { status: "rejected", reason: reason.trim() });
    });
  });

  document.querySelectorAll(".payment-approve-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const paymentId = btn.getAttribute("data-id");
      if (confirm("Are you sure you want to APPROVE this payment?")) {
        handleAction(`/admin/payments/${paymentId}/edit`, "POST", { status: "success" });
      }
    });
  });

  document.querySelectorAll(".payment-reject-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const paymentId = btn.getAttribute("data-id");
      if (confirm("Are you sure you want to REJECT this payment?")) {
        handleAction(`/admin/payments/${paymentId}/edit`, "POST", { status: "failed" });
      }
    });
  });

  document.querySelectorAll(".bike-lock-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const bikeId = btn.getAttribute("data-bike-id");
      if (confirm("Are you sure you want to LOCK this bike?")) {
        handleAction(`/admin/bikes/${bikeId}/lock`, "POST");
      }
    });
  });

  document.querySelectorAll(".bike-unlock-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const bikeId = btn.getAttribute("data-bike-id");
      if (confirm("Are you sure you want to UNLOCK this bike?")) {
        handleAction(`/admin/bikes/${bikeId}/unlock`, "POST");
      }
    });
  });

  document.querySelectorAll(".booking-complete-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const bookingId = btn.getAttribute("data-booking-id");
      if (confirm("Are you sure you want to END this ride manually?")) {
        handleAction(`/admin/bookings/${bookingId}/complete`, "POST");
      }
    });
  });

  document.querySelectorAll(".bike-fixed-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const bikeId = btn.getAttribute("data-bike-id");
      if (confirm("Mark this bike as FIXED and return it to service?")) {
        handleAction(`/admin/maintenance/${bikeId}/fixed`, "POST");
      }
    });
  });

  document.querySelectorAll(".status-check-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      const bikeId = btn.getAttribute("data-bike-id");
      const row = document.getElementById(`bike-row-${bikeId}`);
      if (!row) return;

      const locTextEl = row.querySelector(".bike-loc-text");
      const fillBarEl = row.querySelector(".battery-fill-bar");
      const pctTextEl = row.querySelector(".battery-pct-text");
      
      btn.disabled = true;
      btn.innerHTML = "⏳ Checking...";

      try {
        const adminToken = localStorage.getItem("adminToken");
        const res = await fetch(`/admin/bikes/${bikeId}/live-gps`, {
          headers: {
            "Content-Type": "application/json",
            ...(adminToken ? { Authorization: `Bearer ${adminToken}` } : {}),
          }
        });
        if (res.status === 401) {
          localStorage.removeItem("adminToken");
          window.location.href = "/admin/login";
          return;
        }
        const data = await res.json();
        if (data.success) {
          // Update location text
          if (data.isLive && data.lat && data.lng) {
            locTextEl.innerHTML = `📍 Live: ${data.lat.toFixed(5)}, ${data.lng.toFixed(5)}`;
            locTextEl.style.color = "#10b981"; // success green
          } else {
            locTextEl.innerHTML = "📍 GPS signal unavailable";
            locTextEl.style.color = "#ef4444"; // error red
          }
          
          // Update battery indicators
          const battery = Number(data.battery || 0);
          pctTextEl.textContent = `${battery}%`;
          fillBarEl.style.width = `${battery}%`;
          if (battery < 25) {
            fillBarEl.style.background = "#ef4444"; // red
            pctTextEl.style.color = "#ef4444";
          } else if (battery < 60) {
            fillBarEl.style.background = "#f59e0b"; // yellow
            pctTextEl.style.color = "#f59e0b";
          } else {
            fillBarEl.style.background = "#10b981"; // green
            pctTextEl.style.color = "#10b981";
          }
          
          showToast(`Status checked for bike ${bikeId}`);
          btn.innerHTML = "✓ Updated";
          setTimeout(() => {
            btn.disabled = false;
            btn.innerHTML = "🔍 Status Check";
          }, 3000);
        } else {
          showToast("Failed to fetch GPS status", "error");
          btn.disabled = false;
          btn.innerHTML = "🔍 Status Check";
        }
      } catch (err) {
        showToast("Error checking status", "error");
        btn.disabled = false;
        btn.innerHTML = "🔍 Status Check";
      }
    });
  });

  // Client-side KYC approvals pagination
  (function () {
    let currentPage = 1;
    const itemsPerPage = 5;
    const rows = document.querySelectorAll('.kyc-row');
    const totalPages = Math.ceil(rows.length / itemsPerPage);
    
    function showPage(page) {
      if (page < 1 || page > totalPages) return;
      currentPage = page;
      const start = (page - 1) * itemsPerPage;
      const end = start + itemsPerPage;
      
      rows.forEach((row, idx) => {
        if (idx >= start && idx < end) {
          row.style.display = '';
          row.classList.add('kyc-row-animate');
        } else {
          row.style.display = 'none';
          row.classList.remove('kyc-row-animate');
        }
      });
      
      const prevBtn = document.querySelector('.kyc-prev-btn');
      const nextBtn = document.querySelector('.kyc-next-btn');
      const pageInfo = document.querySelector('.kyc-page-info');
      
      if (prevBtn) prevBtn.disabled = (currentPage === 1);
      if (nextBtn) nextBtn.disabled = (currentPage === totalPages || totalPages === 0);
      if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages || 1}`;
    }
    
    if (rows.length > 0) {
      showPage(1);
    }
    
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('kyc-prev-btn')) {
        if (currentPage > 1) showPage(currentPage - 1);
      }
      if (e.target.classList.contains('kyc-next-btn')) {
        if (currentPage < totalPages) showPage(currentPage + 1);
      }
    });
  })();
})();
</script>
