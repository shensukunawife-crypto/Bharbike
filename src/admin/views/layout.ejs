<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= BRAND_NAME %> Admin — <%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/admin/static/css/style.css?v=3" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
      window.__BRAND_NAME__ = "<%= BRAND_NAME %>";
      window.__BRAND_PRODUCT_NAME__ = "<%= BRAND_PRODUCT_NAME %>";
    </script>
  </head>
  <body>
    <div class="admin-shell">

      <!-- SIDEBAR -->
      <aside class="sidebar" id="admin-sidebar">

        <!-- Logo -->
        <div class="sidebar-logo">
          <div class="logo-mark" style="background: none; border-radius: 0; width: 51px; height: 51px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
            <img src="/admin/static/images/logo.png" alt="<%= BRAND_NAME %> Logo" style="width: 100%; height: 100%; object-fit: contain;" />
          </div>
          <div class="logo-text">
            <span class="logo-name"><%= BRAND_NAME.substring(0,4) %><span class="logo-accent"><%= BRAND_NAME.substring(4) %></span></span>
            <span class="logo-sub">Admin Console</span>
          </div>
          <button id="sidebar-collapse-btn" class="sidebar-collapse-btn" title="Collapse sidebar" aria-label="Collapse sidebar">
            <svg id="collapse-icon-left" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            <svg id="collapse-icon-right" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>

        <!-- Nav -->
        <nav class="sidebar-nav" id="admin-sidebar-nav">
          <%- include('partials/sidebar-nav') %>
        </nav>

        <!-- User Profile at bottom -->
        <div class="sidebar-user">
          <div class="sidebar-user-avatar">
            <%= (locals.admin && (locals.admin.full_name || locals.admin.email)) ? (locals.admin.full_name || locals.admin.email).charAt(0).toUpperCase() : 'A' %>
          </div>
          <div class="sidebar-user-info">
            <p class="sidebar-user-name"><%= (locals.admin && (locals.admin.full_name || locals.admin.email)) ? (locals.admin.full_name || locals.admin.email) : 'Admin' %></p>
            <p class="sidebar-user-role"><%= (locals.admin && locals.admin.role) ? locals.admin.role.replace(/_/g,' ') : 'master admin' %></p>
          </div>
          <button id="admin-logout-btn" class="sidebar-logout-btn" title="Logout">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          </button>
        </div>

      </aside>

      <!-- MAIN -->
      <div class="main-area">

        <!-- Topbar -->
        <header class="topbar">
          <div class="topbar-left">
            <button class="mobile-menu-btn" id="sidebar-menu-btn" aria-label="Toggle menu">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </button>
            <div>
              <h1 class="topbar-title"><%= title %></h1>
            </div>
          </div>
          <div class="topbar-right">
            <!-- Dark Mode Toggle -->
            <button id="theme-toggle" class="icon-btn" title="Toggle dark mode">
              <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
              <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </button>
            <!-- Admin Info -->
            <% if (locals.admin) { %>
            <div class="topbar-admin">
              <div class="topbar-admin-avatar">
                <%= (locals.admin.full_name || locals.admin.email || 'A').charAt(0).toUpperCase() %>
              </div>
              <div class="topbar-admin-info">
                <span class="topbar-admin-name"><%= locals.admin.full_name || locals.admin.email %></span>
                <span class="topbar-admin-role"><%= (locals.admin.role || 'admin').replace(/_/g,' ') %></span>
              </div>
            </div>
            <% } %>
          </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
          <% if (locals.isServiceRoleConfigured === false) { %>
            <div class="rls-warning-banner" style="background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.25); border-radius: var(--radius); padding: 16px 20px; margin-bottom: 24px; display: flex; align-items: flex-start; gap: 16px; color: var(--text);">
              <div style="background: #dc2626; color: white; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-weight: 800; font-size: 18px; box-shadow: 0 4px 12px rgba(220, 38, 38, 0.2);">⚠️</div>
              <div style="flex: 1;">
                <h4 style="margin: 0 0 4px 0; font-size: 14.5px; font-weight: 700; color: var(--text);">Restricted Database Key Mode (RLS Active)</h4>
                <p style="margin: 0; font-size: 13px; color: var(--text-muted); line-height: 1.45;">
                  The backend server is running with the public anonymous key (Subject to Row Level Security) because the <strong>SUPABASE_SERVICE_ROLE_KEY</strong> environment variable is missing. Due to RLS policies, public SELECT queries on the <code>users</code> table are filtered, resulting in <strong>0 users</strong> being displayed on the dashboard and users page.
                </p>
                <div style="margin-top: 10px; display: flex; gap: 12px; align-items: center;">
                  <span style="font-size: 11.5px; font-weight: 700; color: #ef4444; text-transform: uppercase; letter-spacing: 0.05em;"><%= locals.isProduction ? 'Action Required: Configure Render' : 'Action Required: Local .env File' %></span>
                  <a href="#diagnostics-help" onclick="alert('How to Fix This:\n\n1. PRODUCTION (Render):\nGo to Render Dashboard -> bharbike-backend -> Environment. Add a new variable:\n- Key: SUPABASE_SERVICE_ROLE_KEY\n- Value: (Your Supabase service_role secret key from Project Settings -> API)\n\n2. LOCAL DEVELOPMENT:\nAdd SUPABASE_SERVICE_ROLE_KEY to your bike rental system backend/.env file and restart the npm server.')" style="font-size: 12.5px; font-weight: 700; color: var(--text); text-decoration: underline;">How to Fix This</a>
                </div>
              </div>
            </div>
          <% } %>
          <%- include(bodyView) %>
        </main>

      </div>
    </div>

    <div id="toast-container" class="toast-container"></div>

    <script>
      (() => {
        // Auth check
        const token = localStorage.getItem("adminToken");
        if (!token) { window.location.href = "/admin/login"; return; }

        // Logout
        const logoutBtn = document.getElementById("admin-logout-btn");
        if (logoutBtn) {
          logoutBtn.addEventListener("click", () => {
            localStorage.removeItem("adminToken");
            document.cookie = "admin_token=; Path=/; Max-Age=0; SameSite=Lax";
            window.location.href = "/admin/login";
          });
        }

        // Dark mode
        const themeToggle = document.getElementById("theme-toggle");
        const iconMoon = document.getElementById("icon-moon");
        const iconSun = document.getElementById("icon-sun");
        const applyTheme = (dark) => {
          document.body.classList.toggle("dark-mode", dark);
          if (iconMoon) iconMoon.style.display = dark ? "none" : "block";
          if (iconSun) iconSun.style.display = dark ? "block" : "none";
        };
        applyTheme(localStorage.getItem("adminTheme") === "dark");
        if (themeToggle) {
          themeToggle.addEventListener("click", () => {
            const isDark = document.body.classList.toggle("dark-mode");
            localStorage.setItem("adminTheme", isDark ? "dark" : "light");
            applyTheme(isDark);
          });
        }

        // Mobile sidebar
        const menuBtn = document.getElementById("sidebar-menu-btn");
        const sidebar = document.getElementById("admin-sidebar");
        if (menuBtn && sidebar) {
          menuBtn.addEventListener("click", () => sidebar.classList.toggle("open"));
        }

        // Sidebar collapse (desktop)
        const collapseBtn = document.getElementById("sidebar-collapse-btn");
        const iconLeft = document.getElementById("collapse-icon-left");
        const iconRight = document.getElementById("collapse-icon-right");
        const shell = document.querySelector(".admin-shell");
        const applyCollapse = (collapsed) => {
          if (sidebar) sidebar.classList.toggle("sidebar-collapsed", collapsed);
          if (shell) shell.classList.toggle("sidebar-is-collapsed", collapsed);
          if (iconLeft) iconLeft.style.display = collapsed ? "none" : "block";
          if (iconRight) iconRight.style.display = collapsed ? "block" : "none";
          if (collapseBtn) collapseBtn.title = collapsed ? "Expand sidebar" : "Collapse sidebar";
        };
        const savedCollapse = localStorage.getItem("adminSidebarCollapsed") === "true";
        applyCollapse(savedCollapse);
        if (collapseBtn) {
          collapseBtn.addEventListener("click", () => {
            const next = !sidebar.classList.contains("sidebar-collapsed");
            applyCollapse(next);
            localStorage.setItem("adminSidebarCollapsed", next ? "true" : "false");
          });
        }
      })();
    </script>
    <script src="/admin/static/js/sidebar-nav.js?v=3"></script>
    <script src="/admin/static/js/admin.js?v=3"></script>
  </body>
</html>
