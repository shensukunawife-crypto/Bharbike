<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= BRAND_NAME %> Admin - <%= title %></title>
    <link rel="stylesheet" href="/admin/static/css/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
      window.__BRAND_NAME__ = "<%= BRAND_NAME %>";
      window.__BRAND_PRODUCT_NAME__ = "<%= BRAND_PRODUCT_NAME %>";
    </script>
  </head>
  <body>
    <div class="admin-shell">
      <aside class="sidebar">
        <div class="brand">
          <span class="brand-mark">◆</span>
          <span class="brand-copy">
            <span class="brand-title"><%= BRAND_NAME.substring(0, 3) %><span style="color: #F26D21;"><%= BRAND_NAME.substring(3) %></span> Admin</span>
            <span class="brand-subtitle">Smart Rental Management</span>
          </span>
        </div>
        <%- include('partials/sidebar-nav') %>
      </aside>
      <main class="content main-content">
        <header class="topbar">
          <div class="topbar-leading">
            <button
              type="button"
              class="sidebar-menu-btn"
              id="sidebar-menu-btn"
              aria-label="Open navigation menu"
              aria-expanded="false"
              aria-controls="admin-sidebar-nav"
            >
              ☰
            </button>
            <div class="topbar-title-group">
              <h1><%= title %></h1>
              <p>Startup SaaS Admin Dashboard</p>
            </div>
          </div>
          <div class="topbar-profile">
            <button id="admin-logout-btn" class="btn btn-sm">Logout</button>
            <% const _adminInitial = (locals.admin && (locals.admin.full_name || locals.admin.email)) ? (locals.admin.full_name || locals.admin.email).charAt(0).toUpperCase() : 'A'; %>
            <% if (locals.admin) { %>
              <% const _badgeBg = (locals.admin.role === 'master_admin' || locals.admin.role === 'admin') ? '#F26D21' : '#4f46e5'; %>
              <% const _badgeLabel = locals.admin.role === 'master_admin' ? 'MASTER' : (locals.admin.role || 'SUB').toUpperCase(); %>
              <% const _adminDisplay = locals.admin.full_name || locals.admin.email || 'Admin'; %>
              <span class="admin-name" style="display:flex;align-items:center;gap:6px;">
                <%= _adminDisplay %>
                <span class="role-badge" style="font-size:10px;background:<%= _badgeBg %>;color:#fff;padding:2px 7px;border-radius:10px;font-weight:700;letter-spacing:.4px;">
                  <%= _badgeLabel %>
                </span>
              </span>
            <% } else { %>
              <span class="admin-name">Admin</span>
            <% } %>
            <span class="profile-circle"><%= _adminInitial %></span>
          </div>
        </header>
        <section class="panel">
          <%- include(bodyView) %>
        </section>
      </main>
    </div>
    <div class="sidebar-backdrop" id="sidebar-backdrop" aria-hidden="true"></div>
    <div id="toast-container" class="toast-container"></div>
    <script>
      (() => {
        const token = localStorage.getItem("adminToken");
        if (!token) {
          window.location.href = "/admin/login";
          return;
        }
        const logoutBtn = document.getElementById("admin-logout-btn");
        if (logoutBtn) {
          logoutBtn.addEventListener("click", () => {
            localStorage.removeItem("adminToken");
            document.cookie = "admin_token=; Path=/; Max-Age=0; SameSite=Lax";
            window.location.href = "/admin/login";
          });
        }
      })();
    </script>
    <script src="/admin/static/js/sidebar-nav.js"></script>
    <script src="/admin/static/js/admin.js"></script>
  </body>
</html>
