<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-head">
      <span class="stat-label">🛠️ Total in Maintenance</span>
    </div>
    <strong class="stat-value" style="color: var(--accent);"><%= maintenanceStats?.total || 0 %></strong>
  </div>
  
  <div class="stat-card">
    <div class="stat-head">
      <span class="stat-label">⏳ Active Repairs</span>
    </div>
    <strong class="stat-value" style="color: #f59e0b;"><%= maintenanceStats?.inProgress || 0 %></strong>
  </div>
  
  <div class="stat-card">
    <div class="stat-head">
      <span class="stat-label">✅ Completed Fixes</span>
    </div>
    <strong class="stat-value" style="color: #10b981;"><%= maintenanceStats?.completed || 0 %></strong>
  </div>
  
  <div class="stat-card">
    <div class="stat-head">
      <span class="stat-label">💰 Repair Expenses</span>
    </div>
    <strong class="stat-value" style="color: #3b82f6;">₹<%= Number(maintenanceStats?.totalCost || 0).toLocaleString('en-IN') %></strong>
  </div>
</div>

<div class="toolbar" style="background: var(--surface); border: 1px solid var(--border); padding: 16px; border-radius: var(--radius); box-shadow: var(--shadow-sm); margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;">
  <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
    <button class="btn btn-gold glow" data-modal-target="add-maintenance-modal" style="font-weight: 700;">
      ➕ Add Bike to Repair
    </button>
    <div style="width: 1px; height: 24px; background-color: var(--border); margin: 0 8px;"></div>
    <a class="btn <%= filter === 'all' ? 'btn-gold' : 'btn-ghost' %>" href="/admin/maintenance?filter=all" style="font-weight: 600;">All Tickets</a>
    <a class="btn <%= filter === 'active' ? 'btn-gold' : 'btn-ghost' %>" href="/admin/maintenance?filter=active" style="font-weight: 600;">Active</a>
    <a class="btn <%= filter === 'completed' ? 'btn-gold' : 'btn-ghost' %>" href="/admin/maintenance?filter=completed" style="font-weight: 600;">Completed</a>
  </div>
  
  <form method="GET" action="/admin/maintenance" class="inline-form" style="display: flex; gap: 8px; align-items: center;">
    <input type="hidden" name="filter" value="<%= filter %>" />
    <input class="filter-input" type="text" name="search" value="<%= search || '' %>" placeholder="🔍 Search Bike ID..." style="min-width: 200px; padding: 8px 12px;" />
    <button class="btn btn-primary" type="submit" style="background-color: var(--accent); border-color: var(--accent); color: white;">Search</button>
  </form>
</div>

<div class="chart-card" style="margin-bottom: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
    <h3 style="font-size: 16px; font-weight: 700; display: flex; align-items: center; gap: 8px;">
      <span>🔧</span> Active Repair Tickets
    </h3>
    <span class="badge info" style="font-size: 11px; font-weight: 600;"><%= tickets.length %> Records</span>
  </div>
  
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Bike Code</th>
          <th>Issue Type</th>
          <th>Diagnostics / Description</th>
          <th>Status</th>
          <th>Technician</th>
          <th>Repair Cost</th>
          <th>Reported</th>
          <th>Target Date</th>
          <th style="text-align: right; padding-right: 24px;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!tickets.length) { %>
        <tr>
          <td colspan="9" class="empty" style="padding: 48px; text-align: center; color: var(--text-muted);">
            <div style="font-size: 32px; margin-bottom: 12px;">📭</div>
            <strong>No maintenance tickets found</strong>
            <p style="font-size: 12px; margin-top: 4px;">There are currently no active repair records matching this filter.</p>
          </td>
        </tr>
        <% } %>
        <% tickets.forEach((ticket, idx) => { %>
        <tr>
          <td style="font-weight: 700; color: var(--text);">
            <a href="/admin/bikes/<%= ticket.bikeId %>" style="color: var(--accent); text-decoration: none; display: flex; align-items: center; gap: 6px;">
              <span>🛵</span> <%= ticket.bikeCode %>
            </a>
          </td>
          <td>
            <span class="badge info" style="font-weight: 600; font-size: 11px;">
              <%= ticket.issueType %>
            </span>
          </td>
          <td style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text-muted);" title="<%= ticket.description %>">
            <%= ticket.description %>
          </td>
          <td>
            <span class="badge <%= ticket.status === 'under_repair' ? 'danger' : ticket.status === 'in_progress' ? 'warning' : 'success' %>" style="font-weight: 700;">
              <%= ticket.status === 'under_repair' ? 'Under Repair' : ticket.status === 'in_progress' ? 'In Progress' : 'Completed' %>
            </span>
          </td>
          <td>
            <% if (ticket.technicianName) { %>
              <div style="display: flex; align-items: center; gap: 8px;">
                <div style="width: 24px; height: 24px; border-radius: 50%; background-color: var(--border); color: var(--text-muted); font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center;">
                  <%= ticket.technicianName.charAt(0).toUpperCase() %>
                </div>
                <span style="font-weight: 500;"><%= ticket.technicianName %></span>
              </div>
            <% } else { %>
              <span style="color: var(--text-light); font-style: italic;">Unassigned</span>
            <% } %>
          </td>
          <td style="font-weight: 700; color: #10b981;">
            ₹<%= Number(ticket.repairCost || 0).toLocaleString('en-IN') %>
          </td>
          <td style="font-size: 12px; color: var(--text-muted);"><%= ticket.reportedDate %></td>
          <td style="font-size: 12px; font-weight: 600; color: #f59e0b;"><%= ticket.expectedFixDate %></td>
          <td class="actions" style="justify-content: flex-end; padding-right: 24px; gap: 6px;">
            <button class="btn btn-sm btn-success admin-action" data-url="/admin/maintenance/<%= ticket.bikeId %>/fixed" data-method="POST" style="background-color: #22c55e; border-color: #22c55e; color: white; padding: 4px 8px; font-size: 11px;">
              🔧 Fix
            </button>
            <button
              class="btn btn-sm btn-outline open-maintenance-status"
              data-id="<%= ticket.id %>"
              data-status="<%= ticket.status %>"
              data-tech="<%= ticket.technicianName %>"
              data-cost="<%= ticket.repairCost %>"
              data-expected="<%= ticket.expectedFixDate %>"
              style="padding: 4px 8px; font-size: 11px;"
            >
              ✏️ Update
            </button>
            <button class="btn btn-sm btn-ghost admin-action" data-url="/admin/maintenance/<%= ticket.id %>/remove" data-method="POST" style="color: #ef4444; padding: 4px 8px; font-size: 11px;">
              🗑️ Delete
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="grid-2">
  <div class="chart-card">
    <h3 style="font-size: 15px; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
      <span>📜</span> Resolved Repair History
    </h3>
    
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Bike Code</th>
            <th>Issue Fixed</th>
            <th>Total Cost</th>
            <th>Completion Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (!history.length) { %>
          <tr><td colspan="4" class="empty" style="text-align: center; color: var(--text-muted);">No completed repairs in history.</td></tr>
          <% } %>
          <% history.slice(0, 10).forEach((item) => { %>
          <tr>
            <td style="font-weight: 700; color: var(--text);"><%= item.bikeCode %></td>
            <td><span class="badge success" style="font-size: 10px;"><%= item.issueType %></span></td>
            <td style="font-weight: 600; color: #10b981;">₹<%= Number(item.repairCost || 0).toLocaleString('en-IN') %></td>
            <td style="font-size: 12px; color: var(--text-muted);"><%= item.fixedDate || '-' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="chart-card">
    <h3 style="font-size: 15px; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
      <span>💬</span> User Support Flagged Tickets
    </h3>
    
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Ticket ID</th>
            <th>Issue Type</th>
            <th>Rider Description</th>
            <th>Status</th>
            <th>Reported Time</th>
          </tr>
        </thead>
        <tbody id="maintenance-support-body">
          <% if (!(supportTickets || []).length) { %>
          <tr><td colspan="5" class="empty" style="text-align: center; color: var(--text-muted);">No active support issues.</td></tr>
          <% } %>
          <% (supportTickets || []).slice(0, 10).forEach((ticket, idx) => { %>
          <tr>
            <td style="font-weight: 700; font-family: monospace;">
              <% if (ticket.ticket_number != null && ticket.ticket_number !== undefined) { %>#<%= ticket.ticket_number %><% } else { %>—<% } %>
              <button class="btn btn-ghost copy-ticket-id" data-value="<%= (ticket.ticket_number != null && ticket.ticket_number !== undefined) ? ticket.ticket_number : '' %>" style="padding: 2px 4px; font-size: 10px; margin-left: 4px;">📋</button>
            </td>
            <td><span class="badge info" style="font-size: 10px;"><%= ticket.issue_type || '-' %></span></td>
            <td style="max-width: 150px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 12px; color: var(--text-muted);" title="<%= ticket.description || '' %>">
              <%= ticket.description || '-' %>
            </td>
            <td>
              <span class="badge <%= ticket.status === 'resolved' ? 'success' : ticket.status === 'in_progress' ? 'warning' : 'danger' %>" style="font-size: 10px;">
                <%= ticket.status === 'in_progress' ? 'In Progress' : ticket.status === 'resolved' ? 'Resolved' : 'Pending' %>
              </span>
            </td>
            <td style="font-size: 11px; color: var(--text-muted);"><%= String(ticket.created_at || '').slice(0, 16).replace('T', ' ') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- MODALS -->
<div class="modal" id="add-maintenance-modal">
  <div class="modal-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h3 style="margin: 0; font-size: 16px; font-weight: 700;">➕ Flag Bike for Maintenance</h3>
      <button class="modal-close" onclick="document.getElementById('add-maintenance-modal').classList.remove('show')">✕</button>
    </div>
    
    <form class="admin-form ajax-form" data-url="/admin/maintenance/add">
      <div class="form-group">
        <label>Select Vehicle to Service</label>
        <select name="bikeId" required>
          <% bikes.forEach((bike) => { %>
          <option value='<%- JSON.stringify({ id: bike.id, bike_code: bike.bike_code }) %>'><%= bike.bike_code %></option>
          <% }) %>
        </select>
      </div>
      
      <div class="form-group">
        <label>Issue Classification</label>
        <input name="issueType" placeholder="e.g. Engine noise, flat tyre, battery cell drain" required />
      </div>
      
      <div class="form-group">
        <label>Diagnostics Description</label>
        <textarea name="description" rows="3" placeholder="Enter detailed diagnostics / physical damage notes..." required></textarea>
      </div>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        <div class="form-group">
          <label>Assigned Technician</label>
          <input type="text" name="technicianName" placeholder="Tech Name" />
        </div>
        <div class="form-group">
          <label>Estimated Cost (₹)</label>
          <input type="number" name="repairCost" placeholder="0" />
        </div>
      </div>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        <div class="form-group">
          <label>Reported Date</label>
          <input type="date" name="reportedDate" required />
        </div>
        <div class="form-group">
          <label>Expected Fix Date</label>
          <input type="date" name="expectedFixDate" required />
        </div>
      </div>
      
      <button type="submit" class="btn btn-gold glow" style="width: 100%; margin-top: 12px; justify-content: center; padding: 10px;">
        Add to Repair Queue
      </button>
    </form>
  </div>
</div>

<div class="modal" id="update-maintenance-modal">
  <div class="modal-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h3 style="margin: 0; font-size: 16px; font-weight: 700;">✏️ Update Repair Status</h3>
      <button class="modal-close" onclick="document.getElementById('update-maintenance-modal').classList.remove('show')">✕</button>
    </div>
    
    <form class="admin-form ajax-form" id="update-maintenance-form" data-url="">
      <div class="form-group">
        <label>Job Progress</label>
        <select name="status" id="maintenance-status">
          <option value="under_repair">Under Repair</option>
          <option value="in_progress">In Progress</option>
          <option value="completed">Completed</option>
        </select>
      </div>
      
      <div class="form-group">
        <label>Assigned Technician</label>
        <input type="text" name="technicianName" id="maintenance-tech" placeholder="Tech Name" />
      </div>
      
      <div class="form-group">
        <label>Actual / Accrued Cost (₹)</label>
        <input type="number" name="repairCost" id="maintenance-cost" placeholder="0" />
      </div>
      
      <div class="form-group">
        <label>Target / Fixed Date</label>
        <input type="date" name="expectedFixDate" id="maintenance-expected" />
      </div>
      
      <button type="submit" class="btn btn-gold glow" style="width: 100%; margin-top: 12px; justify-content: center; padding: 10px;">
        Save Changes
      </button>
    </form>
  </div>
</div>
