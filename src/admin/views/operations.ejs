<!-- Operations Dashboard Specific Styling -->
<style>
  .ops-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }

  .ops-stat {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .ops-stat:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .ops-stat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .ops-stat-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .ops-stat-value {
    font-size: 32px;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
  }

  .ops-stat-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--border-light);
    color: var(--text-muted);
  }

  .ops-stat-green .ops-stat-icon {
    background: rgba(22, 163, 74, 0.1);
    color: #16a34a;
  }

  .ops-stat-blue .ops-stat-icon {
    background: rgba(37, 99, 235, 0.1);
    color: #2563eb;
  }

  .ops-stat-amber .ops-stat-icon {
    background: rgba(217, 119, 6, 0.1);
    color: #d97706;
  }

  .ops-stat-purple .ops-stat-icon {
    background: rgba(147, 51, 234, 0.1);
    color: #9333ea;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #16a34a;
    display: inline-block;
    position: relative;
  }

  .pulse-dot::after {
    content: '';
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: inherit;
    position: absolute;
    top: 0;
    left: 0;
    animation: statPulse 1.8s infinite ease-in-out;
  }

  @keyframes statPulse {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(3.5); opacity: 0; }
  }

  .ops-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 24px;
  }

  .ops-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    margin-bottom: 24px;
  }

  .ops-card-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(0, 0, 0, 0.02);
  }

  body.dark-mode .ops-card-header {
    background: rgba(255, 255, 255, 0.01);
  }

  .ops-card-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ops-card-body {
    padding: 20px;
  }

  /* List Styling */
  .rider-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .rider-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: background 0.15s;
  }

  .rider-item:hover {
    background: var(--border-light);
  }

  .rider-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .rider-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: var(--text);
  }

  .rider-details p {
    margin: 0;
  }

  .rider-name {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text);
  }

  .rider-meta {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 2px !important;
  }

  .rider-status {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* Table styling */
  .ops-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .ops-table th {
    text-align: left;
    padding: 10px 14px;
    font-weight: 600;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    background: var(--border-light);
  }

  .ops-table td {
    padding: 12px 14px;
    border-bottom: 1px solid var(--border-light);
    color: var(--text);
  }

  .ops-table tr:hover td {
    background: var(--border-light);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    border-radius: 20px;
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .badge-pending { background: rgba(217, 119, 6, 0.1); color: #d97706; }
  .badge-accepted { background: rgba(37, 99, 235, 0.1); color: #2563eb; }
  .badge-ongoing { background: rgba(22, 163, 74, 0.1); color: #16a34a; }

  @media (max-width: 1024px) {
    .ops-stats { grid-template-columns: 1fr 1fr; }
    .ops-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- Top Statistics Deck -->
<div class="ops-stats">
  <div class="ops-stat ops-stat-blue">
    <div class="ops-stat-header">
      <span class="ops-stat-title">Active Deliveries</span>
      <span class="ops-stat-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </span>
    </div>
    <div class="ops-stat-value"><%= stats.activeDeliveries %></div>
  </div>

  <div class="ops-stat ops-stat-green">
    <div class="ops-stat-header">
      <span class="ops-stat-title">Online Riders</span>
      <div style="display: flex; align-items: center; gap: 8px;">
        <span class="pulse-dot"></span>
        <span class="ops-stat-icon" style="margin: 0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </span>
      </div>
    </div>
    <div class="ops-stat-value"><%= stats.onlineRiders %></div>
  </div>

  <div class="ops-stat ops-stat-amber">
    <div class="ops-stat-header">
      <span class="ops-stat-title">Bikes In Field</span>
      <span class="ops-stat-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/></svg>
      </span>
    </div>
    <div class="ops-stat-value"><%= stats.bikesInField %></div>
  </div>

  <div class="ops-stat ops-stat-purple">
    <div class="ops-stat-header">
      <span class="ops-stat-title">Skipped Riders Today</span>
      <span class="ops-stat-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
      </span>
    </div>
    <div class="ops-stat-value"><%= stats.skippedRidersCount %></div>
  </div>
</div>

<!-- Double Column Dashboard Grid -->
<div class="ops-grid">

  <!-- Left Column: Active Orders & Delivery Logs -->
  <div>
    <div class="ops-card">
      <div class="ops-card-header">
        <span class="ops-card-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Active Operations Queue
        </span>
        <span style="font-size: 12px; color: var(--text-muted);"><%= activeOrders.length %> active requests</span>
      </div>
      <div class="ops-card-body" style="padding: 0;">
        <% if (activeOrders.length === 0) { %>
          <div style="padding: 40px; text-align: center; color: var(--text-muted);">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:12px; opacity:0.5;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p style="margin:0; font-weight:500;">No active deliveries or orders at the moment.</p>
          </div>
        <% } else { %>
          <div style="overflow-x: auto;">
            <table class="ops-table">
              <thead>
                <tr>
                  <th>Order ID</th>
                  <th>Customer</th>
                  <th>Pickup</th>
                  <th>Destination</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% activeOrders.forEach(o => { %>
                  <tr>
                    <td style="font-weight: 700; color: var(--accent);" title="<%= o.id %>"><%= o.orderId %></td>
                    <td><%= o.userName %></td>
                    <td style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= o.pickup_location || 'N/A' %></td>
                    <td style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= o.drop_location || 'N/A' %></td>
                    <td>
                      <span class="badge badge-<%= o.status %>"><%= o.status %></span>
                    </td>
                    <td>
                      <div style="display:flex; gap:6px;">
                        <a href="/admin/orders/<%= o.id %>" class="btn btn-outline" style="padding: 4px 8px; font-size:11px;">View</a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Today's Skipped Riders Alert List -->
    <div class="ops-card">
      <div class="ops-card-header">
        <span class="ops-card-title" style="color: #9333ea;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
          Rider Attendance Alerts (Today)
        </span>
      </div>
      <div class="ops-card-body" style="padding: 0;">
        <% if (skippedLogs.length === 0) { %>
          <div style="padding: 30px; text-align: center; color: var(--text-muted); font-size: 13px;">
            No skips reported today. Attendance is at 100%.
          </div>
        <% } else { %>
          <table class="ops-table">
            <thead>
              <tr>
                <th>Rider</th>
                <th>Alert Date</th>
                <th>Reason</th>
                <th>Logged At</th>
              </tr>
            </thead>
            <tbody>
              <% skippedLogs.forEach(log => { %>
                <tr>
                  <td style="font-weight: 600;"><%= log.name %></td>
                  <td><%= log.date %></td>
                  <td style="color: var(--text-muted);"><%= log.reason %></td>
                  <td style="font-size:11px; opacity:0.8;"><%= log.created_at %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right Column: Live Online Delivery Personnel -->
  <div>
    <div class="ops-card">
      <div class="ops-card-header">
        <span class="ops-card-title">
          <span class="pulse-dot" style="margin-right: 4px;"></span>
          Riders Online
        </span>
        <span class="badge" style="background: rgba(22, 163, 74, 0.1); color: #16a34a;"><%= onlineRiders.length %> active</span>
      </div>
      <div class="ops-card-body">
        <% if (onlineRiders.length === 0) { %>
          <div style="padding: 40px 20px; text-align: center; color: var(--text-muted); font-size: 13px;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:8px; opacity:0.4;"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            <p style="margin:0;">No delivery partners online right now.</p>
          </div>
        <% } else { %>
          <div class="rider-list">
            <% onlineRiders.forEach(r => { %>
              <div class="rider-item">
                <div class="rider-info">
                  <div class="rider-avatar">
                    <%= r.name.charAt(0).toUpperCase() %>
                  </div>
                  <div class="rider-details">
                    <p class="rider-name"><%= r.name %></p>
                    <p class="rider-meta"><%= r.vehicleType %> • ⭐ <%= r.rating %></p>
                  </div>
                </div>
                <div class="rider-status">
                  <a href="/admin/delivery-partners/<%= r.userId %>" class="btn btn-outline" style="padding: 4px 8px; font-size: 11px;">Profile</a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
