<style>
  :root {
    --chat-accent: #ff7a00;
    --chat-accent-hover: #e06b00;
    --chat-bg-user: rgba(255, 122, 0, 0.08);
    --chat-bg-admin: var(--border-light);
    --chat-border-user: rgba(255, 122, 0, 0.15);
    --chat-border-admin: var(--border);
  }

  .support-container {
    display: flex;
    height: calc(100vh - 180px);
    background: var(--bg-card, #ffffff);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    margin-top: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    animation: fadeInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Left Panel - Ticket List Sidebar */
  .support-sidebar {
    width: 360px;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    background: var(--bg-sidebar, #fafafa);
    flex-shrink: 0;
  }

  .sidebar-header {
    padding: 16px;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sidebar-search-box {
    position: relative;
  }

  .sidebar-search {
    width: 100%;
    padding: 10px 12px 10px 36px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--text);
    font-size: 13px;
    transition: all 0.2s ease;
  }

  .sidebar-search:focus {
    border-color: var(--chat-accent);
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 122, 0, 0.15);
  }

  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 14px;
    pointer-events: none;
  }

  .ticket-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px;
  }

  .ticket-item {
    display: flex;
    flex-direction: column;
    padding: 14px;
    border-radius: 10px;
    margin-bottom: 6px;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid transparent;
    position: relative;
  }

  .ticket-item:hover {
    background: rgba(0, 0, 0, 0.02);
  }

  .ticket-item.active {
    background: rgba(255, 122, 0, 0.06);
    border-color: rgba(255, 122, 0, 0.2);
  }

  .ticket-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }

  .ticket-number {
    font-weight: 700;
    font-size: 14px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ticket-number::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ccc;
  }

  .ticket-item.status-pending .ticket-number::before {
    background: #ef4444;
    box-shadow: 0 0 8px #ef4444;
    animation: pulse 1.5s infinite;
  }

  .ticket-item.status-in_progress .ticket-number::before {
    background: #eab308;
    box-shadow: 0 0 8px #eab308;
    animation: pulse 1.5s infinite;
  }

  .ticket-item.status-resolved .ticket-number::before {
    background: #22c55e;
  }

  .ticket-date {
    font-size: 11px;
    color: var(--text-muted);
  }

  .ticket-meta {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .ticket-issue {
    background: var(--border-light);
    color: var(--text);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ticket-preview {
    font-size: 12px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Right Panel - Chat Console */
  .support-chat {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    position: relative;
    min-height: 0;
    height: 100%;
    max-height: 100%;
    overflow: hidden;
  }

  .chat-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    color: var(--text-muted);
    text-align: center;
    padding: 32px;
    background: radial-gradient(circle at center, rgba(255,122,0,0.02) 0%, transparent 70%);
  }

  .chat-placeholder-icon {
    font-size: 64px;
    margin-bottom: 16px;
    animation: bounceSlow 3s infinite ease-in-out;
  }

  .chat-placeholder h3 {
    font-size: 18px;
    color: var(--text);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .chat-placeholder p {
    font-size: 13px;
    max-width: 320px;
    line-height: 1.5;
  }

  /* Active Chat Content */
  .chat-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-card);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .chat-header-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .chat-header-title {
    font-weight: 700;
    font-size: 16px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .chat-header-subtitle {
    font-size: 12px;
    color: var(--text-muted);
  }

  .chat-header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    min-height: 0;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: rgba(0,0,0,0.01);
  }

  .message-group {
    display: flex;
    flex-direction: column;
    max-width: 75%;
  }

  .message-group.incoming {
    align-self: flex-start;
    align-items: flex-start;
  }

  .message-group.outgoing {
    align-self: flex-end;
    align-items: flex-end;
  }

  .message-bubble {
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 13px;
    line-height: 1.5;
    position: relative;
    box-shadow: 0 2px 6px rgba(0,0,0,0.02);
  }

  .incoming .message-bubble {
    background: var(--chat-bg-user);
    color: var(--text);
    border: 1px solid var(--chat-border-user);
    border-top-left-radius: 2px;
  }

  .outgoing .message-bubble {
    background: var(--chat-bg-admin);
    color: var(--text);
    border: 1px solid var(--chat-border-admin);
    border-top-right-radius: 2px;
  }

  .message-image {
    max-width: 240px;
    max-height: 200px;
    object-fit: contain;
    border-radius: 8px;
    margin-top: 6px;
    border: 1px solid var(--border);
    cursor: pointer;
  }

  .message-time {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  .chat-quick-replies {
    padding: 10px 16px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 8px;
    overflow-x: auto;
    background: var(--bg-card);
    scrollbar-width: none;
  }

  .quick-reply-chip {
    padding: 6px 12px;
    border-radius: 20px;
    background: var(--border-light);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 12px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .quick-reply-chip:hover {
    border-color: var(--chat-accent);
    background: rgba(255, 122, 0, 0.05);
    color: var(--chat-accent);
  }

  .chat-input-area {
    padding: 16px;
    border-top: 1px solid var(--border);
    background: var(--bg-card);
  }

  .chat-input-form {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .chat-textarea {
    flex: 1;
    resize: none;
    height: 44px;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 13px;
    background: var(--bg);
    color: var(--text);
    transition: all 0.2s ease;
    line-height: 1.4;
  }

  .chat-textarea:focus {
    border-color: var(--chat-accent);
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 122, 0, 0.1);
  }

  .chat-send-btn {
    height: 44px;
    width: 44px;
    border-radius: 10px;
    background: var(--chat-accent);
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .chat-send-btn:hover {
    background: var(--chat-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(255, 122, 0, 0.2);
  }

  .chat-send-btn:active {
    transform: translateY(0);
  }

  /* Stat strip */
  .chat-stats-strip {
    display: flex;
    gap: 16px;
    margin-bottom: 12px;
  }

  .chat-stat-card {
    flex: 1;
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 16px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .chat-stat-icon {
    font-size: 24px;
    opacity: 0.8;
  }

  .chat-stat-info {
    display: flex;
    flex-direction: column;
  }

  .chat-stat-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    font-weight: 700;
  }

  .chat-stat-number {
    font-size: 18px;
    font-weight: 800;
    color: var(--text);
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes bounceSlow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
</style>

<div class="chat-stats-strip">
  <div class="chat-stat-card">
    <div class="chat-stat-icon">🎫</div>
    <div class="chat-stat-info">
      <span class="chat-stat-label">Total Support Sessions</span>
      <span class="chat-stat-number" id="stat-total"><%= stats?.total || 0 %></span>
    </div>
  </div>
  <div class="chat-stat-card" style="border-left: 4px solid #ef4444;">
    <div class="chat-stat-icon">🔴</div>
    <div class="chat-stat-info">
      <span class="chat-stat-label">Pending User Chats</span>
      <span class="chat-stat-number" id="stat-pending"><%= stats?.pending || 0 %></span>
    </div>
  </div>
  <div class="chat-stat-card" style="border-left: 4px solid #eab308;">
    <div class="chat-stat-icon">🔄</div>
    <div class="chat-stat-info">
      <span class="chat-stat-label">In Progress Chats</span>
      <span class="chat-stat-number" id="stat-progress"><%= stats?.inProgress || 0 %></span>
    </div>
  </div>
  <div class="chat-stat-card" style="border-left: 4px solid #22c55e;">
    <div class="chat-stat-icon">✅</div>
    <div class="chat-stat-info">
      <span class="chat-stat-label">Resolved Tickets</span>
      <span class="chat-stat-number" id="stat-resolved"><%= stats?.resolved || 0 %></span>
    </div>
  </div>
</div>

<div class="support-container">
  <!-- Left Panel -->
  <div class="support-sidebar">
    <div class="sidebar-header">
      <div class="sidebar-title">
        <span>💬</span> Live Support Chats
      </div>
      <div class="sidebar-search-box">
        <span class="search-icon">🔍</span>
        <input type="text" id="sidebar-search" class="sidebar-search" placeholder="Search by Ticket ID / User ID..." />
      </div>
    </div>
    <div class="ticket-list" id="ticket-list-container">
      <% if (!(tickets || []).length) { %>
        <div style="padding: 32px 16px; text-align: center; color: var(--text-muted); font-size: 13px;">
          No active support chats
        </div>
      <% } else { %>
        <% tickets.forEach((t) => { %>
          <div class="ticket-item status-<%= t.status %>" 
               id="ticket-item-<%= t.id %>"
               data-id="<%= t.id %>"
               data-number="<%= t.ticket_number %>"
               data-user-id="<%= t.user_id %>"
               data-bike="<%= t.bike_name || '' %>"
               data-issue="<%= t.issue_type || '' %>"
               data-desc="<%= t.description || '' %>"
               data-status="<%= t.status %>"
               data-created="<%= t.created_at %>"
               data-image="<%= t.image_url || '' %>"
               onclick="selectTicket(this)">
            <div class="ticket-item-header">
              <span class="ticket-number">#<%= t.ticket_number || 'BB-Chat' %></span>
              <span class="ticket-date"><%= t.relativeCreatedAt || 'Just now' %></span>
            </div>
            <div class="ticket-meta">
              <span>👤 <%= String(t.user_id || 'User').slice(0, 8) %></span>
              <span class="ticket-issue"><%= t.issue_type %></span>
            </div>
            <div class="ticket-preview"><%= t.description || 'No description provided.' %></div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="support-chat" id="chat-panel-container">
    <!-- Placeholder Screen -->
    <div class="chat-placeholder" id="chat-placeholder-el">
      <div class="chat-placeholder-icon">🧑‍💻</div>
      <h3>BharBike Support Desk</h3>
      <p>Select any customer's active Chat ID from the left panel to begin real-time chat assistance.</p>
    </div>

    <!-- Active Chat Screen (Initially Hidden) -->
    <div style="display: none; flex-direction: column; flex: 1; min-height: 0; height: 100%; max-height: 100%; overflow: hidden;" id="chat-active-el">
      <!-- Chat Header -->
      <div class="chat-header">
        <div class="chat-header-info">
          <div class="chat-header-title">
            <span id="active-chat-title">#000000</span>
            <span class="badge" id="active-chat-status-badge">Pending</span>
          </div>
          <div class="chat-header-subtitle">
            <span id="active-chat-user-lbl">User: loading...</span>
            <span style="margin: 0 6px;">•</span>
            <span id="active-chat-issue-lbl">Issue: RSA</span>
          </div>
        </div>
        <div class="chat-header-actions">
          <button class="btn btn-warning" id="btn-open-repair-modal" style="font-size: 12px; padding: 6px 12px; background: #b45309; color: white;">💰 Set Repair Cost</button>
          <button class="btn btn-outline" id="btn-convert-maint" style="font-size: 12px; padding: 6px 12px;">🛠 Convert to Maint.</button>
          <button class="btn btn-info" id="btn-in-progress" style="font-size: 12px; padding: 6px 12px;">⌛ In Progress</button>
          <button class="btn btn-success" id="btn-resolve-ticket" style="font-size: 12px; padding: 6px 12px;">✅ Resolve</button>
        </div>
      </div>

      <!-- Messages Body -->
      <div class="chat-messages" id="chat-messages-container">
        <!-- Message bubbles dynamically populated here -->
      </div>

      <!-- Quick Replies Bar -->
      <div class="chat-quick-replies">
        <div class="quick-reply-chip" onclick="applyQuickReply('Hello! BharBike Support here. How can I help you today?')">👋 Welcome</div>
        <div class="quick-reply-chip" onclick="applyQuickReply('Could you please upload a photo of the vehicle showing the issue?')">📸 Request Photo</div>
        <div class="quick-reply-chip" onclick="applyQuickReply('We are looking into your issue and resolving it right away.')">⏳ Investigating</div>
        <div class="quick-reply-chip" onclick="applyQuickReply('I have successfully refunded/updated your wallet balance. Please check.')">💳 Wallet Updated</div>
        <div class="quick-reply-chip" onclick="applyQuickReply('Your smartlock is now unlocked. You can resume your ride.')">🔓 Smartlock Unlocked</div>
        <div class="quick-reply-chip" onclick="applyQuickReply('This ticket has been resolved. Feel free to reach out if you have any questions!')">✅ Issue Resolved</div>
      </div>

      <!-- Input Form -->
      <div class="chat-input-area">
        <form class="chat-input-form" onsubmit="handleFormSubmit(event)">
          <input type="text" id="chat-input-msg" class="chat-textarea" placeholder="Type your support reply..." autocomplete="off" />
          <button type="submit" class="chat-send-btn">
            <span>✈</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Convert Confirmation Modal -->
<div class="modal" id="support-convert-modal">
  <div class="modal-card">
    <h3>Convert to Maintenance</h3>
    <p style="color:var(--text-muted); font-size: 13px;">Are you sure you want to convert this support ticket to an active maintenance ticket? This will automatically place the bike in maintenance mode.</p>
    <div class="actions" style="margin-top:16px; display:flex; gap: 8px; justify-content: flex-end;">
      <button class="btn btn-outline" onclick="closeConvertModal()">Cancel</button>
      <button id="support-convert-confirm-btn" class="btn btn-gold">Yes, Convert</button>
    </div>
  </div>
</div>

<!-- Assign Repair Cost Modal -->
<div class="modal" id="repair-cost-modal">
  <div class="modal-card">
    <h3>Assign Repair Cost</h3>
    <p style="color:var(--text-muted); font-size: 13px; margin-bottom: 12px;">Set the repair cost. A message will be sent to the user prompting them to pay.</p>
    <div style="display:flex; flex-direction:column; gap: 10px;">
      <input type="number" id="repair-cost-input-modal" placeholder="Cost Amount (₹)" style="padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
      <textarea id="repair-cost-msg-modal" rows="3" placeholder="Message to user (e.g. Please pay the repair cost for the damaged lock...)" style="padding: 8px; border: 1px solid #ccc; border-radius: 4px; resize: none;"></textarea>
    </div>
    <div class="actions" style="margin-top:16px; display:flex; gap: 8px; justify-content: flex-end;">
      <button class="btn btn-outline" onclick="closeRepairCostModal()">Cancel</button>
      <button onclick="confirmRepairCost()" class="btn btn-warning" style="background:#b45309; color:white;">Assign & Send</button>
    </div>
  </div>
</div>

<script>
  let activeTicketId = null;
  let activeTicketData = null;
  let refreshTimer = null;

  // Select a ticket to display in chat panel
  function selectTicket(el) {
    // UI Update left panel
    document.querySelectorAll('.ticket-item').forEach(item => item.classList.remove('active'));
    el.classList.add('active');

    // Extract attributes
    const id = el.dataset.id;
    const number = el.dataset.number;
    const userId = el.dataset.userId;
    const bike = el.dataset.bike;
    const issue = el.dataset.issue;
    const desc = el.dataset.desc;
    const status = el.dataset.status;
    const created = el.dataset.created;
    const image = el.dataset.image;

    activeTicketId = id;
    activeTicketData = { id, number, userId, bike, issue, desc, status, created, image };

    // Toggle panels
    document.getElementById('chat-placeholder-el').style.display = 'none';
    document.getElementById('chat-active-el').style.display = 'flex';

    // Populate header
    document.getElementById('active-chat-title').innerText = 'Ticket #' + number;
    document.getElementById('active-chat-user-lbl').innerText = 'User: ' + userId.slice(0, 8);
    document.getElementById('active-chat-issue-lbl').innerText = 'Issue: ' + (issue === 'rsa' ? 'RSA (Road Side Support)' : issue);
    
    // Status badge styling
    const badge = document.getElementById('active-chat-status-badge');
    badge.innerText = status.toUpperCase().replace('_', ' ');
    badge.className = 'badge';
    if (status === 'resolved') badge.classList.add('success');
    else if (status === 'in_progress') badge.classList.add('warning');
    else badge.classList.add('danger');

    // Attach event listeners for actions
    document.getElementById('btn-resolve-ticket').onclick = () => updateTicketStatus(id, 'resolved');
    document.getElementById('btn-in-progress').onclick = () => updateTicketStatus(id, 'in_progress');
    document.getElementById('btn-convert-maint').onclick = () => openConvertModal(id);
    document.getElementById('btn-open-repair-modal').onclick = () => openRepairCostModal();

    // Initial load of messages
    loadMessages(id);

    // Set polling refresh for live messages every 2 seconds
    if (refreshTimer) clearInterval(refreshTimer);
    refreshTimer = setInterval(() => {
      if (activeTicketId === id) {
        pollMessages(id);
      }
    }, 2000);
  }

  // Load message list from server
  async function loadMessages(ticketId) {
    const container = document.getElementById('chat-messages-container');
    container.innerHTML = '<div style="text-align:center; padding:20px; color:var(--text-muted);">Syncing messages...</div>';

    try {
      const res = await fetch(`/admin/support/ticket/${ticketId}/messages`);
      const payload = await res.json();

      if (payload.success) {
        renderMessages(payload.data);
      } else {
        container.innerHTML = `<div style="text-align:center; padding:20px; color:red;">Error loading messages: ${payload.message}</div>`;
      }
    } catch (e) {
      container.innerHTML = '<div style="text-align:center; padding:20px; color:red;">Network error syncing chat history.</div>';
    }
  }

  // Polling load (silent, doesn't flash loading spinner)
  async function pollMessages(ticketId) {
    try {
      const res = await fetch(`/admin/support/ticket/${ticketId}/messages`);
      const payload = await res.json();
      if (payload.success && activeTicketId === ticketId) {
        renderMessages(payload.data, true);
      }
    } catch (e) {
      console.warn("Live chat polling failed", e);
    }
  }

  // Render message arrays into bubbles
  let currentMsgCount = 0;
  function renderMessages(messages, isPoll = false) {
    const container = document.getElementById('chat-messages-container');
    
    // If it is a poll and message length hasn't changed, skip DOM re-render to save performance
    if (isPoll && messages.length === currentMsgCount) {
      return;
    }
    currentMsgCount = messages.length;

    let html = '';

    // First, render the original ticket description as the starting system/user message if present
    if (activeTicketData && activeTicketData.desc) {
      html += `
        <div class="message-group incoming">
          <div class="message-bubble" style="background:rgba(0,0,0,0.03); border:1px dashed var(--border);">
            <div style="font-weight:700; font-size:11px; color:var(--text-muted); margin-bottom:4px; text-transform:uppercase;">🎫 Initial Issue Description</div>
            <strong>${activeTicketData.issue.toUpperCase().replace('_', ' ')}:</strong> ${activeTicketData.desc}
            ${activeTicketData.image ? `<br/><img class="message-image" src="${activeTicketData.image}" onclick="window.open('${activeTicketData.image}', '_blank')" />` : ''}
          </div>
          <div class="message-time">${new Date(activeTicketData.created).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</div>
        </div>
      `;
    }

    if (messages.length === 0) {
      html += '<div style="text-align:center; padding:20px; color:var(--text-muted); font-size:12px;">No support messages yet. Type below to reply.</div>';
    } else {
      messages.forEach(msg => {
        const isIncoming = msg.sender_type === 'user';
        const groupClass = isIncoming ? 'incoming' : 'outgoing';
        const formattedTime = new Date(msg.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});

        html += `
          <div class="message-group ${groupClass}">
            <div class="message-bubble">
              ${escapeHtml(msg.message)}
              ${msg.image_url ? `<br/><img class="message-image" src="${msg.image_url}" onclick="window.open('${msg.image_url}', '_blank')" />` : ''}
            </div>
            <div class="message-time">${formattedTime}</div>
          </div>
        `;
      });
    }

    container.innerHTML = html;
    container.scrollTop = container.scrollHeight;
  }

  // Apply quick reply
  function applyQuickReply(text) {
    document.getElementById('chat-input-msg').value = text;
    document.getElementById('chat-input-msg').focus();
  }

  // Handle support message form submit
  async function handleFormSubmit(e) {
    e.preventDefault();
    const input = document.getElementById('chat-input-msg');
    const text = input.value.trim();

    if (!text || !activeTicketId) return;

    input.value = '';

    // Optimistic UI update
    const container = document.getElementById('chat-messages-container');
    const optimisticBubble = document.createElement('div');
    optimisticBubble.className = 'message-group outgoing';
    optimisticBubble.innerHTML = `
      <div class="message-bubble" style="opacity: 0.7;">
        ${escapeHtml(text)}
      </div>
      <div class="message-time">Sending...</div>
    `;
    container.appendChild(optimisticBubble);
    container.scrollTop = container.scrollHeight;

    try {
      const res = await fetch(`/admin/support/ticket/${activeTicketId}/messages`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ message: text })
      });
      const payload = await res.json();
      if (payload.success) {
        loadMessages(activeTicketId);
        
        // Update local ticket item in the sidebar status to "in_progress"
        const ticketItem = document.getElementById(`ticket-item-${activeTicketId}`);
        if (ticketItem) {
          ticketItem.dataset.status = 'in_progress';
          ticketItem.className = 'ticket-item active status-in_progress';
        }
      } else {
        alert("Failed to send message: " + payload.message);
        loadMessages(activeTicketId);
      }
    } catch (err) {
      alert("Network failure. Message could not be delivered.");
      loadMessages(activeTicketId);
    }
  }

  // Update support ticket status (Resolved, In Progress)
  async function updateTicketStatus(ticketId, status) {
    try {
      const res = await fetch(`/api/support/ticket/${ticketId}/status`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ status })
      });
      const payload = await res.json();

      if (payload.success) {
        // Update sidebar element status
        const item = document.getElementById(`ticket-item-${ticketId}`);
        if (item) {
          item.dataset.status = status;
          item.className = `ticket-item active status-${status}`;
        }

        // Update badge
        const badge = document.getElementById('active-chat-status-badge');
        badge.innerText = status.toUpperCase().replace('_', ' ');
        badge.className = 'badge';
        if (status === 'resolved') badge.classList.add('success');
        else if (status === 'in_progress') badge.classList.add('warning');
        else badge.classList.add('danger');

        // Show confirmation banner
        const container = document.getElementById('chat-messages-container');
        const alertDiv = document.createElement('div');
        alertDiv.style.cssText = 'text-align:center; padding:8px; border-radius:8px; margin: 10px 0; font-size:12px; background:rgba(0,0,0,0.03); color:var(--text-muted);';
        alertDiv.innerHTML = `⚙ System: Ticket status updated to <strong>${status.toUpperCase()}</strong>`;
        container.appendChild(alertDiv);
        container.scrollTop = container.scrollHeight;
        
        // Refresh stat badges
        refreshStats();
      } else {
        alert("Failed to update status: " + payload.message);
      }
    } catch (e) {
      alert("Error updating status.");
    }
  }

  async function assignRepairCost(ticketId, cost) {
    try {
      const res = await fetch(`/api/admin/support/${ticketId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ repair_cost: cost })
      });
      const payload = await res.json();
      if (payload.success) {
        alert("Repair cost of ₹" + cost + " assigned successfully! The user will be prompted to pay.");
        document.getElementById('repair-cost-input').value = '';
      } else {
        alert("Failed to assign repair cost: " + payload.message);
      }
    } catch (e) {
      alert("Error assigning repair cost.");
    }
  }

  // Open convert to maintenance modal
  function openConvertModal(ticketId) {
    document.getElementById('support-convert-modal').classList.add('show');
    document.getElementById('support-convert-confirm-btn').onclick = () => confirmConvert(ticketId);
  }

  function closeConvertModal() {
    document.getElementById('support-convert-modal').classList.remove('show');
  }

  async function confirmConvert(ticketId) {
    closeConvertModal();
    try {
      const res = await fetch(`/admin/support/${ticketId}/convert`, {
        method: 'POST'
      });
      const payload = await res.json();
      if (payload.success) {
        updateTicketStatus(ticketId, 'in_progress');
        alert("Ticket successfully converted to active Maintenance Job.");
      } else {
        alert("Convert failed: " + payload.message);
      }
    } catch (e) {
      alert("Error converting ticket.");
    }
  }

  // Repair Cost Modal Logic
  function openRepairCostModal() {
    document.getElementById('repair-cost-input-modal').value = '';
    document.getElementById('repair-cost-msg-modal').value = 'A repair cost has been assessed for this ticket. Please pay the amount to proceed.';
    document.getElementById('repair-cost-modal').classList.add('show');
  }

  function closeRepairCostModal() {
    document.getElementById('repair-cost-modal').classList.remove('show');
  }

  async function confirmRepairCost() {
    const cost = document.getElementById('repair-cost-input-modal').value;
    const message = document.getElementById('repair-cost-msg-modal').value;
    if (!cost) return alert("Please enter a repair cost.");
    
    closeRepairCostModal();
    try {
      const res = await fetch(`/api/admin/support/${activeTicketId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ repair_cost: cost })
      });
      const payload = await res.json();
      
      if (!payload.success) {
        return alert("Failed to assign repair cost: " + payload.message);
      }

      if (message.trim()) {
        await fetch(`/admin/support/ticket/${activeTicketId}/messages`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: message.trim() })
        });
      }
      
      alert("Repair cost assigned and message sent successfully!");
      loadMessages(activeTicketId);
    } catch (e) {
      alert("Error assigning repair cost.");
    }
  }

  // Simple HTML Escaper
  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  // Local Search & Filter Sidebar Chats
  document.getElementById('sidebar-search').addEventListener('input', function(e) {
    const q = e.target.value.toLowerCase().trim();
    document.querySelectorAll('.ticket-item').forEach(item => {
      const ticketId = item.dataset.number.toLowerCase();
      const userId = item.dataset.userId.toLowerCase();
      const issue = item.dataset.issue.toLowerCase();
      const desc = item.dataset.desc.toLowerCase();

      if (ticketId.includes(q) || userId.includes(q) || issue.includes(q) || desc.includes(q)) {
        item.style.display = 'flex';
      } else {
        item.style.display = 'none';
      }
    });
  });

  // Fetch updated support stats
  async function refreshStats() {
    // Local calculation based on list datasets
    const allItems = Array.from(document.querySelectorAll('.ticket-item'));
    const total = allItems.length;
    const pending = allItems.filter(i => i.dataset.status === 'pending').length;
    const progress = allItems.filter(i => i.dataset.status === 'in_progress').length;
    const resolved = allItems.filter(i => i.dataset.status === 'resolved').length;

    document.getElementById('stat-total').innerText = total;
    document.getElementById('stat-pending').innerText = pending;
    document.getElementById('stat-progress').innerText = progress;
    document.getElementById('stat-resolved').innerText = resolved;
  }
</script>
