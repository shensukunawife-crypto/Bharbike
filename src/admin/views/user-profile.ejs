<div class="stats-grid">
  <div class="stat-card" style="display: flex; align-items: center; gap: 16px;">
    <% if (user.selfie_url) { %>
      <img src="<%= user.selfie_url %>" alt="User Selfie" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent);">
    <% } else { %>
      <div style="width: 50px; height: 50px; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 24px;">👤</div>
    <% } %>
    <div>
      <div class="stat-head" style="margin-bottom: 4px;"><span class="stat-label">User</span></div>
      <strong class="stat-value"><%= user.full_name || "N/A" %></strong>
    </div>
  </div>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">🧾</span><span class="stat-label">Total Orders</span></div><strong class="stat-value"><%= user.totalOrders %></strong></div>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">💳</span><span class="stat-label">Total Spent</span></div><strong class="stat-value revenue-positive">₹<%= Number(user.totalSpent || 0).toFixed(2) %></strong></div>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">💰</span><span class="stat-label">Wallet Balance</span></div><strong class="stat-value" style="color: var(--accent);">₹<%= Number(user.walletBalance || 0).toFixed(2) %></strong></div>
</div>

<div class="analytics-grid">
  <div class="chart-card">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <h3 style="margin: 0;">User Details</h3>
      <button onclick="document.getElementById('edit-profile-modal').classList.add('show')" class="btn btn-gold glow" style="font-size: 14px; padding: 6px 16px;">Edit Profile</button>
    </div>
    <div class="summary-list" style="display: flex; flex-direction: column; gap: 16px; margin-top: 20px;">
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">User ID</span>
        <strong style="text-align: right; word-break: break-all; max-width: 60%; cursor: help;" title="<%= user.id %>">
          <%= String(user.id).substring(0, 8) %>...<%= String(user.id).slice(-4) %>
        </strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Full Name</span>
        <strong style="text-align: right;"><%= user.full_name || "N/A" %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Phone</span>
        <strong style="text-align: right;"><%= user.phone || "N/A" %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Email</span>
        <strong style="text-align: right; word-break: break-all; max-width: 60%;"><%= user.email || "N/A" %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Address</span>
        <strong style="text-align: right; word-break: break-word; max-width: 60%;"><%= user.address %> 
          <% if (user.address_verified) { %><span style="color: var(--success); font-size: 11px;">(Verified)</span><% } %>
        </strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Emergency Contact</span>
        <strong style="text-align: right;"><%= user.emergency_contact_name %> <br> <span style="font-size: 12px; color: var(--text-muted);"><%= user.emergency_contact_phone %></span></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 12px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500; font-size: 15px;">Location</span>
        <strong style="text-align: right; font-size: 15px;"><%= user.location || "N/A" %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px;">
        <span style="color: #6b7280; font-weight: 500; font-size: 15px;">Joined Date</span>
        <strong style="text-align: right; font-size: 15px;"><%= String(user.joinedDate).slice(0, 10) %></strong>
      </div>
    </div>
  </div>

  <!-- Dedicated Assigned Bike Section -->
  <div class="chart-card" style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 32px 16px;">
    <h3 style="margin: 0 0 16px 0; color: #6b7280; font-size: 16px;">Currently Assigned Bike</h3>
    
    <% if (user.assignedBike && user.assignedBike !== 'None') { %>
      <div style="font-size: 48px; font-weight: bold; color: var(--accent); margin-bottom: 8px;">
        <%= user.assignedBike %>
      </div>
      <div style="color: #10b981; font-size: 14px; margin-bottom: 32px; display: flex; align-items: center; gap: 6px;">
        <span style="width: 8px; height: 8px; background: #10b981; border-radius: 50%; display: inline-block;"></span> Active Rental
      </div>
    <% } else { %>
      <div style="font-size: 32px; font-weight: bold; color: #9ca3af; margin-bottom: 8px;">
        No Bike Assigned
      </div>
      <div style="color: #6b7280; font-size: 14px; margin-bottom: 32px;">
        This user does not currently have an active rental.
      </div>
    <% } %>

    <button onclick="document.getElementById('change-bike-modal').classList.add('show')" class="btn btn-gold glow" style="font-size: 15px; padding: 12px 24px; width: 100%; max-width: 250px;">
      <%= user.assignedBike !== 'None' ? 'Change / Unassign Bike' : 'Assign New Bike' %>
    </button>
  </div>

  <div class="chart-card">
    <h3>User Activity</h3>
    <div class="summary-list" style="display: flex; flex-direction: column; gap: 12px; margin-top: 16px;">
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Last Login</span>
        <strong style="text-align: right;"><%= String(user.lastLogin).slice(0, 16).replace("T", " ") %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Last Order ID</span>
        <strong style="text-align: right; word-break: break-all; max-width: 60%; cursor: help; color: var(--accent);" title="<%= user.lastOrder %>">
          <%= user.lastOrder !== "N/A" ? `Order ${orderHistory.length}` : "N/A" %>
        </strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px;">
        <span style="color: #6b7280; font-weight: 500;">Last Active</span>
        <strong style="text-align: right;"><%= user.lastActive %></strong>
      </div>
    </div>
  </div>
</div>

