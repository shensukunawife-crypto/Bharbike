<div class="stats-grid">
  <div class="stat-card" style="display: flex; align-items: center; gap: 16px;">
    <% if (user.selfie_url) { %>
      <img src="<%= user.selfie_url %>" alt="User Selfie" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent);">
    <% } else { %>
      <div style="width: 50px; height: 50px; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 24px;">👤</div>
    <% } %>
    <div>
      <div class="stat-head" style="margin-bottom: 4px;"><span class="stat-label">User</span></div>
      <strong class="stat-value"><%= user.full_name || "N/A" %></strong>
    </div>
  </div>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">🧾</span><span class="stat-label">Total Orders</span></div><strong class="stat-value"><%= user.totalOrders %></strong></div>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">💳</span><span class="stat-label">Total Spent</span></div><strong class="stat-value revenue-positive">₹<%= Number(user.totalSpent || 0).toFixed(2) %></strong></div>
  <div class="stat-card"><div class="stat-head"><span class="stat-icon">💰</span><span class="stat-label">Wallet Balance</span></div><strong class="stat-value" style="color: var(--accent);">₹<%= Number(user.walletBalance || 0).toFixed(2) %></strong></div>
</div>

<div class="analytics-grid">
  <div class="chart-card">
    <h3>User Details</h3>
    <div class="summary-list" style="display: flex; flex-direction: column; gap: 12px; margin-top: 16px;">
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">User ID</span>
        <strong style="text-align: right; word-break: break-all; max-width: 60%;"><%= user.id %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Full Name</span>
        <strong style="text-align: right;"><%= user.full_name || "N/A" %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Phone</span>
        <strong style="text-align: right;"><%= user.phone || "N/A" %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Email</span>
        <strong style="text-align: right; word-break: break-all; max-width: 60%;"><%= user.email || "N/A" %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Location</span>
        <strong style="text-align: right;"><%= user.location || "N/A" %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Assigned Bike</span>
        <strong style="text-align: right; color: var(--accent);"><%= user.assignedBike %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px;">
        <span style="color: #6b7280; font-weight: 500;">Joined Date</span>
        <strong style="text-align: right;"><%= String(user.joinedDate).slice(0, 10) %></strong>
      </div>
    </div>
  </div>

  <div class="chart-card">
    <h3>User Activity</h3>
    <div class="summary-list" style="display: flex; flex-direction: column; gap: 12px; margin-top: 16px;">
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Last Login</span>
        <strong style="text-align: right;"><%= String(user.lastLogin).slice(0, 16).replace("T", " ") %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb;">
        <span style="color: #6b7280; font-weight: 500;">Last Order ID</span>
        <strong style="text-align: right; word-break: break-all; max-width: 60%;"><%= user.lastOrder %></strong>
      </div>
      <div style="display: flex; justify-content: space-between; padding-bottom: 8px;">
        <span style="color: #6b7280; font-weight: 500;">Last Active</span>
        <strong style="text-align: right;"><%= user.lastActive %></strong>
      </div>
    </div>
  </div>
</div>

<div class="chart-card">
  <h3>Order History</h3>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Pickup</th>
          <th>Drop</th>
          <th>Status</th>
          <th>Amount</th>
        </tr>
      </thead>
      <tbody>
        <% if (!orderHistory.length) { %>
        <tr><td colspan="5" class="empty">No orders found</td></tr>
        <% } %>
        <% orderHistory.forEach((order) => { %>
        <tr>
          <td><%= order.id %></td>
          <td><%= order.pickup_location %></td>
          <td><%= order.drop_location %></td>
          <td><span class="badge"><%= order.status %></span></td>
          <td class="revenue-positive">₹<%= Number(order.amount || 0).toFixed(2) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
