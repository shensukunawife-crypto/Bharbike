<div class="chart-card">
  <h3>Order History</h3>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Pickup</th>
          <th>Drop</th>
          <th>Status</th>
          <th>Amount</th>
        </tr>
      </thead>
      <tbody>
        <% if (orderHistory.length === 0) { %>
        <tr>
          <td colspan="5" style="text-align: center; color: #6b7280;">No past orders found.</td>
        </tr>
        <% } %>
        <% orderHistory.forEach((order, index) => { %>
        <tr>
          <td title="<%= order.id %>" style="cursor: help; font-weight: 500; color: var(--accent);">
            Order <%= orderHistory.length - index %>
          </td>
          <td><%= order.pickup_location %></td>
          <td><%= order.drop_location %></td>
          <td><span class="badge"><%= order.status %></span></td>
          <td class="revenue-positive">₹<%= Number(order.amount || 0).toFixed(2) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal" id="edit-profile-modal">
  <div class="modal-card">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 16px;">
      <h3 style="margin: 0;">Edit User Profile</h3>
      <button type="button" style="background:none; border:none; font-size:24px; cursor:pointer; color:#6b7280;" onclick="document.getElementById('edit-profile-modal').classList.remove('show')">&times;</button>
    </div>
    <form class="admin-form ajax-form" data-url="/admin/users/<%= user.id %>/edit">
      <div style="margin-bottom: 12px;">
        <label style="display:block; font-size:12px; color:#6b7280; margin-bottom:4px;">Full Name</label>
        <input name="full_name" value="<%= user.full_name %>" required />
      </div>
      <div style="margin-bottom: 12px;">
        <label style="display:block; font-size:12px; color:#6b7280; margin-bottom:4px;">Phone</label>
        <input name="phone" value="<%= user.phone %>" required />
      </div>
      <div style="margin-bottom: 12px;">
        <label style="display:block; font-size:12px; color:#6b7280; margin-bottom:4px;">Email</label>
        <input name="email" value="<%= user.email %>" />
      </div>
      <div style="margin-bottom: 12px;">
        <label style="display:block; font-size:12px; color:#6b7280; margin-bottom:4px;">Address</label>
        <input name="address" value="<%= user.address === 'N/A' ? '' : user.address %>" />
      </div>
      <div style="margin-bottom: 12px;">
        <label style="display:block; font-size:12px; color:#6b7280; margin-bottom:4px;">Emergency Contact Name</label>
        <input name="emergency_contact_name" value="<%= user.emergency_contact_name === 'N/A' ? '' : user.emergency_contact_name %>" />
      </div>
      <div style="margin-bottom: 16px;">
        <label style="display:block; font-size:12px; color:#6b7280; margin-bottom:4px;">Emergency Contact Phone</label>
        <input name="emergency_contact_phone" value="<%= user.emergency_contact_phone === 'N/A' ? '' : user.emergency_contact_phone %>" />
      </div>
      <button type="submit" class="btn btn-gold glow" style="width: 100%;">Save Changes</button>
    </form>
  </div>
</div>

<!-- Change Bike Modal -->
<div class="modal" id="change-bike-modal">
  <div class="modal-card">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 16px;">
      <h3 style="margin: 0;">Assign / Change Bike</h3>
      <button type="button" style="background:none; border:none; font-size:24px; cursor:pointer; color:#6b7280;" onclick="document.getElementById('change-bike-modal').classList.remove('show')">&times;</button>
    </div>
    <form class="admin-form ajax-form" data-url="/admin/users/<%= user.id %>/assign-bike">
      <div style="margin-bottom: 16px;">
        <label style="display:block; font-size:12px; color:#6b7280; margin-bottom:4px;">Bike Code</label>
        <input name="bike_code" placeholder="e.g. BB001 (Leave empty to unassign)" value="<%= user.assignedBike === 'None' ? '' : user.assignedBike %>" />
      </div>
      <button type="submit" class="btn btn-gold glow" style="width: 100%;">Assign Bike</button>
    </form>
  </div>
</div>
<script>
  document.querySelectorAll('.upload-doc-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fileInput = form.querySelector('input[type="file"]');
      const docType = form.getAttribute('data-type');
      if (!fileInput.files[0]) return;
      
      const btn = form.querySelector('button');
      const originalText = btn.innerText;
      btn.innerText = 'Uploading...';
      btn.disabled = true;

      const formData = new FormData();
      formData.append('docType', docType);
      formData.append('file', fileInput.files[0]);

      try {
        const res = await fetch("/admin/users/<%= user.id %>/upload-doc", {
          method: 'POST',
          body: formData
        });
        const data = await res.json();
        if (data.success) {
          alert('Document uploaded successfully!');
          window.location.reload();
        } else {
          alert(data.message || 'Upload failed');
        }
      } catch (err) {
        alert('Upload failed: ' + err.message);
      } finally {
        btn.innerText = originalText;
        btn.disabled = false;
      }
    });
  });
</script>
