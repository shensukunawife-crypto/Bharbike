<!-- Stats -->
<div class="page-stat-bar">
  <div class="page-stat">
    <p class="page-stat-label">Total Users</p>
    <p class="page-stat-value"><%= stats.total %></p>
  </div>
  <div class="page-stat" style="--accent:#16a34a;">
    <p class="page-stat-label">Active</p>
    <p class="page-stat-value" style="color:#16a34a;"><%= stats.active %></p>
  </div>
  <div class="page-stat page-stat-accent">
    <p class="page-stat-label">New Today</p>
    <p class="page-stat-value"><%= stats.newToday %></p>
  </div>
  <div class="page-stat">
    <p class="page-stat-label">Blocked</p>
    <p class="page-stat-value" style="color:#dc2626;"><%= stats.blocked %></p>
  </div>
</div>

<!-- Filter bar -->
<form class="filter-bar" method="get" action="/admin/users">
  <input type="text" name="search" placeholder="Search name / email / phone…" value="<%= filters.search %>" />
  <select name="status">
    <option value="all"     <%= filters.status === 'all'     ? 'selected' : '' %>>All Status</option>
    <option value="active"  <%= filters.status === 'active'  ? 'selected' : '' %>>Active</option>
    <option value="blocked" <%= filters.status === 'blocked' ? 'selected' : '' %>>Blocked</option>
  </select>
  <input type="date" name="date" value="<%= filters.date %>" />
  <button type="submit" class="btn btn-primary">Apply</button>
  <button type="button" class="btn btn-primary" data-modal-target="add-user-modal">+ Add User</button>
</form>

<!-- Table -->
<div class="orders-table-card">
  <div class="orders-table-head">
    <span class="orders-table-title">Users</span>
    <span class="orders-table-meta" id="users-count-info"><%= users.length %> users</span>
  </div>
  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;">
      <thead>
        <tr style="background:var(--border-light);border-bottom:1px solid var(--border);">
          <% ['User Info','Phone','Address','Status','Subscription','Assigned Bike','Payment','Wallet','Joined','Actions'].forEach(h => { %>
          <th style="text-align:left;padding:10px 16px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text-muted);"><%=h%></th>
          <% }) %>
        </tr>
      </thead>
      <tbody id="users-tbody">
        <% if (!users.length) { %>
        <tr><td colspan="10" style="text-align:center;color:var(--text-muted);padding:48px;">No users found</td></tr>
        <% } %>
        <% users.forEach(user => { %>
        <tr style="border-bottom:1px solid var(--border-light);" data-user-id="<%= user.id %>" onmouseover="this.style.background='var(--border-light)'" onmouseout="this.style.background=''">
          <td style="padding:13px 16px;font-size:13px;font-weight:600;color:var(--text);">
            <%= user.full_name || 'N/A' %>
            <div style="font-size:11px;color:var(--text-muted);font-weight:400;margin-top:2px;"><%= user.email || 'N/A' %></div>
          </td>
          <td style="padding:13px 16px;font-size:13px;color:var(--text-muted);"><%= user.phone || 'N/A' %></td>
          <td style="padding:13px 16px;font-size:13px;color:var(--text-muted);">
            <%= user.address || user.location || 'N/A' %>
          </td>
          <td style="padding:13px 16px;">
            <span class="st-dot <%= user.isBlocked ? 'st-cancelled' : 'st-ongoing' %>">
              <%= user.statusLabel %>
            </span>
          </td>
          <td style="padding:13px 16px;font-size:13px;">
            <% if (user.subscriptionText && user.subscriptionText !== 'None / Inactive') { %>
              <span class="badge badge-orange" style="font-size:11px; font-weight:600; text-transform:none; padding:4px 10px;"><%= user.subscriptionText %></span>
            <% } else { %>
              <span class="badge badge-gray" style="font-size:11px; font-weight:500; text-transform:none; padding:4px 10px;"><%= user.subscriptionText %></span>
            <% } %>
          </td>
          <td style="padding:13px 16px;font-size:13px;">
            <% if (user.assignedBikeCode && user.assignedBikeCode !== '-') { %>
              <span class="badge badge-orange" style="font-size:11px; font-weight:600; text-transform:none; padding:4px 10px; background-color:#10b981; color:white;"><%= user.assignedBikeCode %></span>
            <% } else { %>
              <span class="badge badge-gray" style="font-size:11px; font-weight:500; text-transform:none; padding:4px 10px;">-</span>
            <% } %>
          </td>
          <td style="padding:13px 16px;font-size:13px;font-weight:600;color:#16a34a;">₹<%= Number(user.totalSpent || 0).toFixed(2) %></td>
          <td style="padding:13px 16px;font-size:13px;font-weight:600;color:var(--accent);">₹<%= Number(user.walletBalance || 0).toFixed(2) %></td>
          <td style="padding:13px 16px;font-size:12px;color:var(--text-muted);"><%= String(user.joinedDate).slice(0, 10) %></td>
          <td style="padding:13px 16px;">
            <div class="row-actions">
              <a class="btn btn-sm" href="/admin/users/<%= user.id %>">View</a>
              <button type="button" class="btn btn-sm open-edit-user"
                data-id="<%= user.id %>"
                data-full-name="<%= user.full_name || '' %>"
                data-phone="<%= user.phone || '' %>"
                data-email="<%= user.email || '' %>"
                data-is-prepaid="<%= user.is_prepaid ? 'true' : 'false' %>"
                data-sub-start="<%= user.subscription ? user.subscription.start_date : '' %>"
                data-sub-end="<%= user.subscription ? user.subscription.end_date : '' %>"
                data-sub-plan="<%= user.subscription ? user.subscription.plan_id : '' %>"
                data-location="<%= user.address || user.location || '' %>">Edit</button>
              <button class="btn btn-sm <%= user.isBlocked ? 'btn-primary' : 'btn-danger' %> admin-action"
                data-url="/admin/users/<%= user.id %>/block" data-method="POST">
                <%= user.isBlocked ? 'Unblock' : 'Block' %>
              </button>
              <button class="btn btn-sm btn-danger admin-action" style="background:white; color:#ef4444; border:1px solid #fca5a5;"
                data-url="/admin/users/<%= user.id %>/delete" data-method="POST" data-confirm="Are you absolutely sure you want to PERMANENTLY delete this user and all their data? This cannot be undone.">
                Delete
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="pagination" id="users-pagination" style="display:none;">
    <span class="pagination-info" id="users-pg-info"></span>
    <div class="pagination-btns" id="users-pg-btns"></div>
  </div>
</div>

<!-- Add User Modal -->
<div class="modal" id="add-user-modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Add User</h3>
      <button class="modal-close" data-modal-close="add-user-modal">✕</button>
    </div>
    <div class="modal-body">
      <form class="admin-form ajax-form" data-url="/admin/users/add">
        <div class="form-group"><label>Full Name</label><input name="full_name" placeholder="Full name" required /></div>
        <div class="form-group"><label>Phone</label><input name="phone" placeholder="Phone" required /></div>
        <div class="form-group"><label>Email</label><input name="email" placeholder="Email" /></div>
        <div class="form-group"><label>Address</label><input name="address" placeholder="Address" /></div>
        <button type="submit" class="btn btn-primary">Create User</button>
      </form>
    </div>
  </div>
</div>

<!-- Edit User Modal -->
<div class="modal" id="edit-user-modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Edit User</h3>
      <button class="modal-close" data-modal-close="edit-user-modal">✕</button>
    </div>
    <div class="modal-body">
      <form class="admin-form ajax-form" id="edit-user-form" data-url="">
        <div class="form-group"><label>Full Name</label><input name="full_name" id="edit-user-full-name" placeholder="Full name" required /></div>
        <div class="form-group"><label>Phone</label><input name="phone" id="edit-user-phone" placeholder="Phone" required /></div>
        <div class="form-group"><label>Email</label><input name="email" id="edit-user-email" placeholder="Email" /></div>
        <div class="form-group"><label>Address</label><input name="address" id="edit-user-location" placeholder="Address" /></div>
        <div class="form-group" style="display:flex;align-items:center;gap:10px;margin-top:10px;margin-bottom:10px;">
          <input type="checkbox" name="is_prepaid" id="edit-user-is-prepaid" value="true" style="width:20px;height:20px;margin:0;" />
          <label for="edit-user-is-prepaid" style="margin:0;font-weight:600;">Pre-paid (Offline Paid)</label>
        </div>
        <div class="form-group">
          <label>Override Subscription Plan</label>
          <select name="sub_plan" id="edit-user-sub-plan">
            <option value="none">None / Inactive</option>
            <option value="weekly">Weekly Plan</option>
            <option value="monthly">Monthly Plan</option>
          </select>
        </div>
        <div class="form-group">
          <label>Subscription Start Date</label>
          <input type="datetime-local" name="sub_start" id="edit-user-sub-start" />
        </div>
        <div class="form-group">
          <label>Subscription Expiry Date</label>
          <input type="datetime-local" name="sub_end" id="edit-user-sub-end" />
        </div>
        <% if (locals.admin && locals.admin.role === 'master_admin') { %>
        <div style="border-top: 1px solid var(--border); margin-top: 15px; padding-top: 15px; margin-bottom: 10px;">
          <h4 style="margin: 0 0 10px 0; color: #ff8a3d; font-size: 14px; display: flex; align-items: center; gap: 6px;">💰 Manage Wallet Balance</h4>
          <div class="form-row" style="display:flex; gap:16px;">
            <div class="form-group" style="flex:1;">
              <label>Action</label>
              <select name="wallet_action">
                <option value="none">-- Select --</option>
                <option value="add">Credit (+)</option>
                <option value="deduct">Deduct (-)</option>
              </select>
            </div>
            <div class="form-group" style="flex:1;">
              <label>Amount (₹)</label>
              <input type="number" name="wallet_amount" placeholder="e.g. 500" min="1" />
            </div>
          </div>
          <div class="form-group" style="margin-bottom: 10px;">
            <label>Reason / Title</label>
            <input type="text" name="wallet_desc" placeholder="e.g. Promotional Bonus or Penalty" />
          </div>
          <div class="form-group" id="wallet-auth-group" style="display:none; margin-bottom: 10px;">
            <label style="color:#ef4444; font-weight:600;">Admin Passcode Required</label>
            <input type="password" name="admin_passcode" id="admin_passcode" placeholder="Enter Admin Passcode" />
          </div>
        </div>
        <% } %>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
          <button type="button" class="btn btn-danger admin-action" data-url="" id="edit-user-delete-btn" data-confirm="Are you sure you want to permanently delete this user?">Delete User</button>
          <button type="submit" class="btn btn-primary">Update User</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function() {
  // Pagination
  function paginate(tbodyId, pgId, infoId, btnsId, countId) {
    const PAGE = 10;
    let cur = 1;
    const pgFuncName = tbodyId.replace(/-/g, '_') + '_pg';
    function go(p) {
      const rows = Array.from(document.querySelectorAll('#' + tbodyId + ' tr[data-' + (tbodyId === 'users-tbody' ? 'user' : 'order') + '-id]'));
      const total = rows.length;
      if (!total) { document.getElementById(pgId).style.display='none'; return; }
      const pages = Math.ceil(total / PAGE);
      cur = Math.max(1, Math.min(p, pages));
      const s = (cur-1)*PAGE, e = Math.min(s+PAGE, total);
      rows.forEach((r,i) => r.style.display = (i>=s && i<e) ? '' : 'none');
      const pg = document.getElementById(pgId);
      if (pages <= 1) { pg.style.display='none'; return; }
      pg.style.display = 'flex';
      document.getElementById(infoId).textContent = 'Showing '+(s+1)+'–'+e+' of '+total;
      if (countId) document.getElementById(countId).textContent = total + ' users';
      let h = '<button class="pg-btn" onclick="'+pgFuncName+'('+(cur-1)+')" '+(cur===1?'disabled':'')+'>‹</button>';
      for (let i=1;i<=pages;i++) {
        h += '<button class="pg-btn '+(i===cur?'active':'')+'" onclick="'+pgFuncName+'('+i+')">'+i+'</button>';
      }
      h += '<button class="pg-btn" onclick="'+pgFuncName+'('+(cur+1)+')" '+(cur===pages?'disabled':'')+'>›</button>';
      document.getElementById(btnsId).innerHTML = h;
    }
    window[pgFuncName] = go;
    go(1);
  }
  paginate('users-tbody','users-pagination','users-pg-info','users-pg-btns','users-count-info');

  const walletActionSelect = document.querySelector('select[name="wallet_action"]');
  const walletAuthGroup = document.getElementById('wallet-auth-group');
  const adminPasscodeInput = document.getElementById('admin_passcode');
  if (walletActionSelect) {
    walletActionSelect.addEventListener('change', function() {
      if (this.value === 'add' || this.value === 'deduct') {
        walletAuthGroup.style.display = 'block';
        adminPasscodeInput.required = true;
      } else {
        walletAuthGroup.style.display = 'none';
        adminPasscodeInput.required = false;
      }
    });
  }
})();
</script>
